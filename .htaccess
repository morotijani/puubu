RewriteEngine On
RewriteBase /kokuromotie/

# Prevent directory listing
Options -Indexes

# Allow existing files and folders to be served directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else goes to public/
RewriteCond %{REQUEST_URI} !^/kokuromotie/public/
RewriteRule ^(.*)$ public/index.php [L]