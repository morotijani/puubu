RewriteEngine On
RewriteBase /kokuromotie/

# Prevent directory listing
Options -Indexes

# Allow existing files to be served directly
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else goes to public/
RewriteCond %{REQUEST_URI} !^/kokuromotie/public/
RewriteRule ^(.*)$ public/index.php [L]