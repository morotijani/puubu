RewriteEngine On
RewriteBase /kokuromotie/

# Prevent directory listing
Options -Indexes

# Explicitly skip rewriting for asset folders
RewriteRule ^(dist|media|assets|vendor)/ - [L]

# Skip for existing files (but not directories, so we can rewrite the root)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Everything else goes to public/
RewriteCond %{REQUEST_URI} !^/kokuromotie/public/
RewriteRule ^(.*)$ public/index.php [L]
