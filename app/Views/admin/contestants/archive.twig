{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}Archived Contestants • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin">Admin</a></li>
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin/contestants">Contestants</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Archive</li>
                </ol>
            </nav>
            <h1 class="fs-4 mb-0">Contestant Archive</h1>
        </div>
    </div>

    <div class="card mb-6">
        <div class="card-header">
            <h3 class="fs-6 mb-0">Soft-Deleted Contestants</h3>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="fs-sm">Contestant</th>
                        <th class="fs-sm">Ballot #</th>
                        <th class="fs-sm">Position</th>
                        <th class="fs-sm text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cont in contestants %}
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-sm me-3">
                                        {% if cont.profile_image %}
                                            <img class="avatar-img rounded-circle" src="{{ PROOT }}media/uploadedprofile/{{ cont.profile_image }}" alt="{{ cont.first_name }}">
                                        {% else %}
                                            <div class="avatar-initials rounded-circle" style="width: 32px; height: 32px; font-size: 0.7rem;">
                                                {{ cont.first_name|first }}{{ cont.last_name|first }}
                                            </div>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <div class="fw-bold text-heading">{{ cont.first_name }} {{ cont.last_name }}</div>
                                        <div class="fs-sm text-muted">{{ cont.title }}</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-secondary">{{ cont.contestant_ballot_number }}</span></td>
                            <td>{{ cont.position_name }}</td>
                            <td class="text-end">
                                <a href="{{ PROOT }}admin/contestants/toggle-delete/{{ cont.uuid }}/no" class="btn btn-sm btn-success">
                                    <i class="bi bi-arrow-counterclockwise"></i> Restore
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">No archived contestants found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
