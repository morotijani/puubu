{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}{{ contestant ? 'Edit' : 'Add' }} Contestant • Puubu Admin{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card">
                <div class="card-body p-5">
                    <h2 class="mb-4">{{ contestant ? 'Edit' : 'Register New' }} Contestant</h2>
                    
                    <form action="{{ PROOT }}admin/contestants/store" method="POST" enctype="multipart/form-data">
                        {{ csrf_field() }}
                        {% if contestant %}
                            <input type="hidden" name="contestant_id" value="{{ contestant.contestant_id }}">
                            <input type="hidden" name="old_profile" value="{{ contestant.cont_profile }}">
                        {% endif %}

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" class="form-control" name="cont_fname" value="{{ contestant.cont_fname }}" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" class="form-control" name="cont_lname" value="{{ contestant.cont_lname }}" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Gender</label>
                                <select class="form-control" name="cont_gender" required>
                                    <option value="">Select Gender</option>
                                    <option value="male" {{ contestant.cont_gender == 'male' ? 'selected' : '' }}>Male</option>
                                    <option value="female" {{ contestant.cont_gender == 'female' ? 'selected' : '' }}>Female</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Ballot / ID Number</label>
                                <input type="text" class="form-control" name="contestant_ballot_number" value="{{ contestant.contestant_ballot_number }}" required>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">Election</label>
                                <select class="form-control" name="sel_election" id="electionSelect" required>
                                    <option value="">Select Election</option>
                                    {% for election in elections %}
                                        <option value="{{ election.election_id }}" {{ contestant.contestant_election == election.election_id ? 'selected' : '' }}>
                                            {{ election.election_name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Position</label>
                                <select class="form-control" name="cont_position" id="positionSelect" required>
                                    <option value="">Select Position</option>
                                    {% for pos in positions %}
                                        <option value="{{ pos.position_id }}" {{ contestant.cont_position == pos.position_id ? 'selected' : '' }}>
                                            {{ pos.position_name }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Passport Picture</label>
                                {% if contestant.cont_profile %}
                                    <div class="mb-3">
                                        <img src="{{ PROOT }}media/uploadedprofile/{{ contestant.cont_profile }}" class="img-thumbnail" style="width: 150px;">
                                        <p class="text-muted small">Current photo. Upload new to replace.</p>
                                    </div>
                                {% endif %}
                                <input type="file" class="form-control" name="cont_profile" accept="image/*" {{ contestant ? '' : 'required' }}>
                            </div>
                        </div>

                        <div class="mt-5 d-flex gap-2">
                            <button type="submit" class="btn btn-primary px-5">
                                {{ contestant ? 'Update Contestant' : 'Create Contestant' }}
                            </button>
                            <a href="{{ PROOT }}admin/contestants" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function() {
    $('#electionSelect').on('change', function() {
        var electionId = $(this).val();
        if (electionId) {
            $.ajax({
                url: '{{ PROOT }}admin/api/positions/' + electionId,
                type: 'GET',
                success: function(data) {
                    var $posSelect = $('#positionSelect');
                    $posSelect.empty().append('<option value="">Select Position</option>');
                    $.each(data, function(i, pos) {
                        $posSelect.append($('<option>', {
                            value: pos.position_id,
                            text: pos.position_name
                        }));
                    });
                }
            });
        }
    });
});
</script>
{% endblock %}
