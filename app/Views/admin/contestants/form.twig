{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}{{ contestant ? 'Edit' : 'Add' }} Contestant • Kokuromotie Admin{% endblock %}

{% block content %}
    <div class="page-header d-flex align-items-center mb-5">
        <a href="{{ PROOT }}admin/contestants" class="btn btn-light btn-sm me-3 px-2 shadow-sm">
            <span class="material-symbols-outlined fs-5">arrow_back</span>
        </a>
        <div>
            <h1>{{ contestant ? 'Candidate Profile Editor' : 'Register New Candidate' }}</h1>
            <p>{{ contestant ? 'Modify campaign parameters for' : 'Deploy a new candidate profile for' }} the upcoming session.</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-xl-11">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-0">
                    <form action="{{ PROOT }}admin/contestants/store" method="POST" enctype="multipart/form-data">
                        {{ csrf_field()|raw }}
                        {% if contestant %}
                            <input type="hidden" name="uuid" value="{{ contestant.uuid }}">
                            <input type="hidden" name="old_profile" value="{{ contestant.profile_image }}">
                        {% endif %}

                        <div class="row g-0">
                            <!-- Profile Sidebar -->
                            <div class="col-lg-4 border-end bg-light bg-opacity-50">
                                <div class="p-5 text-center">
                                    <h6 class="premium-label mb-4">Candidate Identity</h6>
                                    
                                    <div class="mb-4">
                                        <div class="position-relative d-inline-block">
                                            <div class="profile-preview-wrapper shadow-lg rounded-circle border border-4 border-white overflow-hidden" style="width: 180px; height: 180px;">
                                                <img id="profilePreview" src="{{ contestant.profile_image ? PROOT ~ 'media/uploadedprofile/' ~ contestant.profile_image : 'https://ui-avatars.com/api/?name=' ~ (contestant ? contestant.first_name ~ '+' ~ contestant.last_name : 'Candidate') ~ '&background=064e3b&color=fff&size=200' }}" class="w-100 h-100 object-fit-cover">
                                            </div>
                                            <label for="profile_image" class="btn btn-primary btn-sm rounded-circle position-absolute bottom-0 end-0 p-2 shadow-lg" style="width: 40px; height: 40px;">
                                                <span class="material-symbols-outlined fs-5">photo_camera</span>
                                            </label>
                                        </div>
                                    </div>

                                    <input type="file" class="d-none" name="profile_image" id="profile_image" accept="image/*">
                                    <div class="px-4">
                                        <p class="extra-small text-muted mb-0 mt-3">Upload a high-resolution portrait for the digital ballot. Supported: JPG, PNG, WebP.</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Form Content -->
                            <div class="col-lg-8">
                                <div class="p-5">
                                    <div class="row g-4">
                                        <div class="col-12">
                                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                                <span class="material-symbols-outlined me-2 text-primary">badge</span> Biographical Parameters
                                            </h5>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <label class="form-label">First Name</label>
                                            <input type="text" class="form-control" name="first_name" value="{{ contestant.first_name }}" placeholder="Legal first name" required>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Last Name</label>
                                            <input type="text" class="form-control" name="last_name" value="{{ contestant.last_name }}" placeholder="Legal surname" required>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Identity Gender</label>
                                            <select class="form-select" name="gender" required>
                                                <option value="">Select gender...</option>
                                                <option value="male" {{ contestant.gender == 'male' ? 'selected' : '' }}>Male</option>
                                                <option value="female" {{ contestant.gender == 'female' ? 'selected' : '' }}>Female</option>
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Ballot Intelligence ID</label>
                                            <input type="text" class="form-control" name="contestant_ballot_number" value="{{ contestant.contestant_ballot_number }}" placeholder="e.g. 01" required>
                                        </div>

                                        <div class="col-12 mt-5">
                                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                                <span class="material-symbols-outlined me-2 text-primary">assignment_ind</span> Deployment Matrix
                                            </h5>
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label">Electoral Session</label>
                                            <select class="form-select" name="sel_election" id="electionSelect" required>
                                                <option value="">Choose session...</option>
                                                {% for election in elections %}
                                                    <option value="{{ election.uuid }}" {{ contestant.election_uuid == election.uuid ? 'selected' : '' }}>
                                                        {{ election.title }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label">Contesting Office</label>
                                            <select class="form-select" name="position_id" id="positionSelect" required>
                                                <option value="">Choose office...</option>
                                                {% for pos in positions %}
                                                    <option value="{{ pos.position_id }}" {{ contestant.position_id == pos.position_id ? 'selected' : '' }}>
                                                        {{ pos.position_name }}
                                                    </option>
                                                {% endfor %}
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mt-5 pt-4 d-flex gap-3">
                                        <button type="submit" class="btn btn-primary px-5 py-3">
                                            {{ contestant ? 'Apply Modifications' : 'Initialize Registration' }}
                                        </button>
                                        <a href="{{ PROOT }}admin/contestants" class="btn btn-light px-4 py-3">Discard</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
    .object-fit-cover { object-fit: cover; }
    .tracking-wider { letter-spacing: 0.05em; }
</style>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function() {
    // Dynamic Position Loading
    $('#electionSelect').on('change', function() {
        var electionId = $(this).val();
        if (electionId) {
            $.ajax({
                url: '{{ PROOT }}admin/api/positions/' + electionId,
                type: 'GET',
                success: function(data) {
                    var $posSelect = $('#positionSelect');
                    $posSelect.empty().append('<option value="">Select Position</option>');
                    $.each(data, function(i, pos) {
                        $posSelect.append($('<option>', {
                            value: pos.position_id,
                            text: pos.position_name
                        }));
                    });
                }
            });
        }
    });

    // Image Preview
    $('#profile_image').on('change', function() {
        var reader = new FileReader();
        reader.onload = function(e) {
            $('#profilePreview').attr('src', e.target.result);
        }
        reader.readAsDataURL(this.files[0]);
    });
});
</script>
{% endblock %}

