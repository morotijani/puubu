{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}{{ contestant ? 'Edit' : 'Add' }} Contestant • Puubu Admin{% endblock %}

{% block content %}
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">
            <div class="d-flex align-items-center mb-5">
                <a href="{{ PROOT }}admin/contestants" class="btn btn-white border shadow-sm btn-sm me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h1 class="h3 fw-bold mb-1">{{ contestant ? 'Edit' : 'Register' }} Candidate</h1>
                    <p class="text-muted small mb-0">Fill in the details to {{ contestant ? 'update the' : 'register a new' }} candidate for the election.</p>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <form action="{{ PROOT }}admin/contestants/store" method="POST" enctype="multipart/form-data">
                        {{ csrf_field()|raw }}
                        {% if contestant %}
                            <input type="hidden" name="contestant_id" value="{{ contestant.contestant_id }}">
                            <input type="hidden" name="old_profile" value="{{ contestant.cont_profile }}">
                        {% endif %}

                        <div class="row g-4">
                            <!-- Left Column: Bio & Identity -->
                            <div class="col-lg-8">
                                <div class="row g-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">First Name</label>
                                        <input type="text" class="form-control form-control-lg bg-light border-0" name="cont_fname" value="{{ contestant.cont_fname }}" placeholder="e.g. John" required>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">Last Name</label>
                                        <input type="text" class="form-control form-control-lg bg-light border-0" name="cont_lname" value="{{ contestant.cont_lname }}" placeholder="e.g. Doe" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">Gender</label>
                                        <select class="form-select form-control-lg bg-light border-0" name="cont_gender" required>
                                            <option value="">Select Gender</option>
                                            <option value="male" {{ contestant.cont_gender == 'male' ? 'selected' : '' }}>Male</option>
                                            <option value="female" {{ contestant.cont_gender == 'female' ? 'selected' : '' }}>Female</option>
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">Ballot / ID Number</label>
                                        <input type="text" class="form-control form-control-lg bg-light border-0" name="contestant_ballot_number" value="{{ contestant.contestant_ballot_number }}" placeholder="e.g. 001" required>
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">Target Election</label>
                                        <select class="form-select form-control-lg bg-light border-0" name="sel_election" id="electionSelect" required>
                                            <option value="">Select Election</option>
                                            {% for election in elections %}
                                                <option value="{{ election.uuid }}" {{ contestant.election_uuid == election.uuid ? 'selected' : '' }}>
                                                    {{ election.title }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-uppercase tracking-wider">Contesting Office</label>
                                        <select class="form-select form-control-lg bg-light border-0" name="cont_position" id="positionSelect" required>
                                            <option value="">Select Position</option>
                                            {% for pos in positions %}
                                                <option value="{{ pos.position_id }}" {{ contestant.cont_position == pos.position_id ? 'selected' : '' }}>
                                                    {{ pos.position_name }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Column: Profile Picture -->
                            <div class="col-lg-4">
                                <div class="bg-light rounded-4 p-4 text-center h-100 d-flex flex-column justify-content-center">
                                    <label class="form-label small fw-bold text-uppercase tracking-wider d-block mb-3">Candidate Photo</label>
                                    
                                    <div class="mb-4">
                                        <div class="position-relative d-inline-block">
                                            <img id="profilePreview" src="{{ contestant.cont_profile ? PROOT ~ 'media/uploadedprofile/' ~ contestant.cont_profile : 'https://ui-avatars.com/api/?name=' ~ (contestant ? contestant.cont_fname ~ '+' ~ contestant.cont_lname : 'Candidate') ~ '&background=6366f1&color=fff' }}" class="rounded-circle border shadow-sm object-fit-cover" width="160" height="160">
                                            <div class="position-absolute bottom-0 end-0">
                                                <label for="cont_profile" class="btn btn-indigo btn-sm rounded-circle p-2 shadow">
                                                    <i class="bi bi-camera-fill"></i>
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <input type="file" class="d-none" name="cont_profile" id="cont_profile" accept="image/*" {{ contestant ? '' : 'required' }}>
                                    <p class="text-muted extra-small mb-0">Recommended size: 500x500px. JPG, PNG or WebP.</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-4 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-indigo px-5 py-3 fw-bold shadow-sm">
                                {{ contestant ? 'Update Candidate' : 'Confirm Registration' }}
                            </button>
                            <a href="{{ PROOT }}admin/contestants" class="btn btn-white border px-4 py-3 fw-bold">Discard</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
    .object-fit-cover { object-fit: cover; }
    .tracking-wider { letter-spacing: 0.05em; }
</style>
{% endblock %}

{% block scripts %}
<script>
$(document).ready(function() {
    // Dynamic Position Loading
    $('#electionSelect').on('change', function() {
        var electionId = $(this).val();
        if (electionId) {
            $.ajax({
                url: '{{ PROOT }}admin/api/positions/' + electionId,
                type: 'GET',
                success: function(data) {
                    var $posSelect = $('#positionSelect');
                    $posSelect.empty().append('<option value="">Select Position</option>');
                    $.each(data, function(i, pos) {
                        $posSelect.append($('<option>', {
                            value: pos.position_id,
                            text: pos.position_name
                        }));
                    });
                }
            });
        }
    });

    // Image Preview
    $('#cont_profile').on('change', function() {
        var reader = new FileReader();
        reader.onload = function(e) {
            $('#profilePreview').attr('src', e.target.result);
        }
        reader.readAsDataURL(this.files[0]);
    });
});
</script>
{% endblock %}
