{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}Contestants Registry • Puubu{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
        <div>
            <h1 class="h3 fw-bold mb-1">Contestants Registry</h1>
            <p class="text-muted small mb-0">Manage candidates and their associated electoral campaigns.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            <a href="{{ PROOT }}admin/contestants/archive" class="btn btn-light shadow-sm">
                <i class="bi bi-archive me-1"></i> Archive
            </a>
            <a href="{{ PROOT }}admin/contestants/add" class="btn btn-indigo shadow-sm">
                <i class="bi bi-person-plus-fill me-1"></i> Add Candidate
            </a>
        </div>
    </div>

    <!-- Contestants Registry -->
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white border-bottom pt-4 px-4 pb-3">
            <div class="row align-items-center g-3">
                <div class="col-md-auto">
                    <h5 class="fw-bold mb-0">Active Candidates</h5>
                </div>
                <div class="col-md-3 ms-md-auto">
                    <select id="electionFilter" class="form-select form-select-sm bg-light border-0 shadow-none">
                        <option value="all">All Elections</option>
                        {% for election in elections %}
                            <option value="{{ election.election_id }}">{{ election.election_name }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" id="contestantSearch" class="form-control bg-light border-0" placeholder="Search by name, office...">
                    </div>
                </div>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table align-middle" id="contestantsTable">
                <thead>
                    <tr>
                        <th class="ps-4">Candidate Profile</th>
                        <th>Ballot No.</th>
                        <th>Target Office</th>
                        <th class="text-end pe-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cont in contestants %}
                        <tr class="contestant-row" data-election-id="{{ cont.contestant_election }}">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="position-relative me-3">
                                        <img class="rounded-circle border shadow-sm" src="{{ PROOT }}media/uploadedprofile/{{ cont.cont_profile }}" width="42" height="42" alt="{{ cont.cont_fname }}" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name={{ cont.cont_fname|url_encode }}+{{ cont.cont_lname|url_encode }}&background=6366f1&color=fff'">
                                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle"></span>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6">{{ cont.cont_fname }} {{ cont.cont_lname }}</div>
                                        <div class="text-muted extra-small d-flex align-items-center">
                                            <i class="bi bi-box-seam me-1"></i> {{ cont.election_name }}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-indigo-subtle text-indigo px-3 py-1 border border-indigo-subtle fw-bold">{{ cont.contestant_ballot_number }}</span>
                            </td>
                            <td>
                                <div class="fw-medium text-dark">{{ cont.position_name }}</div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group shadow-sm rounded">
                                    {% if cont.session == 0 %}
                                        <a href="{{ PROOT }}admin/contestants/edit/{{ cont.contestant_id }}" class="btn btn-sm btn-white border border-end-0">
                                            <i class="bi bi-pencil-square text-muted"></i>
                                        </a>
                                        <a href="{{ PROOT }}admin/contestants/toggle-delete/{{ cont.contestant_id }}/yes" class="btn btn-sm btn-white border text-danger" onclick="return confirm('Move this candidate to the archive?')">
                                            <i class="bi bi-archive"></i>
                                        </a>
                                    {% else %}
                                        <span class="badge bg-light text-muted border px-3">Session Locked</span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="mb-2"><i class="bi bi-person-badge fs-1 opacity-25"></i></div>
                                No active candidates found in the registry.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        function performFiltering() {
            var searchTerm = $("#contestantSearch").val().toLowerCase();
            var electionId = $("#electionFilter").val();
            var visibleRows = 0;

            $(".contestant-row").each(function() {
                var $row = $(this);
                var rowText = $row.text().toLowerCase();
                var rowElectionId = $row.data("election-id");

                var matchesSearch = rowText.indexOf(searchTerm) > -1;
                var matchesElection = (electionId === "all" || rowElectionId == electionId);

                if (matchesSearch && matchesElection) {
                    $row.show();
                    visibleRows++;
                } else {
                    $row.hide();
                }
            });

            if (visibleRows === 0 && $(".contestant-row").length > 0) {
                if ($("#noFilterResults").length === 0) {
                    $("#contestantsTable tbody").append('<tr id="noFilterResults"><td colspan="4" class="text-center py-5 text-muted">No candidates match your criteria.</td></tr>');
                }
            } else {
                $("#noFilterResults").remove();
            }
        }

        $("#contestantSearch").on("keyup", performFiltering);
        $("#electionFilter").on("change", performFiltering);
    });
</script>
{% endblock %}
