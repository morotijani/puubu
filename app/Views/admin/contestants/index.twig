{% extends "admin/layout.twig" %}

{% set active_page = 'contestants' %}

{% block title %}Contestants Registry • Kokuromotie{% endblock %}

{% block content %}
    <div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div>
            <h1>Contestants Registry</h1>
            <p>Manage candidates and their associated electoral campaigns.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            <a href="{{ PROOT }}admin/contestants/archive" class="btn btn-light shadow-sm">
                <span class="material-symbols-outlined fs-6">archive</span> View Archive
            </a>
            <a href="{{ PROOT }}admin/contestants/add" class="btn btn-primary shadow-sm">
                <span class="material-symbols-outlined fs-6">person_add</span> Add Candidate
            </a>
        </div>
    </div>

    <!-- Contestants Registry -->
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header border-0 pb-3">
            <div class="row align-items-center g-3 w-100">
                <div class="col-md-auto">
                    <h5 class="fw-bold mb-0">Active Candidates</h5>
                </div>
                <div class="col-md-3 ms-md-auto">
                    <select id="electionFilter" class="form-select bg-light border-0">
                        <option value="all">All Elections</option>
                        {% for election in elections %}
                            <option value="{{ election.uuid }}">{{ election.title }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><span class="material-symbols-outlined fs-6 text-muted">search</span></span>
                        <input type="text" id="contestantSearch" class="form-control bg-light border-0" placeholder="Search by name, office...">
                    </div>
                </div>
            </div>
        </div>
        <div class="table-container">
            <table class="table align-middle" id="contestantsTable">
                <thead>
                    <tr>
                        <th class="ps-4">Candidate Profile</th>
                        <th>Ballot No.</th>
                        <th>Target Office</th>
                        <th class="text-end pe-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    {% for cont in contestants %}
                        <tr class="contestant-row" data-election-id="{{ cont.election_uuid }}">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="position-relative me-3">
                                        {% if cont.profile_image and cont.profile_image != '' %}
                                            <img class="rounded-circle border shadow-sm" src="{{ PROOT }}media/uploadedprofile/{{ cont.profile_image }}" width="45" height="45" alt="{{ cont.first_name }}" style="object-fit: cover;">
                                        {% else %}
                                            <div class="stat-icon bg-primary text-white rounded-circle fw-bold shadow-sm" style="width: 45px; height: 45px; font-size: 0.9rem; border: 2px solid #fff;">
                                                {{ cont.first_name|first|upper }}{{ cont.last_name|first|upper }}
                                            </div>
                                        {% endif %}
                                        <span class="position-absolute bottom-0 end-0 p-1 bg-success border border-white rounded-circle" style="width: 12px; height: 12px;"></span>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6">{{ cont.first_name }} {{ cont.last_name }}</div>
                                        <div class="text-muted extra-small d-flex align-items-center">
                                            <span class="material-symbols-outlined me-1 fs-6">inventory_2</span> {{ cont.title }}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-light text-primary border fw-bold px-3">#{{ cont.contestant_ballot_number }}</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">{{ cont.position_name }}</div>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    {% if cont.status == 0 %}
                                        <a href="{{ PROOT }}admin/contestants/edit/{{ cont.uuid }}" class="btn btn-light btn-sm px-2">
                                            <span class="material-symbols-outlined fs-6">edit</span>
                                        </a>
                                        <a href="{{ PROOT }}admin/contestants/toggle-delete/{{ cont.uuid }}/yes" class="btn btn-light btn-sm px-2 text-danger" onclick="return confirm('Archive candidate?')">
                                            <span class="material-symbols-outlined fs-6">archive</span>
                                        </a>
                                    {% else %}
                                        <span class="badge badge-secondary px-3">Registry Locked</span>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined fs-1 opacity-25">badge</span>
                                <p class="mt-2">No active candidates found in the registry.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        function performFiltering() {
            var searchTerm = $("#contestantSearch").val().toLowerCase();
            var electionId = $("#electionFilter").val();
            var visibleRows = 0;

            $(".contestant-row").each(function() {
                var $row = $(this);
                var rowText = $row.text().toLowerCase();
                var rowElectionId = $row.data("election-id");

                var matchesSearch = rowText.indexOf(searchTerm) > -1;
                var matchesElection = (electionId === "all" || rowElectionId == electionId);

                if (matchesSearch && matchesElection) {
                    $row.show();
                    visibleRows++;
                } else {
                    $row.hide();
                }
            });

            if (visibleRows === 0 && $(".contestant-row").length > 0) {
                if ($("#noFilterResults").length === 0) {
                    $("#contestantsTable tbody").append('<tr id="noFilterResults"><td colspan="4" class="text-center py-5 text-muted">No candidates match your criteria.</td></tr>');
                }
            } else {
                $("#noFilterResults").remove();
            }
        }

        $("#contestantSearch").on("keyup", performFiltering);
        $("#electionFilter").on("change", performFiltering);
    });
</script>
{% endblock %}

