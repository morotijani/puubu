{% extends "admin/layout.twig" %}

{% set active_page = 'dashboard' %}

{% block title %}Admin Dashboard • Kokuromotie{% endblock %}

{% block content %}
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1>Dashboard</h1>
            <p>Electoral intelligence and infrastructure overview.</p>
        </div>
        <div class="d-none d-md-block">
            <div class="btn btn-light shadow-sm">
                <span class="material-symbols-outlined fs-5">calendar_today</span> {{ "now"|date("l, F j, Y") }}
            </div>
        </div>
    </div>

    <!-- Stats Intelligence Grid -->
    <div class="row g-4 mb-5">
        {% if admin.role == 'super_admin' %}
            <div class="col-12 col-md-6">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>Total Organizers</h4>
                        <h2>{{ stats.total_organizers }}</h2>
                    </div>
                    <div class="stat-icon" style="background-color: var(--admin-bg);">
                        <span class="material-symbols-outlined">corporate_fare</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>Global Elections</h4>
                        <h2>{{ stats.total_elections }}</h2>
                    </div>
                    <div class="stat-icon" style="background-color: var(--admin-bg);">
                        <span class="material-symbols-outlined">public</span>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 col-md-6 col-xl-3">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>My Elections</h4>
                        <h2>{{ stats.total_elections }}</h2>
                    </div>
                    <div class="stat-icon" style="background-color: var(--admin-bg);">
                        <span class="material-symbols-outlined">event_note</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>Total Voters</h4>
                        <h2>{{ stats.total_voters }}</h2>
                    </div>
                    <div class="stat-icon" style="background-color: var(--admin-bg);">
                        <span class="material-symbols-outlined">badge</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>Positions</h4>
                        <h2>{{ stats.total_positions }}</h2>
                    </div>
                    <div class="stat-icon" style="background-color: var(--admin-bg);">
                        <span class="material-symbols-outlined">account_tree</span>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-6 col-xl-3">
                <div class="card stat-card">
                    <div class="stat-info">
                        <h4>Total Participation</h4>
                        <h2 class="text-indigo">{{ stats.total_votes_cast|default(0) }}</h2>
                    </div>
                    <div class="stat-icon bg-indigo-subtle">
                        <span class="material-symbols-outlined text-indigo">how_to_vote</span>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>

    {% if admin.role == 'super_admin' %}
    <!-- Recent Organizers -->
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header border-0">
            <div>
                <h5>Recent Institutional Registrations</h5>
            </div>
            <a href="{{ PROOT }}admin/organizers" class="btn btn-light btn-sm">
                Management <span class="material-symbols-outlined fs-6">chevron_right</span>
            </a>
        </div>
        <div class="table-container">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Institution/Organizer</th>
                        <th>Email Address</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Management</th>
                    </tr>
                </thead>
                <tbody>
                    {% for org in recent_organizers %}
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="stat-icon me-3" style="width: 40px; height: 40px; font-size: 1rem;">
                                        {{ org.first_name|slice(0, 1) }}{{ org.last_name|slice(0, 1) }}
                                    </div>
                                    <div class="fw-bold">{{ org.first_name }} {{ org.last_name }}</div>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted">{{ org.email }}</span>
                            </td>
                            <td>
                                <span class="badge badge-success">Verified</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-light btn-sm py-1 px-3">
                                    <span class="material-symbols-outlined fs-6">settings</span>
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined fs-1 opacity-25">person_off</span>
                                <p class="mt-2">No organizers registered yet.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    <!-- Election Sessions -->
    <div class="card border-0 shadow-sm">
        <div class="card-header border-0">
            <div>
                <h5>Active Electoral Infrastructure</h5>
            </div>
            <a href="{{ PROOT }}admin/elections" class="btn btn-light btn-sm">
                Full Registry <span class="material-symbols-outlined fs-6">chevron_right</span>
            </a>
        </div>
        <div class="table-container">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Election Overview</th>
                        <th>Status</th>
                        <th>Participation</th>
                        <th class="text-end pe-4">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for election in elections %}
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="stat-icon me-3 bg-light" style="width: 45px; height: 45px; font-size: 1.25rem;">
                                        <span class="material-symbols-outlined">ballot</span>
                                    </div>
                                    <div>
                                        <div class="fw-bold fs-6">{{ election.title }}</div>
                                        <div class="extra-small text-muted">UUID: {{ election.uuid|slice(0, 8) }}...</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                {% if election.status == 1 %}
                                    <span class="badge badge-success">Running</span>
                                {% elseif election.status == 2 %}
                                    <span class="badge badge-secondary" style="background: #e2e8f0; color: #475569;">Concluded</span>
                                {% else %}
                                    <span class="badge badge-warning">Draft Session</span>
                                {% endif %}
                            </td>
                            <td>
                                <div class="fw-bold">{{ election.votes_count|default(0) }} <span class="text-muted fw-normal">votes cast</span></div>
                            </td>
                            <td class="text-end pe-4">
                                <a href="{{ PROOT }}admin/reports/{{ election.uuid }}" class="btn btn-primary btn-sm px-4">
                                    Intelligence
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined fs-1 opacity-25">inbox</span>
                                <p class="mt-2">No active sessions found.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
</style>
{% endblock %}

