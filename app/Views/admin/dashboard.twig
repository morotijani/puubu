{% extends "admin/layout.twig" %}

{% set active_page = 'dashboard' %}

{% block title %}Dashboard • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col text-center text-md-start">
            <h1>Hello, {{ admin.cfname|capitalize }}</h1>
            <p class="fs-lg text-body-secondary mb-0">Summary of election activity and metrics.</p>
        </div>
        <div class="col-12 col-md-auto d-flex align-items-center justify-content-center mt-4 mt-md-0">
            <div class="avatar text-info me-2">
                <i class="bi bi-clock"></i>
            </div>
            <span>{{ "now"|date("h:i A") }}</span>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-8">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card bg-body-tertiary border-transparent h-100">
                <div class="card-body">
                    <h4 class="fs-sm fw-normal text-body-secondary mb-1">Total Elections</h4>
                    <div class="fs-4 fw-semibold">{{ stats.total_elections }}</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card bg-body-tertiary border-transparent h-100">
                <div class="card-body">
                    <h4 class="fs-sm fw-normal text-body-secondary mb-1">Contestants</h4>
                    <div class="fs-4 fw-semibold">{{ stats.total_contestants }}</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card bg-body-tertiary border-transparent h-100">
                <div class="card-body">
                    <h4 class="fs-sm fw-normal text-body-secondary mb-1">Positions</h4>
                    <div class="fs-4 fw-semibold">{{ stats.total_positions }}</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card bg-body-tertiary border-transparent h-100">
                <div class="card-body">
                    <h4 class="fs-sm fw-normal text-body-secondary mb-1">Voters</h4>
                    <div class="fs-4 fw-semibold">{{ stats.total_voters }}</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Elections Table -->
    <div class="card mb-6">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="fs-6 mb-0">Current Elections</h3>
            <a href="{{ PROOT }}admin/election/add" class="btn btn-sm btn-primary">Add Election</a>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Election</th>
                        <th>Status</th>
                        <th>Turnout</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for election in elections %}
                        <tr>
                            <td>
                                <strong>{{ election.election_name }}</strong><br>
                                <small class="text-muted">By: {{ election.election_by }}</small>
                            </td>
                            <td>
                                {% if election.session == 1 %}
                                    <span class="badge bg-danger-subtle text-danger">Running</span>
                                {% elseif election.session == 2 %}
                                    <span class="badge bg-success-subtle text-success">Ended</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge bg-dark">{{ election.votes_count|default(0) }} votes</span>
                            </td>
                            <td class="text-end">
                                <a href="{{ PROOT }}admin/report/{{ election.election_id }}" class="btn btn-sm btn-outline-secondary">Report</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">No active or completed elections found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
