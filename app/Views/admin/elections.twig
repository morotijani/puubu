{% extends "admin/layout.twig" %}

{% set active_page = 'elections' %}

{% block title %}Elections Hub • Kokuromotie{% endblock %}

{% block content %}
    <div class="mb-5">
        <h1 class="h3 fw-bold mb-1">Elections Hub</h1>
        <p class="text-muted small">Monitor, manage, and deploy your voting sessions.</p>
    </div>

    <div class="row g-4">
        <!-- Main List Section -->
        <div class="col-xl-8">
            <div class="card shadow-none border-0 bg-transparent">
                <div class="card-header border-0 px-0 pt-0 pb-3 bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Active Registry</h5>
                </div>
                <div class="card shadow-none border overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Election Identity</th>
                                    <th>Session Status</th>
                                    <th class="text-end pe-4">Management</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for election in elections %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar avatar-sm me-3 d-flex align-items-center justify-content-center text-indigo fw-bold" style="width: 40px; height: 40px;">
                                                    <i class="bi bi-box-seam fs-5"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark fs-6">{{ election.title }}</div>
                                                    <div class="text-muted extra-small d-flex align-items-center">
                                                        <span class="material-symbols-outlined me-1 fs-6">corporate_fare</span> {{ election.organized_by }}
                                                        <span class="mx-2 opacity-25">|</span>
                                                        <span class="fw-mono">#{{ election.uuid|slice(0, 8) }}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="width: 160px;">
                                            {% if election.status == 1 %}
                                                <span class="badge bg-success-subtle text-success px-3 py-1 border border-success-subtle d-inline-flex align-items-center">
                                                    <span class="p-1 bg-success rounded-circle me-2 animate-pulse"></span> Live
                                                </span>
                                            {% elseif election.status == 2 %}
                                                <span class="badge bg-secondary-subtle text-secondary px-3 py-1 border border-secondary-subtle">Completed</span>
                                            {% else %}
                                                <span class="badge bg-warning-subtle text-warning px-3 py-1 border border-warning-subtle">Draft</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                {% if election.status == 0 %}
                                                    <button class="btn btn-sm btn-success px-3 fw-bold rounded-3 shadow-sm start-btn d-flex align-items-center" data-id="{{ election.uuid }}" title="Start Election">
                                                        <span class="material-symbols-outlined me-1 fs-6">play_arrow</span> Start
                                                    </button>
                                                    <a href="{{ PROOT }}admin/elections?edit={{ election.uuid }}" class="btn btn-sm btn-white border rounded-3 shadow-sm d-flex align-items-center" title="Edit Configuration">
                                                        <span class="material-symbols-outlined fs-6 text-muted">settings</span>
                                                    </a>
                                                    <button class="btn btn-sm btn-white border text-danger rounded-3 shadow-sm delete-btn d-flex align-items-center" data-id="{{ election.uuid }}" title="Purge Session">
                                                        <span class="material-symbols-outlined fs-6">delete</span>
                                                    </button>
                                                {% elseif election.status == 1 %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.uuid }}" class="btn btn-sm btn-indigo px-3 fw-bold rounded-3 shadow-sm d-flex align-items-center">
                                                        Live Analytics <span class="material-symbols-outlined ms-1 fs-6">arrow_forward</span>
                                                    </a>
                                                    <button class="btn btn-sm btn-danger px-3 fw-bold rounded-3 shadow-sm stop-btn d-flex align-items-center" data-id="{{ election.uuid }}" title="Stop Election">
                                                        <span class="material-symbols-outlined me-1 fs-6">stop</span> Stop
                                                    </button>
                                                {% else %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.uuid }}" class="btn btn-sm btn-white border px-3 fw-bold rounded-3 shadow-sm d-flex align-items-center">
                                                        View Report
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <div class="mb-2"><i class="bi bi-inbox fs-1 opacity-25"></i></div>
                                            No sessions found in the registry.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action/Form Section -->
        <div class="col-xl-4">
            <div class="card border border-2 border-indigo border-opacity-10 shadow-sm">
                <div class="card-header bg-light bg-opacity-50 border-bottom-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">{{ edit_election ? 'Session Editor' : 'New Deployment' }}</h5>
                    <p class="text-muted small mt-1 mb-0">{{ edit_election ? 'Update existing election details.' : 'Deploy a new voting session for your institution.' }}</p>
                </div>
                <div class="card-body p-4">
                    <form action="{{ PROOT }}admin/elections/store" method="POST">
                        {{ csrf_field()|raw }}
                        {% if edit_election %}
                            <input type="hidden" name="edit_id" value="{{ edit_election.uuid }}">
                        {% endif %}

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider" for="title">Election Title</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" name="title" id="title" value="{{ edit_election.title }}" placeholder="e.g. Presidential Elections 2024" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider" for="organized_by">Organizing Body</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" name="organized_by" id="organized_by" value="{{ edit_election.organized_by }}" placeholder="e.g. Electoral Commission" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider mb-3">Voter Login Options</label>
                            <div class="bg-light p-3 rounded-4 border">
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_email_login" id="allow_email" value="1" {{ edit_election.allow_email_login ? 'checked' : (edit_election ? '' : 'checked') }}>
                                    <label class="form-check-label small fw-semibold" for="allow_email">
                                        Allow Email Login
                                        <span class="text-muted extra-small d-block fw-normal">Voters use Email & Password. Best for users with email access.</span>
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_sms_login" id="allow_sms" value="1" {{ edit_election.allow_sms_login ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-semibold" for="allow_sms">
                                        Allow SMS OTP Login
                                        <span class="text-muted extra-small d-block fw-normal">Voters use Phone & SMS OTP. Ideal for mobile users.</span>
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_pin_login" id="allow_pin" value="1" {{ edit_election.allow_pin_login ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-semibold" for="allow_pin">
                                        Allow PIN / Offline Login
                                        <span class="text-muted extra-small d-block fw-normal">Voters use Voter ID & PIN only. Best for elderly voters.</span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="allow_direct_link" id="allow_direct" value="1" {{ edit_election.allow_direct_link ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-semibold" for="allow_direct">
                                        Allow Direct Link Access
                                        <span class="text-muted extra-small d-block fw-normal">Voters click a personalized link from WhatsApp. Zero friction.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-indigo w-100 py-3 fw-bold">
                            {{ edit_election ? 'Update Session' : 'Initiate Deployment' }}
                        </button>

                        {% if edit_election %}
                            <div class="mt-3 text-center">
                                <a href="{{ PROOT }}admin/elections" class="text-muted small text-decoration-none d-flex align-items-center justify-content-center">
                                    <span class="material-symbols-outlined me-1 fs-6">cancel</span> Discard Changes
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
                <div class="card-footer bg-light bg-opacity-50 border-top-0 p-4">
                    <div class="d-flex align-items-start">
                        <span class="material-symbols-outlined text-indigo me-2 fs-5">info</span>
                        <p class="small text-muted mb-0">Newly created elections are saved as <strong>Drafts</strong>. You can start the session from the dashboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Start Election Modal -->
    <div class="modal fade glass-modal" id="startElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.98);">
                <form id="startElectionForm" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="start_election" value="1">
                    
                    <!-- Step 1: Configuration -->
                    <div class="modal-step" id="start-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-indigo-subtle text-indigo d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">calendar_month</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Set Timeline</h3>
                                <p class="text-muted small px-4">Define when your voting window should open and close.</p>
                            </div>

                            <div class="mb-3">
                                <div class="premium-field mb-4">
                                    <label class="premium-label">STARTING AT</label>
                                    <input type="datetime-local" class="form-control premium-input form-control-lg" name="start_date" id="start_date_input" required>
                                </div>
                                <div class="premium-field mb-4">
                                    <label class="premium-label">CLOSING AT</label>
                                    <input type="datetime-local" class="form-control premium-input form-control-lg" name="end_date" id="end_date_input" required>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-indigo btn-lg py-3 fw-bold rounded-4 shadow-lg next-step" data-next="start-step-2">
                                    Continue to Security <span class="material-symbols-outlined ms-2 fs-5">arrow_forward</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="start-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb"></div>
                                    <span class="material-symbols-outlined text-success display-4 position-relative">verified_user</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization 🔒</h3>
                                <p class="text-muted px-4 small">Confirm your identity with your security key to deploy this session.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <div class="otp-inputs-display d-flex justify-content-center gap-2">
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                </div>
                                <input type="text" class="form-control otp-hidden-input" name="otp_code" placeholder="000000" maxlength="6" required autocomplete="off">
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg py-3 fw-bold rounded-4 shadow-lg mb-2" style="font-size: 1.1rem;">
                                    Authorize & Deploy
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="start-step-1">
                                    <span class="material-symbols-outlined me-2 fs-5">arrow_back</span> Back to timeline
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                
                <!-- Step Indicator -->
                <div class="step-progress-dots pb-4 text-center">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stop Election Modal -->
    <div class="modal fade glass-modal" id="stopElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.98);">
                <form id="stopElectionForm" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="stop_election" value="1">
                    
                    <!-- Step 1: Reason -->
                    <div class="modal-step" id="stop-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">report</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Termination Audit</h3>
                                <p class="text-muted small px-4">State the reason for early closure before proceeding to authorization.</p>
                            </div>

                            <div class="mb-5">
                                <label class="premium-label">REASON FOR TERMINATION</label>
                                <textarea class="form-control premium-input p-3 bg-light rounded-4 border-0" name="manual_stop_reason" id="stop_reason_input" rows="3" placeholder="Briefly explain the cause for early closure..." required style="resize: none;"></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-danger btn-lg py-3 fw-bold rounded-4 shadow-lg next-step" data-next="stop-step-2">
                                    Proceed to Authorization <span class="material-symbols-outlined ms-2 fs-5">arrow_forward</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Abort
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="stop-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb" style="background: rgba(220, 53, 69, 0.1);"></div>
                                    <span class="material-symbols-outlined text-danger display-4 position-relative">lock</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization 🔒</h3>
                                <p class="text-muted px-4 small">Confirm your identity with your security key to permanently terminate this session.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <div class="otp-inputs-display d-flex justify-content-center gap-2">
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                </div>
                                <input type="text" class="form-control otp-hidden-input" name="otp_code" placeholder="000000" maxlength="6" required autocomplete="off">
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold rounded-4 shadow-lg mb-2" style="font-size: 1.1rem; border: none;">
                                    Finalize Termination
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="stop-step-1">
                                    <span class="material-symbols-outlined me-2 fs-5">arrow_back</span> Back to reason
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <!-- Step Indicator -->
                <div class="step-progress-dots pb-4 text-center">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .fw-mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
    .btn-white {
        background: #fff;
        color: var(--admin-text-main);
    }
    .btn-white:hover {
        background: #f8fafc;
        color: var(--admin-primary);
    }
    .tracking-wider { letter-spacing: 0.05em; }
    .glass-modal {
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    .premium-field {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 12px 16px;
        transition: all 0.2s ease;
    }
    .premium-field:focus-within {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 4px 12px rgba(var(--admin-primary-rgb), 0.1);
    }
    .premium-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 800;
        color: #64748b;
        letter-spacing: 0.1em;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .premium-input {
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        font-size: 0.95rem;
        font-weight: 600;
        color: #1e293b;
    }
    .premium-input:focus {
        box-shadow: none !important;
    }
    .otp-container {
        max-width: 300px;
        margin: 0 auto;
    }
    .otp-premium-input {
        background: transparent !important;
        border: none !important;
        font-size: 2.5rem !important;
        font-weight: 800 !important;
        letter-spacing: 0.8rem !important;
        text-align: center !important;
        font-family: 'Outfit', sans-serif;
        color: #0f172a;
    }
    .otp-premium-input::placeholder {
        color: #cbd5e1;
        letter-spacing: 0.8rem;
    }
    .shadow-2xl {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    .modal-step {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .step-progress-dots .dot {
        width: 8px;
        height: 8px;
        background: #e2e8f0;
        border-radius: 50%;
        display: inline-block;
        margin: 0 4px;
        transition: all 0.3s ease;
    }
    .step-progress-dots .dot.active {
        background: var(--admin-primary);
        width: 24px;
        border-radius: 10px;
    }
    .bg-indigo-subtle { background: #eef2ff !important; }
    .text-indigo { color: #4f46e5 !important; }
    .btn-indigo { background: #4f46e5; border-color: #4f46e5; color: white; }
    .btn-indigo:hover { background: #4338ca; border-color: #4338ca; color: white; }

    /* Animated Security Shield */
    .security-shield-animated {
        position: relative;
        display: inline-block;
    }
    .shield-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: rgba(25, 135, 84, 0.1);
        border-radius: 50%;
        animation: pulse-orb 2s infinite;
    }
    @keyframes pulse-orb {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    /* Modern OTP UI */
    .otp-modern-wrapper {
        position: relative;
        max-width: 340px;
        margin: 0 auto;
    }
    .otp-hidden-input {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        opacity: 0 !important;
        cursor: text !important;
        z-index: 10 !important;
        border: none !important;
        background: transparent !important;
        color: transparent !important;
        caret-color: transparent !important;
    }
    .otp-box {
        width: 48px;
        height: 64px;
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Outfit', sans-serif;
    }
    .otp-box.active {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(var(--admin-primary-rgb), 0.1);
        transform: translateY(-2px);
    }
    .otp-box.filled {
        background: #fff;
        border-color: #cbd5e1;
    }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        // Multi-step navigation
        $('.next-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var nextStepId = $(this).data('next');
            var $form = $(this).closest('form');
            
            // Basic validation for Step 1
            var valid = true;
            if (currentStepId === 'start-step-1') {
                if (!$('#start_date_input').val() || !$('#end_date_input').val()) {
                    valid = false;
                    Toast.fire({ icon: 'warning', title: 'Please set both dates' });
                }
            } else if (currentStepId === 'stop-step-1') {
                if (!$('#stop_reason_input').val()) {
                    valid = false;
                    Toast.fire({ icon: 'warning', title: 'Please provide a reason' });
                }
            }

            if (valid) {
                $('#' + currentStepId).addClass('d-none');
                $('#' + nextStepId).removeClass('d-none');
                $(this).closest('.modal-content').find('.dot').last().addClass('active').siblings().removeClass('active');
            }
        });

        $('.prev-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var prevStepId = $(this).data('prev');
            $('#' + currentStepId).addClass('d-none');
            $('#' + prevStepId).removeClass('d-none');
            $(this).closest('.modal-content').find('.dot').first().addClass('active').siblings().removeClass('active');
        });

        // Reset modals on close
        $('.modal').on('hidden.bs.modal', function () {
            $(this).find('.modal-step').addClass('d-none').first().removeClass('d-none');
            $(this).find('.dot').first().addClass('active').siblings().removeClass('active');
            $(this).find('form')[0].reset();
            $(this).find('.otp-box').text('').removeClass('active filled');
        });

        // OTP Input Sync
        $('.otp-hidden-input').on('input', function() {
            var val = $(this).val();
            var $boxes = $(this).siblings('.otp-inputs-display').find('.otp-box');
            
            $boxes.each(function(index) {
                if (index < val.length) {
                    $(this).text(val[index]).addClass('filled').removeClass('active');
                } else if (index === val.length) {
                    $(this).text('').addClass('active').removeClass('filled');
                } else {
                    $(this).text('').removeClass('active filled');
                }
            });
        });

        $('.otp-hidden-input').on('focus', function() {
            var val = $(this).val();
            var $boxes = $(this).siblings('.otp-inputs-display').find('.otp-box');
            if (val.length < 6) {
                $boxes.eq(val.length).addClass('active');
            }
        }).on('blur', function() {
            $(this).siblings('.otp-inputs-display').find('.otp-box').removeClass('active');
        });

        $('.start-btn').on('click', function() {
            var id = $(this).data('id');
            $('#startElectionForm').attr('action', '{{ PROOT }}admin/elections/start/' + id);
            $('#startElectionModal').modal('show');
        });

        $('.stop-btn').on('click', function() {
            var id = $(this).data('id');
            $('#stopElectionForm').attr('action', '{{ PROOT }}admin/elections/stop/' + id);
            $('#stopElectionModal').modal('show');
        });

        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to purge this session? All associated data will be removed.')) {
                window.location.href = '{{ PROOT }}admin/elections/delete/' + id;
            }
        });
    });
</script>
{% endblock %}

