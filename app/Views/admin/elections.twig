{% extends "admin/layout.twig" %}

{% set active_page = 'elections' %}

{% block title %}Elections Management • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin">Admin</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Elections</li>
                </ol>
            </nav>
            <h1 class="fs-4 mb-0">Elections Management</h1>
        </div>
    </div>

    <!-- Add/Edit Form -->
    <div class="card bg-body-tertiary border-transparent mb-7">
        <div class="card-body p-4">
            <form action="{{ PROOT }}admin/elections/store" method="POST">
                {{ csrf_field() }}
                {% if edit_election %}
                    <input type="hidden" name="edit_id" value="{{ edit_election.election_id }}">
                {% endif %}

                <div class="row align-items-end g-3">
                    <div class="col-md-5">
                        <label class="form-label" for="election_name">Election Name</label>
                        <input type="text" class="form-control" name="election_name" id="election_name" value="{{ edit_election.election_name }}" placeholder="e.g. SRC Elections 2024" required>
                    </div>
                    <div class="col-md-5">
                        <label class="form-label" for="election_by">Organizers</label>
                        <input type="text" class="form-control" name="election_by" id="election_by" value="{{ edit_election.election_by }}" placeholder="e.g. Electoral Commission" required>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            {{ edit_election ? 'Update' : 'Add' }}
                        </button>
                    </div>
                </div>
                {% if edit_election %}
                    <div class="mt-2">
                        <a href="{{ PROOT }}admin/elections" class="btn btn-sm btn-link text-secondary">Cancel Edit</a>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- List Table -->
    <div class="card mb-6">
        <div class="card-header">
            <h3 class="fs-6 mb-0">Registered Elections</h3>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="fs-sm">Status</th>
                        <th class="fs-sm">Election Name</th>
                        <th class="fs-sm">Organizer</th>
                        <th class="fs-sm text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for election in elections %}
                        <tr>
                            <td>
                                {% if election.session == 1 %}
                                    <span class="badge bg-success-subtle text-success">Running</span>
                                {% elseif election.session == 2 %}
                                    <span class="badge bg-danger-subtle text-danger">Ended</span>
                                {% else %}
                                    <span class="badge bg-secondary-subtle text-secondary">Draft</span>
                                {% endif %}
                            </td>
                            <td><strong class="fw-semibold">{{ election.election_name }}</strong></td>
                            <td>{{ election.election_by }}</td>
                            <td class="text-end">
                                {% if election.session == 0 %}
                                    <a href="{{ PROOT }}admin/elections?edit={{ election.election_id }}" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <button class="btn btn-sm btn-danger delete-btn" data-id="{{ election.election_id }}">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                {% elseif election.session == 1 %}
                                    <a href="{{ PROOT }}admin/reports?election={{ election.election_id }}" class="btn btn-sm btn-info" target="_blank">
                                        <i class="bi bi-graph-up"></i> Live Results
                                    </a>
                                {% else %}
                                    <a href="{{ PROOT }}admin/report/full/{{ election.election_id }}" class="btn btn-sm btn-secondary" target="_blank">
                                        <i class="bi bi-file-earmark-bar-graph"></i> Report
                                    </a>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">No elections found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to delete this election? This action cannot be undone.')) {
                window.location.href = '{{ PROOT }}admin/elections/delete/' + id;
            }
        });
    });
</script>
{% endblock %}
