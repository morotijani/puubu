{% extends "admin/layout.twig" %}

{% set active_page = 'elections' %}

{% block title %}Elections Hub • Puubu{% endblock %}

{% block content %}
    <div class="mb-5">
        <h1 class="h3 fw-bold mb-1">Elections Hub</h1>
        <p class="text-muted small">Monitor, manage, and deploy your voting sessions.</p>
    </div>

    <div class="row g-4">
        <!-- Main List Section -->
        <div class="col-xl-8">
            <div class="card shadow-none border-0 bg-transparent">
                <div class="card-header border-0 px-0 pt-0 pb-3 bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0">Active Registry</h5>
                </div>
                <div class="card shadow-none border">
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Session Status</th>
                                    <th>Election Identity</th>
                                    <th class="text-end">Management</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for election in elections %}
                                    <tr>
                                        <td style="width: 160px;">
                                            {% if election.session == 1 %}
                                                <span class="badge bg-success-subtle text-success px-2 py-1 border border-success-subtle d-inline-flex align-items-center">
                                                    <span class="p-1 bg-success rounded-circle me-2 animate-pulse"></span> Live
                                                </span>
                                            {% elseif election.session == 2 %}
                                                <span class="badge bg-secondary-subtle text-secondary px-2 py-1 border border-secondary-subtle">Completed</span>
                                            {% else %}
                                                <span class="badge bg-warning-subtle text-warning px-2 py-1 border border-warning-subtle">Draft</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <div class="fw-bold text-dark">{{ election.election_name }}</div>
                                            <div class="text-muted small d-flex align-items-center">
                                                <i class="bi bi-building me-1"></i> {{ election.election_by }}
                                                <span class="mx-2 opacity-25">|</span>
                                                <i class="bi bi-fingerprint me-1"></i> {{ election.election_id|slice(0, 8) }}...
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group shadow-sm rounded">
                                                {% if election.session == 0 %}
                                                    <a href="{{ PROOT }}admin/elections?edit={{ election.election_id }}" class="btn btn-sm btn-white border border-end-0" title="Edit Configuration">
                                                        <i class="bi bi-gear-fill text-muted"></i>
                                                    </a>
                                                    <button class="btn btn-sm btn-white border text-danger delete-btn" data-id="{{ election.election_id }}" title="Purge Session">
                                                        <i class="bi bi-trash3"></i>
                                                    </button>
                                                {% elseif election.session == 1 %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.election_id }}" class="btn btn-sm btn-primary px-3">
                                                        Live Analytics <i class="bi bi-arrow-right ms-1"></i>
                                                    </a>
                                                {% else %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.election_id }}" class="btn btn-sm btn-light border px-3">
                                                        View Report
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <div class="mb-2"><i class="bi bi-inbox fs-1 opacity-25"></i></div>
                                            No sessions found in the registry.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action/Form Section -->
        <div class="col-xl-4">
            <div class="card border border-2 border-primary border-opacity-10">
                <div class="card-header bg-light bg-opacity-50 border-bottom-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">{{ edit_election ? 'Session Editor' : 'New Deployment' }}</h5>
                    <p class="text-muted small mt-1 mb-0">{{ edit_election ? 'Update existing election details.' : 'Deploy a new voting session for your institution.' }}</p>
                </div>
                <div class="card-body p-4">
                    <form action="{{ PROOT }}admin/elections/store" method="POST">
                        {{ csrf_field()|raw }}
                        {% if edit_election %}
                            <input type="hidden" name="edit_id" value="{{ edit_election.election_id }}">
                        {% endif %}

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider" for="election_name">Election Title</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" name="election_name" id="election_name" value="{{ edit_election.election_name }}" placeholder="e.g. Presidential Elections 2024" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider" for="election_by">Organizing Body</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" name="election_by" id="election_by" value="{{ edit_election.election_by }}" placeholder="e.g. Electoral Commission" required>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold">
                            {{ edit_election ? 'Update Session' : 'Initiate Deployment' }}
                        </button>

                        {% if edit_election %}
                            <div class="mt-3 text-center">
                                <a href="{{ PROOT }}admin/elections" class="text-muted small text-decoration-none">
                                    <i class="bi bi-x-circle me-1"></i> Discard Changes
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
                <div class="card-footer bg-light bg-opacity-50 border-top-0 p-4">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-info-circle text-primary me-2 mt-1"></i>
                        <p class="small text-muted mb-0">Newly created elections are saved as <strong>Drafts</strong>. You can start the session from the dashboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
    .btn-white {
        background: #fff;
        color: var(--admin-text-main);
    }
    .btn-white:hover {
        background: #f8fafc;
        color: var(--admin-primary);
    }
    .tracking-wider { letter-spacing: 0.05em; }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to purge this session? All associated data will be removed.')) {
                window.location.href = '{{ PROOT }}admin/elections/delete/' + id;
            }
        });
    });
</script>
{% endblock %}
