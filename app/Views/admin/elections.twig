{% extends "admin/layout.twig" %}

{% set active_page = 'elections' %}

{% block title %}Elections Hub • Kokuromotie{% endblock %}

{% block content %}
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1>Elections Hub</h1>
            <p>Monitor, manage, and deploy your voting sessions.</p>
        </div>
        <div class="d-none d-md-block">
            <div class="btn btn-light shadow-sm">
                <span class="material-symbols-outlined fs-5">hub</span> Infrastructure Active
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main List Section -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-none bg-transparent">
                <div class="card-header border-0 px-0 pt-0 pb-3 bg-transparent">
                    <h5>Active Session Registry</h5>
                </div>
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="table-container">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th class="ps-4">Election Identity</th>
                                    <th>Session Status</th>
                                    <th class="text-end pe-4">Management</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for election in elections %}
                                    <tr>
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="stat-icon me-3 bg-light" style="width: 45px; height: 45px; font-size: 1.25rem;">
                                                    <span class="material-symbols-outlined">ballot</span>
                                                </div>
                                                <div>
                                                    <a href="{{ PROOT }}admin/elections/view/{{ election.uuid }}" class="text-decoration-none">
                                                        <div class="fw-bold fs-6 text-dark hover-text-primary transition-all">{{ election.title }}</div>
                                                    </a>
                                                    <div class="text-muted extra-small d-flex align-items-center">
                                                        <span class="material-symbols-outlined me-1 fs-6">corporate_fare</span> {{ election.organized_by }}
                                                        <span class="mx-2 opacity-25">|</span>
                                                        <span class="fw-mono">#{{ election.uuid|slice(0, 8) }}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="width: 160px;">
                                            {% if election.status == 1 %}
                                                <span class="badge badge-success">Running</span>
                                            {% elseif election.status == 2 %}
                                                <span class="badge badge-secondary" style="background: #e2e8f0; color: #475569;">Concluded</span>
                                            {% else %}
                                                <span class="badge badge-warning">Draft Session</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                {% if election.status == 0 %}
                                                    <button class="btn btn-primary btn-sm px-3 start-btn" data-id="{{ election.uuid }}" data-bs-toggle="modal" data-bs-target="#startElectionModal" onclick="document.getElementById('startElectionForm').action = '{{ PROOT }}admin/elections/start/{{ election.uuid }}'">
                                                        <span class="material-symbols-outlined fs-6">play_arrow</span> Start
                                                    </button>
                                                    <a href="{{ PROOT }}admin/elections?edit={{ election.uuid }}" class="btn btn-light btn-sm" title="Configure">
                                                        <span class="material-symbols-outlined fs-6">settings</span>
                                                    </a>
                                                    <button class="btn btn-light btn-sm text-danger delete-btn" data-id="{{ election.uuid }}" title="Purge">
                                                        <span class="material-symbols-outlined fs-6">delete</span>
                                                    </button>
                                                {% elseif election.status == 1 %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.uuid }}" class="btn btn-primary btn-sm px-4">
                                                        Intelligence
                                                    </a>
                                                    <button class="btn btn-light btn-sm text-danger stop-btn" data-id="{{ election.uuid }}" data-bs-toggle="modal" data-bs-target="#stopElectionModal" onclick="document.getElementById('stopElectionForm').action = '{{ PROOT }}admin/elections/stop/{{ election.uuid }}'">
                                                        <span class="material-symbols-outlined fs-6">stop</span> Stop
                                                    </button>
                                                {% else %}
                                                    <a href="{{ PROOT }}admin/reports/{{ election.uuid }}" class="btn btn-light btn-sm px-3">
                                                        View Report
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <span class="material-symbols-outlined fs-1 opacity-25">inbox</span>
                                            <p class="mt-2">No electoral sessions in the registry.</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action/Form Section -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 pb-0">
                    <h5>{{ edit_election ? 'Session Editor' : 'Session Deployment' }}</h5>
                </div>
                <div class="card-body">
                    <form action="{{ PROOT }}admin/elections/store" method="POST">
                        {{ csrf_field()|raw }}
                        {% if edit_election %}
                            <input type="hidden" name="edit_id" value="{{ edit_election.uuid }}">
                        {% endif %}

                        <div class="mb-4">
                            <label class="form-label">Election Title</label>
                            <input type="text" class="form-control" name="title" value="{{ edit_election.title }}" placeholder="e.g. Presidential Elections 2024" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Organizing Institution</label>
                            <input type="text" class="form-control" name="organized_by" value="{{ edit_election.organized_by }}" placeholder="e.g. Electoral Commission" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label mb-3">Voter Authentication Matrix</label>
                            <div class="bg-light p-3 rounded-4">
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_email_login" id="allow_email" value="1" {{ edit_election.allow_email_login ? 'checked' : (edit_election ? '' : 'checked') }}>
                                    <label class="form-check-label small fw-bold" for="allow_email">
                                        Email Authentication
                                        <span class="text-muted extra-small d-block fw-normal">Voters login with verified email and password.</span>
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_sms_login" id="allow_sms" value="1" {{ edit_election.allow_sms_login ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="allow_sms">
                                        SMS OTP Verification
                                        <span class="text-muted extra-small d-block fw-normal">Voters receive a secure PIN via SMS on their phone.</span>
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="checkbox" name="allow_pin_login" id="allow_pin" value="1" {{ edit_election.allow_pin_login ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="allow_pin">
                                        Offline / PIN Login
                                        <span class="text-muted extra-small d-block fw-normal">Voters use a unique Voter ID and system-generated PIN.</span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="allow_direct_link" id="allow_direct" value="1" {{ edit_election.allow_direct_link ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="allow_direct">
                                        Direct Link Access
                                        <span class="text-muted extra-small d-block fw-normal">One-click access via personalized voting tokens.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 mt-2">
                            {{ edit_election ? 'Update Session Parameters' : 'Deploy Electoral Session' }}
                        </button>

                        {% if edit_election %}
                            <div class="mt-3 text-center">
                                <a href="{{ PROOT }}admin/elections" class="text-muted small text-decoration-none d-flex align-items-center justify-content-center">
                                    <span class="material-symbols-outlined me-1 fs-6">cancel</span> Discard Changes
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
                <div class="card-footer border-0 bg-light bg-opacity-50">
                    <div class="d-flex align-items-start">
                        <span class="material-symbols-outlined text-primary me-2 fs-5">info</span>
                        <p class="extra-small text-muted mb-0">Newly deployed sessions are initiated as <strong>Drafts</strong>. Use the Start button to open the polls.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>    <!-- Start Election Modal -->
    <div class="modal fade glass-modal" id="startElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.99);">
                <form id="startElectionForm" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="start_election" value="1">
                    
                    <!-- Step 1: Configuration -->
                    <div class="modal-step" id="start-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">timer</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Intelligence Session</h3>
                                <p class="text-muted small px-4">Define the temporal boundaries for this electoral session.</p>
                            </div>

                            <div class="mb-4">
                                <div class="premium-field mb-4">
                                    <label class="premium-label">DEPLOYMENT START</label>
                                    <input type="datetime-local" class="form-control premium-input form-control-lg" name="start_date" id="start_date_input" required>
                                </div>
                                <div class="premium-field mb-4">
                                    <label class="premium-label">SESSION TERMINATION</label>
                                    <input type="datetime-local" class="form-control premium-input form-control-lg" name="end_date" id="end_date_input" required>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary btn-lg py-3 fw-bold rounded-4 shadow-sm next-step" data-next="start-step-2">
                                    Continue to Authorization <span class="material-symbols-outlined ms-2 fs-5">security</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Abort Deployment
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="start-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb"></div>
                                    <span class="material-symbols-outlined text-primary display-4 position-relative">verified_user</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization Layer</h3>
                                <p class="text-muted px-4 small">Enter your administrator security key to authorize this session deployment.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <div class="otp-inputs-display d-flex justify-content-center gap-2">
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                </div>
                                <input type="text" class="form-control otp-hidden-input" name="otp_code" placeholder="000000" maxlength="6" required autocomplete="off">
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg py-3 fw-bold rounded-4 shadow-sm mb-2" style="font-size: 1.1rem;">
                                    Authorize & Deploy Session
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="start-step-1">
                                    <span class="material-symbols-outlined me-2 fs-5">arrow_back</span> Back to timeline
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
                
                <!-- Step Indicator -->
                <div class="step-progress-dots pb-4 text-center">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                </div>
            </div>
        </div>
    </div>

    <!-- Stop Election Modal -->
    <div class="modal fade glass-modal" id="stopElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-2xl overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.99);">
                <form id="stopElectionForm" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="stop_election" value="1">
                    
                    <!-- Step 1: Reason -->
                    <div class="modal-step" id="stop-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">cancel_presentation</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Termination Audit</h3>
                                <p class="text-muted small px-4">Identify the catalyst for early session closure for the intelligence logs.</p>
                            </div>

                            <div class="mb-5">
                                <label class="premium-label">REASON FOR TERMINATION</label>
                                <textarea class="form-control premium-input p-3 bg-light rounded-4 border-0" name="manual_stop_reason" id="stop_reason_input" rows="3" placeholder="State reason for manual override..." required style="resize: none;"></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-primary btn-lg py-3 fw-bold rounded-4 shadow-sm next-step" data-next="stop-step-2">
                                    Proceed to Authorization <span class="material-symbols-outlined ms-2 fs-5">security</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Abort Termination
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="stop-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb" style="background: rgba(220, 53, 69, 0.1);"></div>
                                    <span class="material-symbols-outlined text-danger display-4 position-relative">lock_person</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization Layer</h3>
                                <p class="text-muted px-4 small">Authorize the permanent termination of this session using your security key.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <div class="otp-inputs-display d-flex justify-content-center gap-2">
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                    <div class="otp-box"></div>
                                </div>
                                <input type="text" class="form-control otp-hidden-input" name="otp_code" placeholder="000000" maxlength="6" required autocomplete="off">
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-danger btn-lg py-3 fw-bold rounded-4 shadow-sm mb-2" style="font-size: 1.1rem; border: none;">
                                    Confirm Permanent Termination
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="stop-step-1">
                                    <span class="material-symbols-outlined me-2 fs-5">arrow_back</span> Back to reason
                                </button>
                            </div>
                        </div>
                    </div>
                </form>

                <!-- Step Indicator -->
                <div class="step-progress-dots pb-4 text-center">
                    <span class="dot active"></span>
                    <span class="dot"></span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .fw-mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
    .btn-white:hover {
        background: #f8fafc;
        color: var(--admin-primary);
    }
    .hover-text-primary:hover {
        color: var(--admin-primary) !important;
        transform: translateX(4px);
    }
    .tracking-wider { letter-spacing: 0.05em; }
    .glass-modal {
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }
    .premium-field {
        background: var(--admin-bg);
        border: 1px solid var(--admin-border);
        border-radius: 16px;
        padding: 12px 16px;
        transition: all 0.2s ease;
    }
    .premium-field:focus-within {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 4px 12px rgba(29, 61, 55, 0.1);
    }
    .premium-label {
        display: block;
        font-size: 0.65rem;
        font-weight: 800;
        color: var(--admin-text-muted);
        letter-spacing: 0.1em;
        margin-bottom: 4px;
        text-transform: uppercase;
    }
    .premium-input {
        background: transparent !important;
        border: none !important;
        padding: 0 !important;
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--admin-text-main);
    }
    .premium-input:focus {
        box-shadow: none !important;
    }
    .otp-container {
        max-width: 300px;
        margin: 0 auto;
    }
    .otp-premium-input {
        background: transparent !important;
        border: none !important;
        font-size: 2.5rem !important;
        font-weight: 800 !important;
        letter-spacing: 0.8rem !important;
        text-align: center !important;
        font-family: 'Outfit', sans-serif;
        color: var(--admin-text-main);
    }
    .otp-premium-input::placeholder {
        color: var(--admin-border);
        letter-spacing: 0.8rem;
    }
    .shadow-2xl {
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    .modal-step {
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .step-progress-dots .dot {
        width: 8px;
        height: 8px;
        background: #e2e8f0;
        border-radius: 50%;
        display: inline-block;
        margin: 0 4px;
        transition: all 0.3s ease;
    }
    .step-progress-dots .dot.active {
        background: var(--admin-primary);
        width: 24px;
        border-radius: 10px;
    }
    .bg-primary-subtle { background: var(--admin-accent-subtle) !important; }
    .text-primary { color: var(--admin-primary) !important; }

    /* Animated Security Shield */
    .security-shield-animated {
        position: relative;
        display: inline-block;
    }
    .shield-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: rgba(25, 135, 84, 0.1);
        border-radius: 50%;
        animation: pulse-orb 2s infinite;
    }
    @keyframes pulse-orb {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    /* Modern OTP UI */
    .otp-modern-wrapper {
        position: relative;
        max-width: 340px;
        margin: 0 auto;
    }
    .otp-hidden-input {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        opacity: 0 !important;
        cursor: text !important;
        z-index: 10 !important;
        border: none !important;
        background: transparent !important;
        color: transparent !important;
        caret-color: transparent !important;
    }
    .otp-box {
        width: 48px;
        height: 64px;
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Outfit', sans-serif;
    }
    .otp-box.active {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(var(--admin-primary-rgb), 0.1);
        transform: translateY(-2px);
    }
    .otp-box.filled {
        background: #fff;
        border-color: #cbd5e1;
    }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        // Multi-step navigation
        $('.next-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var nextStepId = $(this).data('next');
            var $form = $(this).closest('form');
            
            // Basic validation for Step 1
            var valid = true;
            if (currentStepId === 'start-step-1') {
                if (!$('#start_date_input').val() || !$('#end_date_input').val()) {
                    valid = false;
                    Toast.fire({ icon: 'warning', title: 'Please set both dates' });
                }
            } else if (currentStepId === 'stop-step-1') {
                if (!$('#stop_reason_input').val()) {
                    valid = false;
                    Toast.fire({ icon: 'warning', title: 'Please provide a reason' });
                }
            }

            if (valid) {
                $('#' + currentStepId).addClass('d-none');
                $('#' + nextStepId).removeClass('d-none');
                $(this).closest('.modal-content').find('.dot').last().addClass('active').siblings().removeClass('active');
            }
        });

        $('.prev-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var prevStepId = $(this).data('prev');
            $('#' + currentStepId).addClass('d-none');
            $('#' + prevStepId).removeClass('d-none');
            $(this).closest('.modal-content').find('.dot').first().addClass('active').siblings().removeClass('active');
        });

        // Reset modals on close
        $('.modal').on('hidden.bs.modal', function () {
            $(this).find('.modal-step').addClass('d-none').first().removeClass('d-none');
            $(this).find('.dot').first().addClass('active').siblings().removeClass('active');
            $(this).find('form')[0].reset();
            $(this).find('.otp-box').text('').removeClass('active filled');
        });

        // OTP Input Sync
        $('.otp-hidden-input').on('input', function() {
            var val = $(this).val();
            var $boxes = $(this).siblings('.otp-inputs-display').find('.otp-box');
            
            $boxes.each(function(index) {
                if (index < val.length) {
                    $(this).text(val[index]).addClass('filled').removeClass('active');
                } else if (index === val.length) {
                    $(this).text('').addClass('active').removeClass('filled');
                } else {
                    $(this).text('').removeClass('active filled');
                }
            });
        });

        $('.otp-hidden-input').on('focus', function() {
            var val = $(this).val();
            var $boxes = $(this).siblings('.otp-inputs-display').find('.otp-box');
            if (val.length < 6) {
                $boxes.eq(val.length).addClass('active');
            }
        }).on('blur', function() {
            $(this).siblings('.otp-inputs-display').find('.otp-box').removeClass('active');
        });



        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to purge this session? All associated data will be removed.')) {
                window.location.href = '{{ PROOT }}admin/elections/delete/' + id;
            }
        });
    });
</script>
{% endblock %}

