<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/logo.svg" type="image/svg+xml" />

    <!-- Primary Meta Tags -->
    <meta name="title" content="Kokuromotie Admin - Control Center" />
    <meta name="description" content="Administrative command center for the Kokuromotie electoral platform. Manage voters, elections, and real-time results." />
    <meta name="robots" content="noindex, nofollow" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Kokuromotie Admin - Control Center" />
    <meta property="og:description" content="Secure administrative access to electoral intelligence and registry management." />
    <meta property="og:image" content="{{ PROOT }}media/logo.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/index.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">
    
    <title>{% block title %}Kokuromotie Admin{% endblock %}</title>
    {% block styles %}{% endblock %}
</head>
<body>
    <!-- Mobile Header -->
    <header class="mobile-header d-lg-none">
        <div class="d-flex align-items-center justify-content-between p-3 bg-sidebar shadow-sm">
            <a class="navbar-brand m-0" href="{{ PROOT }}admin" style="font-size: 1.25rem;">
                <span class="material-symbols-outlined me-2 fs-3">how_to_vote</span> KOKURO<span>MOTIE</span>
            </a>
            <button class="btn btn-link text-white p-0" id="mobileMenuToggle">
                <span class="material-symbols-outlined fs-1">menu</span>
            </button>
        </div>
    </header>

    <!-- Sidebar Overlay for Mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Sidebar -->
    <aside class="aside" id="sidebar">
        <div class="d-flex align-items-center justify-content-between mb-5">
            <a class="navbar-brand m-0" href="{{ PROOT }}admin" style="font-size: 1.2rem; gap: 8px;">
                <span class="material-symbols-outlined fs-2">how_to_vote</span> 
                <span class="brand-text">KOKURO<span>MOTIE</span></span>
            </a>
            <button class="btn btn-link p-0 d-none d-lg-flex" id="sidebarToggle" style="color: var(--admin-accent); border: none; outline: none; box-shadow: none; min-width: 32px;">
                <span class="material-symbols-outlined fs-2" id="toggleIcon">menu_open</span>
            </button>
        </div>
        
        <nav class="navbar-vertical">
            <div class="sidebar-heading">Electoral Intelligence</div>
            <a class="nav-link {% if active_page == 'dashboard' %}active{% endif %}" href="{{ PROOT }}admin">
                <span class="material-symbols-outlined">analytics</span> <span class="nav-text">Dashboard</span>
            </a>
            <a class="nav-link {% if active_page == 'elections' %}active{% endif %}" href="{{ PROOT }}admin/elections">
                <span class="material-symbols-outlined">event_note</span> <span class="nav-text">Elections</span>
            </a>
            
            <div class="sidebar-heading">Registry Management</div>
            <a class="nav-link {% if active_page == 'voters' %}active{% endif %}" href="{{ PROOT }}admin/voters">
                <span class="material-symbols-outlined">badge</span> <span class="nav-text">Voters Registrar</span>
            </a>
            <a class="nav-link {% if active_page == 'positions' %}active{% endif %}" href="{{ PROOT }}admin/positions">
                <span class="material-symbols-outlined">account_tree</span> <span class="nav-text">Positions</span>
            </a>
            <a class="nav-link {% if active_page == 'contestants' %}active{% endif %}" href="{{ PROOT }}admin/contestants">
                <span class="material-symbols-outlined">person_pin</span> <span class="nav-text">Contestants</span>
            </a>

            <div class="sidebar-heading">Intelligence Audit</div>
            <a class="nav-link {% if active_page == 'logs' %}active{% endif %}" href="{{ PROOT }}admin/logs">
                <span class="material-symbols-outlined">history_edu</span> <span class="nav-text">System Logs</span>
            </a>
            
            {% if admin.role == 'super_admin' %}
            <div class="sidebar-heading">System Core</div>
            <a class="nav-link {% if active_page == 'organizers' %}active{% endif %}" href="{{ PROOT }}admin/organizers">
                <span class="material-symbols-outlined">admin_panel_settings</span> <span class="nav-text">Organizers</span>
            </a>
            {% endif %}

            <div class="sidebar-heading">Profile</div>
            <a class="nav-link {% if active_page == 'help' %}active{% endif %}" href="{{ PROOT }}admin/help">
                <span class="material-symbols-outlined">help_center</span> <span class="nav-text">Help Center</span>
            </a>
            <a class="nav-link {% if active_page == 'settings' %}active{% endif %}" href="{{ PROOT }}admin/settings">
                <span class="material-symbols-outlined">settings_suggest</span> <span class="nav-text">Settings</span>
            </a>
            <a class="nav-link" href="{{ PROOT }}admin/auth/logout">
                <span class="material-symbols-outlined">logout</span> <span class="nav-text">Sign out</span>
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main" id="mainContent">
        {% block content %}{% endblock %}
    </main>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="{{ PROOT }}dist/js/vendor.bundle.js"></script>
    <script src="{{ PROOT }}dist/js/index.bundle.js"></script>

    <script>
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true,
            didOpen: (toast) => {
                toast.addEventListener('mouseenter', Swal.stopTimer)
                toast.addEventListener('mouseleave', Swal.resumeTimer)
            }
        });

        $(document).ready(function() {
            {% if session.flash_success %}
                Toast.fire({
                    icon: 'success',
                    title: '{{ session.flash_success }}'
                });
            {% endif %}

            {% if session.flash_error %}
                Toast.fire({
                    icon: 'error',
                    title: '{{ session.flash_error }}'
                });
            {% endif %}

            // Sidebar Toggle Logic
            const sidebar = document.getElementById('sidebar');
            const mainContent = document.getElementById('mainContent');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const toggleIcon = document.getElementById('toggleIcon');
            const mobileMenuToggle = document.getElementById('mobileMenuToggle');
            const sidebarOverlay = document.getElementById('sidebarOverlay');

            // Load preferred state
            const isCollapsed = localStorage.getItem('sidebarCollapsed') === 'true';
            if (isCollapsed && window.innerWidth > 992) {
                if(sidebar) sidebar.classList.add('collapsed');
                if(mainContent) mainContent.classList.add('sidebar-collapsed');
                if(toggleIcon) toggleIcon.textContent = 'menu';
            }

            if(sidebarToggle) {
                sidebarToggle.addEventListener('click', () => {
                    const nowCollapsed = sidebar.classList.toggle('collapsed');
                    mainContent.classList.toggle('sidebar-collapsed');
                    if(toggleIcon) toggleIcon.textContent = nowCollapsed ? 'menu' : 'menu_open';
                    localStorage.setItem('sidebarCollapsed', nowCollapsed);
                });
            }

            // Mobile Logic
            if(mobileMenuToggle) {
                mobileMenuToggle.addEventListener('click', () => {
                    sidebar.classList.add('mobile-show');
                    sidebarOverlay.classList.add('show');
                });
            }

            if(sidebarOverlay) {
                sidebarOverlay.addEventListener('click', () => {
                    sidebar.classList.remove('mobile-show');
                    sidebarOverlay.classList.remove('show');
                });
            }
        });
    </script>
    {% block scripts %}{% endblock %}
</body>
</html>

