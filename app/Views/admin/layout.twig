<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/puubu.favicon.png" type="image/x-icon" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/index.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <title>{% block title %}Puubu Admin{% endblock %}</title>
</head>
<body>
    <!-- Sidebar -->
    <aside class="aside">
        <a class="navbar-brand d-flex align-items-center mb-5" href="{{ PROOT }}admin">
            <i class="bi bi-box-seam text-primary me-2"></i> Puu<span class="text-primary">Bu</span>
        </a>
        
        <nav class="navbar-vertical">
            <div class="sidebar-heading">Main Menu</div>
            <a class="nav-link {% if active_page == 'dashboard' %}active{% endif %}" href="{{ PROOT }}admin">
                <span class="material-symbols-outlined">space_dashboard</span> Dashboard
            </a>
            <a class="nav-link {% if active_page == 'elections' %}active{% endif %}" href="{{ PROOT }}admin/elections">
                <span class="material-symbols-outlined">how_to_vote</span> Elections
            </a>
            <a class="nav-link {% if active_page == 'positions' %}active{% endif %}" href="{{ PROOT }}admin/positions">
                <span class="material-symbols-outlined">move_selection_up</span> Positions
            </a>
            <a class="nav-link {% if active_page == 'contestants' %}active{% endif %}" href="{{ PROOT }}admin/contestants">
                <span class="material-symbols-outlined">groups_2</span> Contestants
            </a>
            <a class="nav-link {% if active_page == 'voters' %}active{% endif %}" href="{{ PROOT }}admin/voters">
                <span class="material-symbols-outlined">crowdsource</span> Voters
            </a>

            <div class="sidebar-heading">Account</div>
            <a class="nav-link {% if active_page == 'settings' %}active{% endif %}" href="{{ PROOT }}admin/settings">
                <span class="material-symbols-outlined">settings</span> Settings
            </a>
            <a class="nav-link" href="{{ PROOT }}admin/auth/logout">
                <span class="material-symbols-outlined">logout</span> Sign out
            </a>
        </nav>
    </aside>

    <!-- Main Content -->
    <main class="main">
        {% if flash %}
            <div class="mb-4">
                {{ flash|raw }}
            </div>
        {% endif %}
        
        {% block content %}{% endblock %}
    </main>

    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="{{ PROOT }}dist/js/vendor.bundle.js"></script>
    <script src="{{ PROOT }}dist/js/index.bundle.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
