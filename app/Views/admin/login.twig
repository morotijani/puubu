<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/puubu.favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/index.bundle.css" />
    <title>Admin Login • Puubu</title>
</head>
<body class="d-flex align-items-center bg-light-subtle">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-5 col-xl-4 my-8">
                <div class="text-center mb-6">
                    <h1 class="display-5 fw-bold mb-3">Admin Login</h1>
                    <p class="text-body-secondary">Access the Puubu management portal.</p>
                </div>

                {% if errorsMsg %}
                    <div class="alert alert-danger" role="alert">{{ errorsMsg }}</div>
                {% endif %}

                <form method="POST">
                    {{ csrf_field() }}
                    <div class="mb-4">
                        <label class="form-label" for="admin_email">Email address</label>
                        <input type="email" class="form-control" name="admin_email" id="admin_email" placeholder="name@address.com" required />
                    </div>
                    <div class="mb-4">
                        <label class="form-label" for="admin_pass">Password</label>
                        <input type="password" class="form-control" name="admin_pass" id="admin_pass" placeholder="Enter your password" required />
                    </div>
                    <button class="btn btn-lg btn-primary w-100" type="submit" name="submitAdmin">Sign in</button>
                </form>

                <p class="text-center mt-5">
                    <small class="text-body-secondary">
                        Puubu E-Voting &copy; 2021
                    </small>
                </p>
            </div>
        </div>
    </div>
</body>
</html>
