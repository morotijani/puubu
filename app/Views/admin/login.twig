<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/logo.svg" type="image/svg+xml" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css?v={{ "now"|date("U") }}" />
    
    <title>Admin Sign In • Kokuromotie</title>
</head>
<body class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center">
            <div class="auth-logo-circle">
                <img src="{{ PROOT }}media/logo.svg" style="width: 48px; height: 48px;" alt="Logo">
            </div>
            <h1 class="auth-title">Kokuromotie</h1>
            <p class="auth-subtitle">Command Center Access</p>
        </div>

        {% if errorsMsg %}
            <div class="alert alert-danger border-0 small text-center mb-4 py-2" role="alert" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 1rem;">
                <i class="bi bi-exclamation-circle me-1"></i> {{ errorsMsg }}
            </div>
        {% endif %}

        <form method="POST">
            {{ csrf_field()|raw }}
            <div class="mb-3">
                <div class="auth-input-wrapper">
                    <i class="bi bi-person-badge"></i>
                    <input type="email" class="form-control" name="admin_email" id="admin_email" placeholder="Administrator Email" required autofocus />
                </div>
            </div>
            <div class="mb-3">
                <div class="auth-input-wrapper">
                    <i class="bi bi-shield-lock"></i>
                    <input type="password" class="form-control" name="admin_pass" id="admin_pass" placeholder="Access Password" required />
                </div>
            </div>
            <button class="btn btn-primary w-100 auth-btn shadow-lg" type="submit" name="submitAdmin">
                Unlock Portal <i class="bi bi-chevron-right fs-6"></i>
            </button>
        </form>
        <br>
        <div class="mt-5 text-center">
            <p class="small mb-0" style="opacity: 0.4; color: white;">&copy; {{ "now"|date("Y") }} Kokuromotie Power | Mijma Inc.</p>
        </div>
    </div>
</body>
</html>

