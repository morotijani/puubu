<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/Kokuromotie.favicon.png" type="image/x-icon" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/index.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css" />
    
    <title>Admin Access • Kokuromotie</title>
</head>
<body class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-5">
            <div class="mb-3">
                <i class="bi bi-box-seam text-primary fs-1"></i>
            </div>
            <h1 class="h3 fw-bold mb-1">Admin Portal</h1>
            <p class="text-muted small">Sign in to manage elections</p>
        </div>

        {% if errorsMsg %}
            <div class="alert alert-danger p-2 small text-center mb-4" role="alert">{{ errorsMsg }}</div>
        {% endif %}

        <form method="POST">
            {{ csrf_field()|raw }}
            <div class="mb-3">
                <label class="form-label small fw-semibold" for="admin_email">Email Address</label>
                <input type="email" class="form-control" name="admin_email" id="admin_email" placeholder="admin@Kokuromotie.com" required autofocus />
            </div>
            <div class="mb-4">
                <label class="form-label small fw-semibold" for="admin_pass">Password</label>
                <input type="password" class="form-control" name="admin_pass" id="admin_pass" placeholder="••••••••" required />
            </div>
            <button class="btn btn-primary w-100 py-2" type="submit" name="submitAdmin">Enter Portal</button>
        </form>

        <div class="mt-5 text-center">
            <p class="text-muted small mb-0">&copy; 2024 Kokuromotie E-Voting System</p>
        </div>
    </div>
</body>
</html>

