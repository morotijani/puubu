{% extends "admin/layout.twig" %}

{% set active_page = 'organizers' %}

{% block title %}Manage Organizers • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-5">
        <div class="col">
            <h1 class="h3 fw-bold mb-1">Election Organizers</h1>
            <p class="text-muted small mb-0">Manage sub-accounts for schools and organizations running elections.</p>
        </div>
        <div class="col-auto">
            <button type="button" class="btn btn-indigo shadow-sm d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#addOrganizerModal">
                <span class="material-symbols-outlined me-1 fs-6">person_add</span> Add Organizer
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Organizer Details</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for org in organizers %}
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">{{ org.cfname }} {{ org.clname }}</div>
                                <div class="text-muted small">Joined: {{ org.joined_date|date('M d, Y') }}</div>
                            </td>
                            <td>
                                <a href="mailto:{{ org.cemail }}" class="text-decoration-none text-primary">{{ org.cemail }}</a>
                            </td>
                            <td>
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-10">Active</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-light border text-danger d-flex align-items-center">
                                    <span class="material-symbols-outlined me-1 fs-6">lock</span> Suspend
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <div class="mb-2"><span class="material-symbols-outlined fs-1 opacity-25">badge</span></div>
                                No organizers found.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Organizer Modal -->
    <div class="modal fade" id="addOrganizerModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg border-radius-xl">
                <div class="modal-header border-bottom-0 pb-0">
                    <h5 class="modal-title fw-bold">Add New Organizer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="{{ PROOT }}admin/organizers/store" method="POST">
                    {{ csrf_field()|raw }}
                    <div class="modal-body py-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" name="fname" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" name="lname" class="form-control">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Temporary Password</label>
                                <input type="text" name="password" class="form-control" required minlength="6" placeholder="Provide a password for the organizer">
                                <div class="form-text mt-2 d-flex align-items-start">
                                    <span class="material-symbols-outlined me-1 fs-6">info</span> 
                                    <span>Give this password to the organizer securely. They can change it after logging in.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 pt-0">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-indigo">Create Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
