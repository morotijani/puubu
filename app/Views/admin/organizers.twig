{% extends "admin/layout.twig" %}

{% set active_page = 'organizers' %}

{% block title %}Manage Organizers • Kokuromotie Admin{% endblock %}

{% block content %}
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1>Election Organizers</h1>
            <p>Manage sub-accounts for schools and organizations running elections.</p>
        </div>
        <div class="d-none d-md-block">
            <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addOrganizerModal">
                <span class="material-symbols-outlined fs-6">person_add</span> Add Organizer
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="table-container">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th class="ps-4">Organizer Details</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for org in organizers %}
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="stat-icon me-3 bg-light" style="width: 42px; height: 42px; font-size: 1rem;">
                                        <span class="material-symbols-outlined">person</span>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">{{ org.first_name }} {{ org.last_name }}</div>
                                        <div class="text-muted extra-small">Joined: {{ org.created_at|date('M d, Y') }}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <a href="mailto:{{ org.email }}" class="text-decoration-none text-primary fw-medium">{{ org.email }}</a>
                            </td>
                            <td>
                                <span class="badge badge-success">Active</span>
                            </td>
                            <td class="text-end pe-4">
                                <button class="btn btn-light btn-sm text-danger px-3">
                                    <span class="material-symbols-outlined fs-6">lock</span> Suspend
                                </button>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <span class="material-symbols-outlined fs-1 opacity-25">badge</span>
                                <p class="mt-2">No organizers found in the system.</p>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Add Organizer Modal -->
    <div class="modal fade" id="addOrganizerModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="modal-header border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">Register Organizer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form action="{{ PROOT }}admin/organizers/store" method="POST">
                    {{ csrf_field()|raw }}
                    <div class="modal-body p-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label">First Name</label>
                                <input type="text" name="fname" class="form-control" placeholder="John" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Last Name</label>
                                <input type="text" name="lname" class="form-control" placeholder="Doe">
                            </div>
                            <div class="col-12">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="email" class="form-control" placeholder="john@example.com" required>
                            </div>
                            <div class="col-12">
                                <label class="form-label">Security Key / Password</label>
                                <input type="password" name="password" class="form-control" required minlength="6" placeholder="Define access key">
                                <div class="form-text mt-2 d-flex align-items-start">
                                    <span class="material-symbols-outlined me-1 fs-6 text-primary">info</span> 
                                    <span class="extra-small">Provide this key to the organizer. They will be required to update it upon first authentication.</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 p-4 pt-0">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary px-4">Initialize Account</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

