{% extends "admin/layout.twig" %}

{% set active_page = 'positions' %}

{% block title %}Positions Management • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin">Admin</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Positions</li>
                </ol>
            </nav>
            <h1 class="fs-4 mb-0">Positions Management</h1>
        </div>
    </div>

    <!-- Add/Edit Form -->
    <div class="card bg-body-tertiary border-transparent mb-7">
        <div class="card-body p-4">
            <form action="{{ PROOT }}admin/positions/store" method="POST">
                {{ csrf_field() }}
                {% if edit_position %}
                    <input type="hidden" name="edit_id" value="{{ edit_position.position_id }}">
                {% endif %}

                <div class="row align-items-end g-3">
                    <div class="col-md-4">
                        <label class="form-label" for="election_id">Target Election</label>
                        <select class="form-control" name="election_id" id="election_id" required>
                            <option value="">Select Election</option>
                            {% for election in elections %}
                                <option value="{{ election.election_id }}" {{ (edit_position.election_id == election.election_id) ? 'selected' : '' }}>
                                    {{ election.election_name }} ({{ election.election_by }})
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="position_name">Position Name</label>
                        <input type="text" class="form-control" name="position_name" id="position_name" value="{{ edit_position.position_name }}" placeholder="e.g. SRC President" required>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            {{ edit_position ? 'Update' : 'Add' }}
                        </button>
                    </div>
                </div>
                {% if edit_position %}
                    <div class="mt-2">
                        <a href="{{ PROOT }}admin/positions" class="btn btn-sm btn-link text-secondary">Cancel Edit</a>
                    </div>
                {% endif %}
            </form>
        </div>
    </div>

    <!-- List Table -->
    <div class="card mb-6">
        <div class="card-header">
            <h3 class="fs-6 mb-0">Registered Positions</h3>
        </div>
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="fs-sm">Position</th>
                        <th class="fs-sm">Election</th>
                        <th class="fs-sm">Election Status</th>
                        <th class="fs-sm text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for pos in positions %}
                        <tr>
                            <td><strong class="fw-semibold">{{ pos.position_name }}</strong></td>
                            <td>{{ pos.election_name }} ({{ pos.election_by }})</td>
                            <td>
                                {% if pos.session == 1 %}
                                    <span class="badge bg-success-subtle text-success">Running</span>
                                {% elseif pos.session == 2 %}
                                    <span class="badge bg-danger-subtle text-danger">Ended</span>
                                {% else %}
                                    <span class="badge bg-secondary-subtle text-secondary">Draft</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                {% if pos.session == 0 %}
                                    <a href="{{ PROOT }}admin/positions?edit={{ pos.position_id }}" class="btn btn-sm btn-warning me-1">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <button class="btn btn-sm btn-danger delete-btn" data-id="{{ pos.position_id }}">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                {% else %}
                                    <span class="text-muted small">Locked</span>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5">No positions found.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to delete this position?')) {
                window.location.href = '{{ PROOT }}admin/positions/delete/' + id;
            }
        });
    });
</script>
{% endblock %}
