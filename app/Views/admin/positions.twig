{% extends "admin/layout.twig" %}

{% set active_page = 'positions' %}

{% block title %}Positions Hub • Kokuromotie{% endblock %}

{% block content %}
    <div class="page-header d-flex justify-content-between align-items-center">
        <div>
            <h1>Positions Hub</h1>
            <p>Define and manage electoral offices for your sessions.</p>
        </div>
        <div class="d-none d-md-block">
            <div class="btn btn-light shadow-sm">
                <span class="material-symbols-outlined fs-5">account_tree</span> Structure Manager
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main List Section -->
        <div class="col-xl-8">
            <div class="card border-0 shadow-none bg-transparent">
                <div class="card-header border-0 px-0 pt-0 pb-3 bg-transparent">
                    <div class="row g-3 align-items-center w-100">
                        <div class="col-md">
                            <h5 class="fw-bold mb-0">Office Registry</h5>
                        </div>
                        <div class="col-md-4">
                            <select id="electionFilter" class="form-select bg-white shadow-sm border-0">
                                <option value="all">All Sessions</option>
                                {% for election in elections %}
                                    <option value="{{ election.uuid }}">
                                        {{ election.title }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text bg-white border-0 shadow-sm"><span class="material-symbols-outlined fs-6 text-muted">search</span></span>
                                <input type="text" id="positionSearch" class="form-control bg-white border-0 shadow-sm" placeholder="Search offices...">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card border-0 shadow-sm overflow-hidden">
                    <div class="table-container">
                        <table class="table align-middle" id="positionsTable">
                            <thead>
                                <tr>
                                    <th class="ps-4">Office Details</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pos in positions %}
                                    <tr class="position-row" data-election-id="{{ pos.election_uuid }}">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="stat-icon me-3 bg-light" style="width: 42px; height: 42px; font-size: 1.1rem;">
                                                    <span class="material-symbols-outlined">work</span>
                                                </div>
                                                <div>
                                                    <div class="fw-bold fs-6">{{ pos.position_name }}</div>
                                                     <div class="text-muted extra-small d-flex align-items-center">
                                                        <span class="material-symbols-outlined me-1 fs-6">inventory_2</span> {{ pos.title }}
                                                        <span class="mx-2 opacity-25">|</span>
                                                        <span class="badge {{ pos.gender_restriction == 'all' ? 'bg-light text-muted' : 'bg-indigo-subtle text-indigo' }} extra-small px-2">
                                                            {{ pos.gender_restriction|upper }}
                                                        </span>
                                                        <span class="mx-2 opacity-25">|</span>
                                                        <span class="badge bg-light text-dark extra-small px-2 border border-secondary border-opacity-25" title="Display Order">
                                                            Order: {{ pos.display_order }}
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                         <td style="width: 140px;">
                                            {% if pos.status == 1 %}
                                                <span class="badge badge-success">Active</span>
                                            {% elseif pos.status == 2 %}
                                                <span class="badge badge-secondary" style="background: #e2e8f0; color: #475569;">Ended</span>
                                            {% else %}
                                                <span class="badge badge-warning">Draft</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex justify-content-end gap-2">
                                                {% if pos.status == 0 %}
                                                    <a href="{{ PROOT }}admin/positions?edit={{ pos.position_id }}" class="btn btn-light btn-sm px-2">
                                                        <span class="material-symbols-outlined fs-6">edit</span>
                                                    </a>
                                                    <button class="btn btn-light btn-sm px-2 text-danger delete-btn" data-id="{{ pos.position_id }}">
                                                        <span class="material-symbols-outlined fs-6">delete</span>
                                                    </button>
                                                {% else %}
                                                    <span class="badge bg-light text-muted border px-3">Locked</span>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr id="noResults">
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <span class="material-symbols-outlined fs-1 opacity-25">book_off</span>
                                            <p class="mt-2">No positions found in the registry.</p>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Section -->
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header border-0 pb-0">
                    <h5>{{ edit_position ? 'Office Editor' : 'Register New Office' }}</h5>
                </div>
                <div class="card-body">
                    <form action="{{ PROOT }}admin/positions/store" method="POST">
                        {{ csrf_field()|raw }}
                        {% if edit_position %}
                            <input type="hidden" name="edit_id" value="{{ edit_position.position_id }}">
                        {% endif %}

                        <div class="mb-4">
                            <label class="form-label">Office Title</label>
                            <input type="text" class="form-control" name="position_name" value="{{ edit_position.position_name }}" placeholder="e.g. SRC President" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Target Election Session</label>
                            <select class="form-select" name="election_uuid" id="election_uuid_select" required>
                                <option value="">Select Election...</option>
                                {% for election in draft_elections %}
                                    <option value="{{ election.uuid }}" {{ (edit_position.election_uuid ?? active_election_context) == election.uuid ? 'selected' : '' }}>
                                        {{ election.title }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        
                        <div class="mb-4">
                            <label class="form-label">Display Order</label>
                            <select class="form-select" name="display_order" id="display_order_select" required>
                                {% for i in 1..30 %}
                                    <option value="{{ i }}" {{ (edit_position.display_order ?? 0) == i ? 'selected' : '' }}>Position Order {{ i }}</option>
                                {% endfor %}
                            </select>
                            <div class="form-text small text-muted mt-2"><span class="material-symbols-outlined fs-6 align-middle">sort</span> Positions with lower numbers (e.g. 1, 2) appear first on the voters' ballot.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label mb-3">Voting Restriction Matrix</label>
                            <div class="bg-light p-3 rounded-4">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="gender_restriction" id="restrictAll" value="all" {{ (not edit_position or edit_position.gender_restriction == 'all') ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="restrictAll">
                                        Universal Participation <span class="text-muted fw-normal d-block extra-small">Open to all registered voters.</span>
                                    </label>
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="gender_restriction" id="restrictMale" value="male" {{ edit_position.gender_restriction == 'male' ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="restrictMale">
                                        Male Restricted <span class="text-muted fw-normal d-block extra-small">Only men can participate in this contest.</span>
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="gender_restriction" id="restrictFemale" value="female" {{ edit_position.gender_restriction == 'female' ? 'checked' : '' }}>
                                    <label class="form-check-label small fw-bold" for="restrictFemale">
                                        Female Restricted <span class="text-muted fw-normal d-block extra-small">Only women can participate in this contest.</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 mt-2">
                            {{ edit_position ? 'Update Parameters' : 'Create Office' }}
                        </button>

                        {% if edit_position %}
                            <div class="mt-3 text-center">
                                <a href="{{ PROOT }}admin/positions" class="text-muted small text-decoration-none d-flex align-items-center justify-content-center">
                                    <span class="material-symbols-outlined fs-6 me-1">cancel</span> Discard Changes
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
                <div class="card-footer border-0 bg-light bg-opacity-50">
                    <div class="d-flex align-items-start">
                        <span class="material-symbols-outlined text-primary me-2 fs-5">tips_and_updates</span>
                        <p class="extra-small text-muted mb-0">Positions can only be added to sessions that are currently in <strong>Draft</strong> status.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .fw-mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
</style>
{% endblock %}

{% block scripts %}
<script>
    const takenOrders = {{ taken_orders|json_encode|raw }};
    const currentEditOrder = {{ edit_position.display_order ?? 0 }};
    
    function updateDisplayOrderOptions() {
        const electionId = $('#election_uuid_select').val();
        const taken = takenOrders[electionId] || [];
        
        $('#display_order_select option').each(function() {
            const val = parseInt($(this).val());
            if (taken.includes(val) && val !== currentEditOrder) {
                $(this).attr('disabled', 'disabled').hide();
            } else {
                $(this).removeAttr('disabled').show();
            }
        });
        
        // If the currently selected option is now disabled, reset the selection to the first available
        if ($('#display_order_select option:selected').is(':disabled') || !$('#display_order_select').val()) {
            $('#display_order_select').val($('#display_order_select option:not(:disabled):first').val());
        }
    }

    $(document).ready(function() {
        $('#election_uuid_select').on('change', updateDisplayOrderOptions);
        updateDisplayOrderOptions(); // Run on load
        
        // Combined Filter and Search Logic
        function performFiltering() {
            var searchTerm = $("#positionSearch").val().toLowerCase();
            var electionId = $("#electionFilter").val();
            var visibleRows = 0;

            $(".position-row").each(function() {
                var $row = $(this);
                var rowText = $row.text().toLowerCase();
                var rowElectionId = $row.data("election-id");

                var matchesSearch = rowText.indexOf(searchTerm) > -1;
                var matchesElection = (electionId === "all" || rowElectionId == electionId);

                if (matchesSearch && matchesElection) {
                    $row.show();
                    visibleRows++;
                } else {
                    $row.hide();
                }
            });

            // Handle "No Results" display
            if (visibleRows === 0 && $(".position-row").length > 0) {
                if ($("#noFilterResults").length === 0) {
                    $("#positionsTable tbody").append('<tr id="noFilterResults"><td colspan="3" class="text-center py-5 text-muted">No positions match your criteria.</td></tr>');
                }
            } else {
                $("#noFilterResults").remove();
            }
        }

        $("#positionSearch").on("keyup", performFiltering);
        $("#electionFilter").on("change", performFiltering);

        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to purge this position? All candidates linked to it will be affected.')) {
                window.location.href = '{{ PROOT }}admin/positions/delete/' + id;
            }
        });
    });
</script>
{% endblock %}

