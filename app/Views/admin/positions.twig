{% extends "admin/layout.twig" %}

{% set active_page = 'positions' %}

{% block title %}Positions Hub • Puubu{% endblock %}

{% block content %}
    <div class="mb-5">
        <h1 class="h3 fw-bold mb-1">Positions Hub 🏛️</h1>
        <p class="text-muted small">Define and manage electoral offices for your sessions.</p>
    </div>

    <div class="row g-4">
        <!-- Main List Section -->
        <div class="col-xl-8">
            <div class="card shadow-none border-0 bg-transparent">
                <div class="card-header border-0 px-0 pt-0 pb-3 bg-transparent">
                    <div class="row g-3 align-items-center">
                        <div class="col-md">
                            <h5 class="fw-bold mb-0">Office Registry 📋</h5>
                        </div>
                        <div class="col-md-4">
                            <select id="electionFilter" class="form-select form-select-sm bg-white border shadow-sm">
                                <option value="all">All Elections</option>
                                {% for election in elections %}
                                    <option value="{{ election.election_id }}">{{ election.election_name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text bg-white border border-end-0 shadow-sm"><span class="material-symbols-outlined fs-6 text-muted">search</span></span>
                                <input type="text" id="positionSearch" class="form-control bg-white border border-start-0 shadow-sm" placeholder="Search offices...">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card shadow-none border overflow-hidden">
                    <div class="table-responsive">
                        <table class="table align-middle" id="positionsTable">
                            <thead>
                                <tr>
                                    <th class="ps-4">Office Details</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for pos in positions %}
                                    <tr class="position-row" data-election-id="{{ pos.election_id }}">
                                        <td class="ps-4">
                                            <div class="d-flex align-items-center">
                                                <div class="avatar avatar-sm me-3 d-flex align-items-center justify-content-center text-indigo fw-bold bg-indigo-subtle rounded-circle" style="width: 40px; height: 40px;">
                                                    <span class="material-symbols-outlined fs-5">work</span>
                                                </div>
                                                <div>
                                                    <div class="fw-bold text-dark fs-6">{{ pos.position_name }}</div>
                                                    <div class="text-muted extra-small d-flex align-items-center">
                                                        <span class="material-symbols-outlined me-1 fs-6">inventory_2</span> {{ pos.election_name }}
                                                        <span class="mx-2 opacity-25">|</span>
                                                        <span class="fw-mono">PID: {{ pos.position_id }}</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td style="width: 140px;">
                                            {% if pos.session == 1 %}
                                                <span class="badge bg-success-subtle text-success px-3 py-1 border border-success-subtle d-inline-flex align-items-center">
                                                    <span class="p-1 bg-success rounded-circle me-2 animate-pulse"></span> Active
                                                </span>
                                            {% elseif pos.session == 2 %}
                                                <span class="badge bg-secondary-subtle text-secondary px-3 py-1 border border-secondary-subtle">Completed</span>
                                            {% else %}
                                                <span class="badge bg-warning-subtle text-warning px-3 py-1 border border-warning-subtle">Draft</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="btn-group shadow-sm rounded">
                                                {% if pos.session == 0 %}
                                                    <a href="{{ PROOT }}admin/positions?edit={{ pos.position_id }}" class="btn btn-sm btn-white border border-end-0" title="Edit Office">
                                                        <span class="material-symbols-outlined fs-6 text-muted">edit</span>
                                                    </a>
                                                    <button class="btn btn-sm btn-white border text-danger delete-btn" data-id="{{ pos.position_id }}" title="Purge Office">
                                                        <span class="material-symbols-outlined fs-6">delete</span>
                                                    </button>
                                                {% else %}
                                                    <span class="badge bg-light text-muted border px-3">Registry Locked</span>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr id="noResults">
                                        <td colspan="3" class="text-center py-5 text-muted">
                                            <div class="mb-2"><span class="material-symbols-outlined fs-1 opacity-25">book_off</span></div>
                                            No positions found in the registry.
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Action Section -->
        <div class="col-xl-4">
            <div class="card border border-2 border-indigo border-opacity-10 shadow-sm">
                <div class="card-header bg-light bg-opacity-50 border-bottom-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">{{ edit_position ? 'Office Editor ✨' : 'New Office ✨' }}</h5>
                    <p class="text-muted small mt-1 mb-0">{{ edit_position ? 'Update existing office details.' : 'Add a new contestable position to an election.' }}</p>
                </div>
                <div class="card-body p-4">
                    <form action="{{ PROOT }}admin/positions/store" method="POST">
                        {{ csrf_field()|raw }}
                        {% if edit_position %}
                            <input type="hidden" name="edit_id" value="{{ edit_position.position_id }}">
                        {% endif %}

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider">Office Title</label>
                            <input type="text" class="form-control form-control-lg bg-light border-0" name="position_name" value="{{ edit_position.position_name }}" placeholder="e.g. SRC President" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase tracking-wider">Target Election</label>
                            <select class="form-select form-control-lg bg-light border-0" name="election_id" required>
                                <option value="">Select Election...</option>
                                {% for election in elections %}
                                    <option value="{{ election.election_id }}" {{ edit_position.election_id == election.election_id ? 'selected' : '' }}>
                                        {{ election.election_name }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>

                        <button type="submit" class="btn btn-indigo w-100 py-3 fw-bold">
                            {{ edit_position ? 'Update Position' : 'Create Position' }}
                        </button>

                        {% if edit_position %}
                            <div class="mt-3 text-center">
                                <a href="{{ PROOT }}admin/positions" class="text-muted small text-decoration-none d-flex align-items-center justify-content-center">
                                    <span class="material-symbols-outlined fs-6 me-1">cancel</span> Discard Changes
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
                <div class="card-footer bg-light bg-opacity-50 border-top-0 p-4">
                    <div class="d-flex align-items-start">
                        <span class="material-symbols-outlined text-warning me-2 fs-5">tips_and_updates</span>
                        <p class="small text-muted mb-0">Positions can only be added to elections that are currently in <strong>Draft</strong> status.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .fw-mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
    .animate-pulse {
        animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: .5; }
    }
</style>
{% endblock %}

{% block scripts %}
<script>
    $(document).ready(function() {
        // Combined Filter and Search Logic
        function performFiltering() {
            var searchTerm = $("#positionSearch").val().toLowerCase();
            var electionId = $("#electionFilter").val();
            var visibleRows = 0;

            $(".position-row").each(function() {
                var $row = $(this);
                var rowText = $row.text().toLowerCase();
                var rowElectionId = $row.data("election-id");

                var matchesSearch = rowText.indexOf(searchTerm) > -1;
                var matchesElection = (electionId === "all" || rowElectionId == electionId);

                if (matchesSearch && matchesElection) {
                    $row.show();
                    visibleRows++;
                } else {
                    $row.hide();
                }
            });

            // Handle "No Results" display
            if (visibleRows === 0 && $(".position-row").length > 0) {
                if ($("#noFilterResults").length === 0) {
                    $("#positionsTable tbody").append('<tr id="noFilterResults"><td colspan="3" class="text-center py-5 text-muted">No positions match your criteria.</td></tr>');
                }
            } else {
                $("#noFilterResults").remove();
            }
        }

        $("#positionSearch").on("keyup", performFiltering);
        $("#electionFilter").on("change", performFiltering);

        $('.delete-btn').on('click', function() {
            var id = $(this).data('id');
            if (confirm('Are you sure you want to purge this position? All candidates linked to it will be affected.')) {
                window.location.href = '{{ PROOT }}admin/positions/delete/' + id;
            }
        });
    });
</script>
{% endblock %}
