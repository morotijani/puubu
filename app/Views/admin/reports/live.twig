{% extends "admin/layout.twig" %}

{% set active_page = 'dashboard' %}

{% block title %}Live Reports • {{ election.election_name }}{% endblock %}

{% block styles %}
<style>
    :root {
        --admin-primary: #4f46e5;
        --admin-primary-rgb: 79, 70, 229;
        --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    /* Modal Step Transitions */
    .modal-step {
        transition: all 0.3s ease;
    }
    .modal-step.d-none {
        display: none !important;
        opacity: 0;
        transform: translateX(20px);
    }

    /* Premium UI Components */
    .premium-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.75rem;
        display: block;
    }

    /* Animated Security Shield */
    .security-shield-animated {
        position: relative;
        display: inline-block;
    }
    .shield-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: rgba(220, 53, 69, 0.1);
        border-radius: 50%;
        animation: pulse-orb 2s infinite;
    }
    @keyframes pulse-orb {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    /* Modern OTP UI */
    .otp-modern-wrapper {
        position: relative;
        max-width: 340px;
        margin: 0 auto;
    }
    .otp-hidden-input {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        opacity: 0 !important;
        cursor: text !important;
        z-index: 10 !important;
        border: none !important;
        background: transparent !important;
        color: transparent !important;
        caret-color: transparent !important;
    }
    .otp-box {
        width: 48px;
        height: 64px;
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Outfit', sans-serif;
    }
    .otp-box.active {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(var(--admin-primary-rgb), 0.1);
        transform: translateY(-2px);
    }
    .otp-box.filled {
        background: #fff;
        border-color: #cbd5e1;
    }
</style>
{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin">Admin</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Live Reports</li>
                </ol>
            </nav>
            <h1 class="fs-4 mb-0">{{ election.election_name }} - Live Results</h1>
            <p class="text-muted small">Election By: {{ election.election_by }}</p>
        </div>
        <div class="col-12 col-sm-auto mt-4 mt-sm-0">
            <div class="row gx-2">
                {% if election.session == 1 %}
                    <div class="col-auto">
                        <button type="button" class="btn btn-warning shadow-sm d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#stopElectionModal">
                            <span class="material-symbols-outlined me-1 fs-6">stop_circle</span> End Election
                        </button>
                    </div>
                {% endif %}
                {% if election.session == 2 %}
                    <div class="col-auto">
                        <a href="{{ PROOT }}admin/reports/download/{{ election.election_id }}" class="btn btn-dark shadow-sm d-flex align-items-center">
                            <span class="material-symbols-outlined me-1 fs-6">download</span> Download PDF
                        </a>
                    </div>
                {% endif %}
                <div class="col-auto">
                    <button class="btn btn-light" onclick="location.reload()">
                        <i class="bi bi-arrow-clockwise"></i> Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="row g-4 mb-7">
        <div class="col-md-4">
            <div class="card bg-primary text-white border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-white-50 text-uppercase mb-2 small fw-bold">Total Votes Cast</h6>
                    <h2 class="mb-0" id="stat-total-votes">0</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-dark text-white border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-white-50 text-uppercase mb-2 small fw-bold">Turnout Percentage</h6>
                    <h2 class="mb-0" id="stat-turnout">0%</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-white border-0 shadow-sm">
                <div class="card-body p-4">
                    <h6 class="text-muted text-uppercase mb-2 small fw-bold">Status</h6>
                    <h2 class="mb-0">
                        {% if election.session == 1 %}
                            <span class="text-success"><i class="bi bi-record-fill me-1"></i> Running</span>
                        {% else %}
                            <span class="text-danger"><i class="bi bi-check-circle-fill me-1"></i> Ended</span>
                        {% endif %}
                    </h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Live Results Container -->
    <div id="results-container">
        <!-- Dynamic content injected via JS -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-muted">Gathering live results...</p>
        </div>
    </div>

    {% if election.session == 1 %}
    <!-- Stop Election Modal (2FA Step Form) -->
    <div class="modal fade" id="stopElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.98); box-shadow: var(--shadow-2xl);">
                <form action="{{ PROOT }}admin/elections/stop/{{ election.election_id }}" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="stop_election" value="1">
                    
                    <!-- Step 1: Reason -->
                    <div class="modal-step" id="stop-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">report</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Termination Audit</h3>
                                <p class="text-muted small px-4">State the reason for early closure before proceeding to authorization.</p>
                            </div>

                            <div class="mb-5">
                                <label class="premium-label">REASON FOR TERMINATION</label>
                                <textarea class="form-control premium-input p-3 bg-light rounded-4 border-0" name="manual_stop_reason" id="stop_reason_input" rows="3" placeholder="Briefly explain the cause for early closure..." required style="resize: none;"></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-danger btn-lg py-3 fw-bold rounded-4 shadow-lg next-step" data-next="stop-step-2">
                                    Proceed to Authorization <span class="material-symbols-outlined ms-2 fs-5">arrow_forward</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Abort
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="stop-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb"></div>
                                    <span class="material-symbols-outlined text-danger display-4 position-relative">lock</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization 🔒</h3>
                                <p class="text-muted px-4 small">Confirm your identity with your security key to permanently terminate this session.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <input type="text" name="otp_code" class="otp-hidden-input" maxlength="6" pattern="\d*" inputmode="numeric" autocomplete="one-time-code" required>
                                <div class="d-flex justify-content-between gap-2">
                                    <div class="otp-box" data-index="0"></div>
                                    <div class="otp-box" data-index="1"></div>
                                    <div class="otp-box" data-index="2"></div>
                                    <div class="otp-box" data-index="3"></div>
                                    <div class="otp-box" data-index="4"></div>
                                    <div class="otp-box" data-index="5"></div>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-dark btn-lg py-3 fw-bold rounded-4 shadow-lg">
                                    Confirm Termination
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="stop-step-1">
                                    Back to Reason
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const electionId = "{{ election.election_id }}";
    const proot = "{{ PROOT }}";
    let charts = {};

    function updateStats(data) {
        $('#stat-total-votes').text(data.total_votes_cast);
        const turnout = data.total_voters > 0 ? ((data.total_votes_cast / data.total_voters) * 100).toFixed(1) : 0;
        $('#stat-turnout').text(turnout + '%');
    }

    function renderResults(data) {
        const container = $('#results-container');
        
        // Use a temporary storage to compare if we need to redraw
        data.results.forEach((res, index) => {
            const posId = res.position.position_id;
            const posName = res.position.position_name;
            
            let cardId = `pos-card-${posId}`;
            let chartId = `chart-${posId}`;
            
            if ($(`#${cardId}`).length === 0) {
                // Create new card for position
                const html = `
                    <div class="card mb-6 shadow-sm border-0" id="${cardId}">
                        <div class="card-header bg-transparent border-0 pt-4 px-4">
                            <h3 class="fs-5 mb-0 fw-bold">${posName}</h3>
                        </div>
                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div style="height: 300px;">
                                        <canvas id="${chartId}"></canvas>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <ul class="list-group list-group-flush" id="list-${posId}">
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                if (index === 0) container.empty();
                container.append(html);
            }

            // Update List
            const list = $(`#list-${posId}`);
            list.empty();
            
            const labels = [];
            const votes = [];
            const colors = [
                '#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b', 
                '#858796', '#5a5c69', '#2e59d9', '#17a673', '#2c9faf'
            ];

            res.contestants.forEach((c, cIndex) => {
                const name = c.cont_fname + ' ' + c.cont_lname;
                const initials = c.cont_fname.charAt(0) + c.cont_lname.charAt(0);
                const profileImg = c.cont_profile ? `${proot}media/uploadedprofile/${c.cont_profile}` : null;
                const isUnopposed = res.contestants.length === 1;

                const avatarHtml = profileImg 
                    ? `<img src="${profileImg}" class="rounded-circle me-3 border" style="width: 40px; height: 40px; object-fit: cover;">`
                    : `<div class="avatar-initials rounded-circle me-3 d-flex align-items-center justify-content-center bg-primary-subtle text-primary fw-bold" style="width: 40px; height: 40px; font-size: 14px;">${initials}</div>`;

                if (isUnopposed) {
                    labels.push(name + ' (YES)');
                    votes.push(c.results);
                    labels.push(name + ' (NO)');
                    votes.push(c.results_no);

                    list.append(`
                        <li class="list-group-item bg-transparent px-0 border-0 mb-4">
                            <div class="d-flex align-items-center mb-3">
                                ${avatarHtml}
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">${name}</span>
                                        <span class="badge bg-light text-muted extra-small">Unopposed</span>
                                    </div>
                                    <div class="extra-small text-muted">Ballot #${c.contestant_ballot_number}</div>
                                </div>
                            </div>
                            <div class="d-flex gap-2">
                                <div class="flex-grow-1 bg-success-subtle p-3 rounded-4 d-flex justify-content-between align-items-center">
                                    <span class="small fw-bold text-success">YES</span>
                                    <span class="badge bg-success rounded-pill fs-6">${c.results}</span>
                                </div>
                                <div class="flex-grow-1 bg-danger-subtle p-3 rounded-4 d-flex justify-content-between align-items-center">
                                    <span class="small fw-bold text-danger">NO</span>
                                    <span class="badge bg-danger rounded-pill fs-6">${c.results_no}</span>
                                </div>
                            </div>
                        </li>
                    `);
                } else {
                    labels.push(name);
                    votes.push(c.results);
                    
                    list.append(`
                        <li class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-0 border-0 mb-3">
                            <div class="d-flex align-items-center">
                                ${avatarHtml}
                                <div>
                                    <span class="fw-bold">${name}</span>
                                    <div class="extra-small text-muted">Ballot #${c.contestant_ballot_number}</div>
                                </div>
                            </div>
                            <span class="badge bg-primary rounded-pill fs-6 px-3 shadow-sm">${c.results}</span>
                        </li>
                    `);
                }
            });

            // Update Chart
            if (!charts[posId]) {
                const ctx = document.getElementById(chartId).getContext('2d');
                charts[posId] = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Votes',
                            data: votes,
                            backgroundColor: colors.slice(0, labels.length),
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: {
                            y: { beginAtZero: true, grid: { display: false } },
                            x: { grid: { display: false } }
                        }
                    }
                });
            } else {
                charts[posId].data.labels = labels;
                charts[posId].data.datasets[0].data = votes;
                charts[posId].update();
            }
        });
    }

    function pollData() {
        $.ajax({
            url: proot + 'admin/api/reports/' + electionId,
            method: 'GET',
            success: function(data) {
                updateStats(data);
                renderResults(data);
            }
        });
    }

    $(document).ready(function() {
        // Multi-step navigation
        $('.next-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var nextStepId = $(this).data('next');
            var $form = $(this).closest('form');
            
            // Basic validation for Step 1
            if (currentStepId === 'stop-step-1') {
                if (!$('#stop_reason_input').val()) {
                    Toast.fire({ icon: 'warning', title: 'Please provide a reason' });
                    return;
                }
            }
            
            $(this).closest('.modal-step').addClass('d-none');
            $('#' + nextStepId).removeClass('d-none');
        });

        $('.prev-step').on('click', function() {
            var prevStepId = $(this).data('prev');
            $(this).closest('.modal-step').addClass('d-none');
            $('#' + prevStepId).removeClass('d-none');
        });

        // OTP Input Logic
        $('.otp-hidden-input').on('input', function() {
            const val = $(this).val();
            const $wrapper = $(this).closest('.otp-modern-wrapper');
            const $boxes = $wrapper.find('.otp-box');
            
            $boxes.removeClass('active filled').text('');
            
            for(let i = 0; i < 6; i++) {
                if(i < val.length) {
                    $boxes.eq(i).addClass('filled').text(val[i]);
                }
                if(i === val.length) {
                    $boxes.eq(i).addClass('active');
                }
            }
        });

        // Focus hidden input when clicking on boxes
        $('.otp-box').on('click', function() {
            $(this).siblings('.otp-hidden-input').focus();
        });

        pollData();
        {% if election.session == 1 %}
            setInterval(pollData, 5000);
        {% endif %}
    });
</script>
{% endblock %}
