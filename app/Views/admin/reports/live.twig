{% extends "admin/layout.twig" %}

{% set active_page = 'dashboard' %}

{% block title %}Live Reports • {{ election.title }}{% endblock %}

{% block styles %}
<style>
    :root {
        --admin-primary: #4f46e5;
        --admin-primary-rgb: 79, 70, 229;
        --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }

    /* Modal Step Transitions */
    .modal-step {
        transition: all 0.3s ease;
    }
    .modal-step.d-none {
        display: none !important;
        opacity: 0;
        transform: translateX(20px);
    }

    /* Premium UI Components */
    .premium-label {
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        margin-bottom: 0.75rem;
        display: block;
    }

    /* Animated Security Shield */
    .security-shield-animated {
        position: relative;
        display: inline-block;
    }
    .shield-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 120px;
        height: 120px;
        background: rgba(220, 53, 69, 0.1);
        border-radius: 50%;
        animation: pulse-orb 2s infinite;
    }
    @keyframes pulse-orb {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    /* Modern OTP UI */
    .otp-modern-wrapper {
        position: relative;
        max-width: 340px;
        margin: 0 auto;
    }
    .otp-hidden-input {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        height: 100% !important;
        opacity: 0 !important;
        cursor: text !important;
        z-index: 10 !important;
        border: none !important;
        background: transparent !important;
        color: transparent !important;
        caret-color: transparent !important;
    }
    .otp-box {
        width: 48px;
        height: 64px;
        background: #f1f5f9;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Outfit', sans-serif;
    }
    .otp-box.active {
        border-color: var(--admin-primary);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(var(--admin-primary-rgb), 0.1);
        transform: translateY(-2px);
    }
    .otp-box.filled {
        background: #fff;
        border-color: #cbd5e1;
    }
</style>
{% endblock %}

{% block content %}
    <div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2">
                    <li class="breadcrumb-item"><a href="{{ PROOT }}admin">Intelligence</a></li>
                    <li class="breadcrumb-item active">Live Reports</li>
                </ol>
            </nav>
            <h1>{{ election.title }} • Results</h1>
            <p>Mission Authority: {{ election.organized_by }}</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            {% if election.status == 1 %}
                <button type="button" class="btn btn-accent shadow-sm" data-bs-toggle="modal" data-bs-target="#stopElectionModal">
                    <span class="material-symbols-outlined fs-6">stop_circle</span> Terminate Session
                </button>
            {% endif %}
            {% if election.status == 2 %}
                <div class="dropdown">
                    <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <span class="material-symbols-outlined fs-6">download</span> Export Intelligence
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-2">
                        <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ PROOT }}admin/reports/download/{{ election.uuid }}"><span class="material-symbols-outlined me-2 text-muted fs-6">picture_as_pdf</span> Official PDF Report</a></li>
                        <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ PROOT }}admin/reports/export/voters/{{ election.uuid }}"><span class="material-symbols-outlined me-2 text-muted fs-6">group</span> Participation Data (CSV)</a></li>
                        <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ PROOT }}admin/reports/export/logs/{{ election.uuid }}"><span class="material-symbols-outlined me-2 text-muted fs-6">history_edu</span> Security Audit Logs</a></li>
                        <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ PROOT }}admin/reports/export/ballots/{{ election.uuid }}"><span class="material-symbols-outlined me-2 text-muted fs-6">ballot</span> Individual Ballots</a></li>
                    </ul>
                </div>
            {% endif %}
            <button class="btn btn-light" onclick="location.reload()">
                <span class="material-symbols-outlined fs-6">refresh</span>
            </button>
        </div>
    </div>

    <!-- Stats Overview -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-info">
                    <h4>Total Ballots Cast</h4>
                    <h2 id="stat-total-votes">0</h2>
                </div>
                <div class="d-flex flex-column align-items-end gap-2">
                    <div class="stat-icon bg-primary-subtle text-primary">
                        <span class="material-symbols-outlined">how_to_vote</span>
                    </div>
                    <span class="badge badge-success">Live</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-info">
                    <h4>Registered Electorate</h4>
                    <h2 id="stat-total-voters">0</h2>
                </div>
                <div class="stat-icon bg-indigo-subtle text-indigo">
                    <span class="material-symbols-outlined">group</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-info">
                    <h4>Turnout Efficiency</h4>
                    <h2 id="stat-turnout">0%</h2>
                </div>
                <div class="stat-icon bg-accent-subtle text-accent">
                    <span class="material-symbols-outlined">analytics</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-info">
                    <h4>Session Status</h4>
                    <h2 id="stat-session-status">
                        {% if election.status == 1 %}
                            <span class="text-success fs-4 fw-bold">RUNNING</span>
                        {% else %}
                            <span class="text-muted fs-4 fw-bold">CONCLUDED</span>
                        {% endif %}
                    </h2>
                </div>
                <div class="stat-icon bg-light text-muted">
                    <span class="material-symbols-outlined">sensors</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Live Results Container -->
    <div id="results-container">
        <!-- Dynamic content injected via JS -->
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-4 text-muted fw-bold">Gathering Electoral Intelligence...</p>
        </div>
    </div>

    {% if election.status == 1 %}
    <!-- Stop Election Modal (2FA Step Form) -->
    <div class="modal fade" id="stopElectionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 overflow-hidden" style="border-radius: 32px; background: rgba(255, 255, 255, 0.98); box-shadow: var(--shadow-2xl);">
                <form action="{{ PROOT }}admin/elections/stop/{{ election.uuid }}" method="POST">
                    {{ csrf_field()|raw }}
                    <input type="hidden" name="stop_election" value="1">
                    
                    <!-- Step 1: Reason -->
                    <div class="modal-step" id="stop-step-1">
                        <div class="modal-body p-5">
                            <div class="text-center mb-5">
                                <div class="bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 72px; height: 72px;">
                                    <span class="material-symbols-outlined fs-1">report</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Termination Audit</h3>
                                <p class="text-muted small px-4">State the reason for early closure before proceeding to authorization.</p>
                            </div>

                            <div class="mb-5">
                                <label class="premium-label">REASON FOR TERMINATION</label>
                                <textarea class="form-control premium-input p-3 bg-light rounded-4 border-0" name="manual_stop_reason" id="stop_reason_input" rows="3" placeholder="Briefly explain the cause for early closure..." required style="resize: none;"></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="button" class="btn btn-danger btn-lg py-3 fw-bold rounded-4 shadow-lg next-step" data-next="stop-step-2">
                                    Proceed to Authorization <span class="material-symbols-outlined ms-2 fs-5">arrow_forward</span>
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2" data-bs-dismiss="modal">
                                    Abort
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 2: Security -->
                    <div class="modal-step d-none" id="stop-step-2">
                        <div class="modal-body p-5 text-center">
                            <div class="mb-5">
                                <div class="security-shield-animated mb-4">
                                    <div class="shield-orb"></div>
                                    <span class="material-symbols-outlined text-danger display-4 position-relative">lock</span>
                                </div>
                                <h3 class="fw-bold text-dark mb-1">Authorization 🔒</h3>
                                <p class="text-muted px-4 small">Confirm your identity with your security key to permanently terminate this session.</p>
                            </div>

                            <div class="otp-modern-wrapper mb-5">
                                <input type="text" name="otp_code" class="otp-hidden-input" maxlength="6" pattern="\d*" inputmode="numeric" autocomplete="one-time-code" required>
                                <div class="d-flex justify-content-between gap-2">
                                    <div class="otp-box" data-index="0"></div>
                                    <div class="otp-box" data-index="1"></div>
                                    <div class="otp-box" data-index="2"></div>
                                    <div class="otp-box" data-index="3"></div>
                                    <div class="otp-box" data-index="4"></div>
                                    <div class="otp-box" data-index="5"></div>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-dark btn-lg py-3 fw-bold rounded-4 shadow-lg">
                                    Confirm Termination
                                </button>
                                <button type="button" class="btn btn-link text-muted fw-semibold text-decoration-none py-2 prev-step" data-prev="stop-step-1">
                                    Back to Reason
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}
{% endblock %}

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const electionId = "{{ election.uuid }}";
    const proot = "{{ PROOT }}";
    let charts = {};

    function updateStats(data) {
        $('#stat-total-votes').text(data.total_votes_cast);
        $('#stat-total-voters').text(data.total_voters);
        const turnout = data.total_voters > 0 ? ((data.total_votes_cast / data.total_voters) * 100).toFixed(1) : 0;
        $('#stat-turnout').text(turnout + '%');
    }

    function renderResults(data) {
        const container = $('#results-container');
        
        // Use a temporary storage to compare if we need to redraw
        data.results.forEach((res, index) => {
            const posId = res.position.position_id;
            const posName = res.position.position_name;
            
            let cardId = `pos-card-${posId}`;
            let chartId = `chart-${posId}`;
            
            if ($(`#${cardId}`).length === 0) {
                // Create new card for position
                const html = `
                    <div class="card mb-5 shadow-sm border-0" id="${cardId}">
                        <div class="card-header border-0 pb-0 d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0">${posName}</h5>
                            <div class="badge bg-light text-muted border px-3 rounded-pill fw-bold">
                                <span class="material-symbols-outlined fs-6 align-middle me-1">block</span>
                                <span id="skipped-${posId}">0</span> Abstentions
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row g-4">
                                <div class="col-lg-7">
                                    <div style="height: 320px;" class="bg-light bg-opacity-50 rounded-4 p-3">
                                        <canvas id="${chartId}"></canvas>
                                    </div>
                                </div>
                                <div class="col-lg-5">
                                    <div class="list-group list-group-flush border-0" id="list-${posId}">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                if (index === 0) container.empty();
                container.append(html);
            }

            // Update Skips count
            $(`#skipped-${posId}`).text(res.position.skipped_votes || 0);

            // Update List
            const list = $(`#list-${posId}`);
            list.empty();
            
            const labels = [];
            const votes = [];
            const colors = [
                '#15803d', '#4f46e5', '#8b5cf6', '#d97706', '#dc2626', 
                '#475569', '#0891b2', '#7c3aed', '#059669', '#be185d'
            ];

            res.contestants.forEach((c, cIndex) => {
                const name = c.first_name + ' ' + c.last_name;
                const initials = c.first_name.charAt(0) + c.last_name.charAt(0);
                const profileImg = c.profile_image ? `${proot}media/uploadedprofile/${c.profile_image}` : null;
                const isUnopposed = res.contestants.length === 1;

                const avatarHtml = profileImg 
                    ? `<img src="${profileImg}" class="rounded-circle me-3 border" style="width: 42px; height: 42px; object-fit: cover;">`
                    : `<div class="stat-icon me-3 bg-light text-primary" style="width: 42px; height: 42px; font-size: 0.8rem;">${initials}</div>`;

                if (isUnopposed) {
                    labels.push(name + ' (YES)');
                    votes.push(c.votes_for);
                    labels.push(name + ' (NO)');
                    votes.push(c.votes_against);

                    list.append(`
                        <div class="mb-4">
                            <div class="d-flex align-items-center mb-3">
                                ${avatarHtml}
                                <div class="flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold text-dark">${name}</span>
                                        <span class="badge bg-indigo-subtle text-indigo extra-small px-2">UNOPPOSED</span>
                                    </div>
                                    <div class="extra-small text-muted mt-1">Ballot Intelligence #${c.contestant_ballot_number}</div>
                                </div>
                            </div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-4 text-center">
                                        <div class="premium-label mb-1" style="font-size: 0.6rem; color: #15803d;">AFFIRMATIVE</div>
                                        <div class="fw-900 text-dark fs-4">${c.votes_for}</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded-4 text-center">
                                        <div class="premium-label mb-1" style="font-size: 0.6rem; color: #dc2626;">NEGATIVE</div>
                                        <div class="fw-900 text-dark fs-4">${c.votes_against}</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `);
                } else {
                    labels.push(name);
                    votes.push(c.votes_for);
                    
                    list.append(`
                        <div class="d-flex justify-content-between align-items-center p-3 mb-2 bg-light bg-opacity-50 rounded-4">
                            <div class="d-flex align-items-center">
                                ${avatarHtml}
                                <div>
                                    <div class="fw-bold text-dark mb-1">${name}</div>
                                    <div class="extra-small text-muted">Ballot Intelligence #${c.contestant_ballot_number}</div>
                                </div>
                            </div>
                            <div class="text-end">
                                <div class="premium-label mb-0" style="font-size: 0.6rem;">VOTES</div>
                                <div class="fw-900 text-primary fs-4">${c.votes_for}</div>
                            </div>
                        </div>
                    `);
                }
            });

            // Update Chart
            if (!charts[posId]) {
                const ctx = document.getElementById(chartId).getContext('2d');
                charts[posId] = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: labels,
                        datasets: [{
                            label: 'Votes',
                            data: votes,
                            backgroundColor: colors.slice(0, labels.length),
                            borderRadius: 6,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        indexAxis: 'y',
                        plugins: { 
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: '#1e293b',
                                titleFont: { size: 13, weight: 'bold' },
                                padding: 12,
                                cornerRadius: 8
                            }
                        },
                        scales: {
                            y: { grid: { display: false }, ticks: { font: { size: 11, weight: 'bold' } } },
                            x: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 10 } } }
                        }
                    }
                });
            } else {
                charts[posId].data.labels = labels;
                charts[posId].data.datasets[0].data = votes;
                charts[posId].update();
            }
        });
    }

    function pollData() {
        $.ajax({
            url: proot + 'admin/api/reports/' + electionId,
            method: 'GET',
            success: function(data) {
                updateStats(data);
                renderResults(data);
            }
        });
    }

    $(document).ready(function() {
        // Multi-step navigation
        $('.next-step').on('click', function() {
            var currentStepId = $(this).closest('.modal-step').attr('id');
            var nextStepId = $(this).data('next');
            var $form = $(this).closest('form');
            
            // Basic validation for Step 1
            if (currentStepId === 'stop-step-1') {
                if (!$('#stop_reason_input').val()) {
                    Toast.fire({ icon: 'warning', title: 'Please provide a reason' });
                    return;
                }
            }
            
            $(this).closest('.modal-step').addClass('d-none');
            $('#' + nextStepId).removeClass('d-none');
        });

        $('.prev-step').on('click', function() {
            var prevStepId = $(this).data('prev');
            $(this).closest('.modal-step').addClass('d-none');
            $('#' + prevStepId).removeClass('d-none');
        });

        // OTP Input Logic
        $('.otp-hidden-input').on('input', function() {
            const val = $(this).val();
            const $wrapper = $(this).closest('.otp-modern-wrapper');
            const $boxes = $wrapper.find('.otp-box');
            
            $boxes.removeClass('active filled').text('');
            
            for(let i = 0; i < 6; i++) {
                if(i < val.length) {
                    $boxes.eq(i).addClass('filled').text(val[i]);
                }
                if(i === val.length) {
                    $boxes.eq(i).addClass('active');
                }
            }
        });

        // Focus hidden input when clicking on boxes
        $('.otp-box').on('click', function() {
            $(this).siblings('.otp-hidden-input').focus();
        });

        pollData();
        {% if election.status == 1 %}
            setInterval(pollData, 5000);
        {% endif %}
    });
</script>
{% endblock %}
