{% extends "admin/layout.twig" %}

{% set active_page = 'settings' %}

{% block title %}Settings • Kokuromotie Admin{% endblock %}

{% block content %}
    <div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center">
        <div>
            <h1>Administrative Intelligence</h1>
            <p>Maintain your security protocols and personal identity parameters.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <!-- Profile Update -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-header border-0 pt-4 px-4 bg-transparent">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon me-3 bg-primary-subtle text-primary rounded-circle" style="width: 42px; height: 42px;">
                            <span class="material-symbols-outlined fs-5">fingerprint</span>
                        </div>
                        <h5 class="fw-bold mb-0">Biographical Identity</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form action="{{ PROOT }}admin/settings/profile" method="POST">
                        {{ csrf_field()|raw }}
                        <div class="mb-4">
                            <label class="form-label premium-label">First Name</label>
                            <input type="text" class="form-control" name="fname" value="{{ admin.first_name }}" placeholder="Legal first name" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label premium-label">Last Name</label>
                            <input type="text" class="form-control" name="lname" value="{{ admin.last_name }}" placeholder="Legal surname" required>
                        </div>
                        <div class="mb-4">
                            <label class="form-label premium-label">Communication Email</label>
                            <input type="email" class="form-control" name="email" value="{{ admin.email }}" placeholder="Institutional email" required>
                        </div>
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm">Save Parameters</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Password & Security -->
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm mb-4 rounded-4">
                <div class="card-header border-0 pt-4 px-4 bg-transparent">
                    <div class="d-flex align-items-center">
                        <div class="stat-icon me-3 bg-accent-subtle text-accent rounded-circle" style="width: 42px; height: 42px;">
                            <span class="material-symbols-outlined fs-5">key</span>
                        </div>
                        <h5 class="fw-bold mb-0">Security Protocols</h5>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form action="{{ PROOT }}admin/settings/password" method="POST">
                        {{ csrf_field()|raw }}
                        <div class="mb-4">
                            <label class="form-label premium-label">Current Security Key</label>
                            <input type="password" class="form-control" name="old_password" placeholder="Verify current password" required>
                        </div>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label premium-label">New Key</label>
                                <input type="password" class="form-control" name="password" placeholder="Min. 8 chars" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label premium-label">Confirm New</label>
                                <input type="password" class="form-control" name="confirm" placeholder="Re-enter key" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-dark px-4 fw-bold shadow-sm">Update Protocols</button>
                    </form>
                </div>
            </div>

            <!-- 2FA Security Status -->
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between p-4 bg-light rounded-4 border-0">
                        <div class="d-flex align-items-center">
                            <div class="stat-icon me-3 {{ admin.is_2fa_enabled ? 'bg-success text-white' : 'bg-danger text-white' }} rounded-circle animate-pulse" style="width: 48px; height: 48px;">
                                <span class="material-symbols-outlined">{{ admin.is_2fa_enabled ? 'shield' : 'gpp_maybe' }}</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Multi-Factor Authentication</h6>
                                <p class="extra-small mb-0">
                                    {% if admin.is_2fa_enabled %}
                                        <span class="text-success fw-bold">Active & Shielding</span>
                                    {% else %}
                                        <span class="text-danger fw-bold">Vulnerability Detected</span>
                                    {% endif %}
                                </p>
                            </div>
                        </div>
                        <a href="{{ PROOT }}admin/setup-2fa" class="btn btn-white shadow-sm border px-4 fw-bold small">
                            Configure
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; border-color: var(--admin-primary); color: var(--admin-primary); }
</style>
{% endblock %}

