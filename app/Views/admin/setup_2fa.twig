{% extends "admin/layout.twig" %}

{% block title %}Setup 2FA • Kokuromotie Admin{% endblock %}

{% block content %}
<div class="row justify-content-center mt-5">
    <div class="col-12 col-md-8 col-xl-6">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-body p-5 text-center">
                <div class="mb-4">
                    <div class="security-shield-animated mx-auto mb-4">
                        <div class="shield-orb"></div>
                        <span class="material-symbols-outlined text-primary display-4 position-relative">shield_lock</span>
                    </div>
                </div>
                
                <h2 class="fw-bold mb-3">Cryptographic Protection</h2>
                <p class="text-muted small mb-5 px-lg-5">Secure your administrator profile by adding a secondary cryptographic layer. Synchronize your authenticator with the cluster below.</p>

                <div class="mb-5 d-inline-block p-4 bg-white border rounded-4 shadow-sm" style="border-style: dashed !important; border-width: 2px !important;">
                    <img src="{{ qrCodeUrl }}" alt="QR Code" class="img-fluid" style="width: 220px; filter: contrast(1.1);">
                </div>

                {% if errorsMsg %}
                    <div class="alert alert-danger py-2 small mb-4 border-0 bg-danger bg-opacity-10 text-danger rounded-3">
                        <span class="material-symbols-outlined fs-6 align-middle me-1">error</span> {{ errorsMsg }}
                    </div>
                {% endif %}

                <form method="POST" class="mx-auto" style="max-width: 320px;">
                    {{ csrf_field()|raw }}
                    <div class="mb-4">
                        <label class="form-label premium-label">6-Digit Verification Code</label>
                        <input type="text" name="otp_code" class="form-control form-control-lg text-center fw-bold fs-3 bg-light border-0 py-3" placeholder="000 000" maxlength="6" required style="letter-spacing: 0.5rem;">
                    </div>
                    
                    <button type="submit" name="activate2fa" class="btn btn-primary w-100 py-3 fw-bold rounded-3 shadow-sm d-flex align-items-center justify-content-center gap-2">
                        <span class="material-symbols-outlined fs-5">verified</span>
                        Activate Security Shield
                    </button>
                    
                    <div class="mt-4">
                        <a href="{{ PROOT }}admin/settings" class="text-muted small fw-bold text-decoration-none d-flex align-items-center justify-content-center gap-1 opacity-75">
                            <span class="material-symbols-outlined fs-6">cancel</span> Abort Setup
                        </a>
                    </div>
                </form>
            </div>
            <div class="card-footer bg-light bg-opacity-50 border-0 p-4 text-start">
                <h6 class="fw-bold small mb-2 text-uppercase tracking-wider d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined fs-6 text-primary">info</span>
                    Protocol Instructions
                </h6>
                <ol class="small text-muted mb-0 ps-3">
                    <li class="mb-1">Initialize Google Authenticator or Microsoft Authenticator.</li>
                    <li class="mb-1">Scan the high-contrast QR code generated above.</li>
                    <li>Synchronize the temporal 6-digit code to activate the shield.</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<style>
    .security-shield-animated {
        position: relative;
        display: inline-block;
    }
    .shield-orb {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 100px;
        height: 100px;
        background: rgba(29, 61, 55, 0.1);
        border-radius: 50%;
        animation: pulse-orb 2s infinite;
    }
    @keyframes pulse-orb {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }
</style>
{% endblock %}

