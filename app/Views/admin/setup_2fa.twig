{% extends "admin/layout.twig" %}

{% block title %}Setup 2FA • Puubu Admin{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card card-body p-5 text-center">
            <h1 class="mb-3">Secure Your Account</h1>
            <p class="text-muted mb-5">Scan the QR code below with your Google Authenticator app and enter the generated code to activate 2FA.</p>

            <div class="mb-5">
                <img src="{{ qrCodeUrl }}" alt="QR Code" class="img-fluid border p-3 rounded bg-white">
            </div>

            {% if errorsMsg %}
                <div class="alert alert-danger">{{ errorsMsg }}</div>
            {% endif %}

            <form method="POST" class="mx-auto" style="max-width: 300px;">
                <div class="mb-4">
                    <label class="form-label">Verification Code</label>
                    <input type="text" name="otp_code" class="form-control text-center fs-4" placeholder="000000" maxlength="6" required>
                </div>
                <button type="submit" name="activate2fa" class="btn btn-warning w-100">Activate 2FA</button>
            </form>
        </div>
    </div>
</div>
{% endblock %}
