{% extends "admin/layout.twig" %}

{% block title %}Cryptographic Setup • Kokuromotie Security{% endblock %}

{% block content %}
<div class="row justify-content-center mt-5 mb-5">
    <div class="col-12 col-md-10 col-xl-8">
        <div class="card border-0 shadow-lg rounded-5 overflow-hidden bg-white">
            <div class="row g-0">
                <!-- Left Side: Information & Branding -->
                <div class="col-lg-5 bg-primary p-5 d-flex flex-column justify-content-between text-white">
                    <div>
                        <div class="d-flex align-items-center mb-4">
                            <span class="material-symbols-outlined fs-1 text-accent me-3">shield_person</span>
                            <h2 class="h4 fw-bold mb-0">Security Shield</h2>
                        </div>
                        <h3 class="fw-bold mb-3">Multi-Factor Authentication</h3>
                        <p class="text-white-50 small mb-5">Protect your administrative authority by adding a secondary cryptographic verification layer to your account profile.</p>
                        
                        <div class="d-flex flex-column gap-4">
                            <div class="d-flex gap-3">
                                <div class="step-number">1</div>
                                <div>
                                    <h6 class="fw-bold mb-1">Initialize App</h6>
                                    <p class="extra-small text-white-50 mb-0">Open Google Authenticator or Authy on your mobile device.</p>
                                </div>
                            </div>
                            <div class="d-flex gap-3">
                                <div class="step-number">2</div>
                                <div>
                                    <h6 class="fw-bold mb-1">Synchronize Cluster</h6>
                                    <p class="extra-small text-white-50 mb-0">Scan the high-contrast QR code to establish a secure handshake.</p>
                                </div>
                            </div>
                            <div class="d-flex gap-3">
                                <div class="step-number">3</div>
                                <div>
                                    <h6 class="fw-bold mb-1">Activate Profile</h6>
                                    <p class="extra-small text-white-50 mb-0">Enter the generated 6-digit temporal key to finalize setup.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-5 p-3 rounded-4" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                        <p class="extra-small text-white-50 mb-0 d-flex align-items-center gap-2">
                            <span class="material-symbols-outlined fs-6 text-accent">info</span>
                            Setup once to protect your credentials globally.
                        </p>
                    </div>
                </div>

                <!-- Right Side: Interaction -->
                <div class="col-lg-7 p-5 text-center bg-light bg-opacity-10">
                    <div class="mb-5">
                        <div class="qr-container p-3 d-inline-block bg-white rounded-5 shadow-sm border animate__animated animate__fadeIn">
                            <img src="{{ qrCodeUrl }}" alt="QR Code" class="img-fluid rounded-4" style="width: 240px;">
                        </div>
                    </div>

                    <div class="mx-auto" style="max-width: 360px;">
                        {% if errorsMsg %}
                            <div class="alert alert-danger py-2 small mb-4 border-0 bg-danger bg-opacity-10 text-danger rounded-3 animate__animated animate__shakeX">
                                <span class="material-symbols-outlined fs-6 align-middle me-1">error</span> {{ errorsMsg }}
                            </div>
                        {% endif %}

                        <form method="POST">
                            {{ csrf_field()|raw }}
                            <div class="mb-4">
                                <label class="form-label premium-label text-start d-block mb-3">Verification Terminal</label>
                                <div class="otp-input-wrapper">
                                    <input type="text" name="otp_code" class="form-control form-control-lg otp-input" placeholder="000 000" maxlength="6" required autofocus autocomplete="off">
                                </div>
                            </div>
                            
                            <button type="submit" name="activate2fa" class="btn btn-primary w-100 py-3 fw-bold rounded-4 shadow-sm d-flex align-items-center justify-content-center gap-2 mb-4">
                                <span class="material-symbols-outlined fs-5">lock_open</span>
                                Activate Shield Profile
                            </button>
                            
                            <a href="{{ PROOT }}admin/settings" class="btn btn-link text-muted small fw-bold text-decoration-none d-flex align-items-center justify-content-center gap-2 opacity-75 hover-opacity-100">
                                <span class="material-symbols-outlined fs-6">arrow_back</span> Return to Settings
                            </a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .step-number {
        width: 32px;
        height: 32px;
        background: var(--admin-accent);
        color: var(--admin-primary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.875rem;
        flex-shrink: 0;
    }
    .qr-container {
        transition: all 0.3s ease;
    }
    .qr-container:hover {
        transform: scale(1.02);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
    }
    .otp-input {
        text-align: center;
        font-weight: 800;
        font-size: 2.25rem !important;
        letter-spacing: 0.5rem;
        background: #fff !important;
        border: 2px solid #eef2f7 !important;
        border-radius: 1.25rem !important;
        padding: 1.25rem !important;
        transition: all 0.3s ease !important;
    }
    .otp-input:focus {
        border-color: var(--admin-primary) !important;
        box-shadow: 0 0 0 4px rgba(29, 61, 55, 0.05) !important;
    }
    .hover-opacity-100:hover {
        opacity: 1 !important;
    }
</style>
{% endblock %}
