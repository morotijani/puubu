<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/Kokuromotie.favicon.png" type="image/x-icon" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css" />
    <title>Security Verification • Kokuromotie Admin</title>
    <style>
        .otp-input {
            letter-spacing: 0.5rem;
            font-size: 2rem !important;
            font-weight: 700;
            background-color: #f8fafc !important;
            border: 2px solid #e2e8f0 !important;
        }
        .otp-input:focus {
            border-color: var(--admin-primary) !important;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.1) !important;
        }
    </style>
</head>
<body class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center mb-5">
            <div class="mb-4">
                <span class="d-inline-flex align-items-center justify-content-center bg-indigo bg-opacity-10 text-indigo rounded-circle" style="width: 64px; height: 64px;">
                    <i class="bi bi-shield-lock-fill fs-2"></i>
                </span>
            </div>
            <h1 class="h3 fw-bold mb-2">Two-Step Verification</h1>
            <p class="text-muted small px-3">For security, please enter the 6-digit code from your authenticator app.</p>
        </div>

        {% if errorsMsg %}
            <div class="alert alert-danger py-2 small mb-4 border-0 bg-danger bg-opacity-10 text-danger text-center">
                <i class="bi bi-exclamation-circle me-1"></i> {{ errorsMsg }}
            </div>
        {% endif %}

        <form method="POST">
            {{ csrf_field()|raw }}
            <div class="mb-4">
                <label class="form-label small fw-bold text-uppercase tracking-wider text-center d-block">Authentication Code</label>
                <input type="text" name="otp_code" class="form-control form-control-lg text-center otp-input" placeholder="000000" maxlength="6" autofocus required autocomplete="one-time-code">
            </div>
            
            <button class="btn btn-indigo w-100 py-3 fw-bold shadow-sm" type="submit" name="verify2fa">
                Verify & Continue <i class="bi bi-arrow-right ms-1"></i>
            </button>
        </form>

        <div class="mt-5 text-center">
            <a href="{{ PROOT }}admin/auth/logout" class="text-muted small text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i> Back to login
            </a>
        </div>
    </div>
</body>
</html>

