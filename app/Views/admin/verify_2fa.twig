<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/logo.svg" type="image/svg+xml" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/admin-new.css?v={{ "now"|date("U") }}" />
    
    <title>Security Verification • Kokuromotie Admin</title>
</head>
<body class="auth-wrapper">
    <div class="auth-card">
        <div class="text-center">
            <div class="auth-logo-circle" style="background: rgba(220, 243, 176, 0.05); border: 1.5px solid var(--admin-accent);">
                <i class="bi bi-shield-lock-fill" style="color: var(--admin-accent) !important; font-size: 2.5rem;"></i>
            </div>
            <h1 class="auth-title" style="font-size: 1.75rem;">Verify Access</h1>
            <p class="auth-subtitle" style="margin-bottom: 2.5rem; opacity: 0.8;">Two-Step Security Check</p>
        </div>

        {% if errorsMsg %}
            <div class="alert alert-danger border-0 small text-center mb-4 py-2" role="alert" style="background: rgba(239, 68, 68, 0.1); color: #ef4444; border-radius: 1rem;">
                <i class="bi bi-exclamation-circle me-1"></i> {{ errorsMsg }}
            </div>
        {% endif %}

        <form method="POST">
            {{ csrf_field()|raw }}
            <div class="mb-4">
                <input type="text" name="otp_code" class="form-control text-center" placeholder="000000" maxlength="6" autofocus required autocomplete="one-time-code" style="letter-spacing: 0.6rem; font-size: 2.5rem; height: 5rem; background: rgba(0,0,0,0.3) !important; color: var(--admin-accent) !important; border: 1px solid rgba(220, 243, 176, 0.15) !important; border-radius: 1.25rem !important; padding-left: 0.6rem; width: 100%; max-width: 320px; margin: 0 auto;">
                <p class="text-center mt-3" style="color: rgba(220, 243, 176, 0.3); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; font-weight: 600;">Enter 6-Digit Code</p>
            </div>
            
            <button class="btn btn-primary w-100 auth-btn shadow-lg" type="submit" name="verify2fa">
                Confirm Identity <i class="bi bi-patch-check-fill ms-2"></i>
            </button>
        </form>
        <br>
        <div class="mt-4 text-center">
            <a href="{{ PROOT }}admin/auth/logout" class="small text-decoration-none d-inline-flex align-items-center" style="color: rgba(220, 243, 176, 0.5); padding-top: 1rem;">
                <i class="bi bi-arrow-left me-2"></i> Return to login
            </a>
        </div>
    </div>

    <style>
        .hover-primary:hover { color: var(--admin-primary) !important; }
        .extra-small { font-size: 0.75rem; }
    </style>
</body>
</html>

