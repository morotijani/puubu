{% extends "admin/layout.twig" %}

{% set active_page = 'voters' %}

{% block title %}Duplicated Voters • Puubu Admin{% endblock %}

{% block content %}
    <div class="row align-items-center mb-7">
        <div class="col">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin">Admin</a></li>
                    <li class="breadcrumb-item"><a class="text-body-secondary" href="{{ PROOT }}admin/voters">Voters</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Duplicates</li>
                </ol>
            </nav>
            <h1 class="fs-4 mb-0">Duplicated Emails</h1>
        </div>
    </div>

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle me-2"></i> The following voters share the same email address. Please review and resolve potential duplicates.
    </div>

    <div class="card mb-6">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th class="fs-sm">Voter</th>
                        <th class="fs-sm">Identity #</th>
                        <th class="fs-sm">Election</th>
                        <th class="fs-sm text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for voter in voters %}
                        <tr class="table-warning">
                            <td>
                                <div class="fw-bold text-heading">{{ voter.std_fname }} {{ voter.std_lname }}</div>
                                <div class="fs-sm text-muted">{{ voter.std_email }}</div>
                            </td>
                            <td><code class="text-primary">{{ voter.std_id }}</code></td>
                            <td>{{ voter.election_name }}</td>
                            <td class="text-end">
                                <a href="{{ PROOT }}admin/voters/edit/{{ voter.voter_id }}" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a href="{{ PROOT }}admin/voters/delete/{{ voter.voter_id }}" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Delete this voter?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-5 text-success">
                                <i class="bi bi-check-circle fs-1 mb-3"></i><br>
                                No duplicated emails found!
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
