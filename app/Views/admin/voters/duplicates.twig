{% extends "admin/layout.twig" %}

{% set active_page = 'voters' %}

{% block title %}Identify Duplicates • Puubu Admin{% endblock %}

{% block content %}
    <div class="mb-5">
        <div class="d-flex align-items-center mb-2">
            <a href="{{ PROOT }}admin/voters" class="btn btn-sm btn-white border rounded-circle me-3 shadow-sm">
                <span class="material-symbols-outlined fs-6 pt-1">arrow_back</span>
            </a>
            <h1 class="h3 fw-bold mb-0">Duplication Audit</h1>
        </div>
        <p class="text-muted small ps-5">Review voters sharing identical email addresses across the registry.</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-4 px-4">
                    <form action="{{ PROOT }}admin/voters/duplicates" method="GET" class="row g-2 align-items-center">
                        <div class="col-md-8">
                            <select class="form-select border-0 bg-light shadow-none fw-bold" name="election_uuid">
                                <option value="">All Elections</option>
                                {% for election in elections %}
                                    <option value="{{ election.uuid }}" {{ selected_election == election.uuid ? 'selected' : '' }}>
                                        {{ election.title }}
                                    </option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-4 text-end">
                            <button type="submit" class="btn btn-dark w-100 fw-bold">Filter Registry</button>
                        </div>
                    </form>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 text-uppercase extra-small fw-bold opacity-50">Voter Details</th>
                                <th class="text-uppercase extra-small fw-bold opacity-50">Identity #</th>
                                <th class="text-uppercase extra-small fw-bold opacity-50">Election</th>
                                <th class="pe-4 text-end text-uppercase extra-small fw-bold opacity-50">Manage</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for voter in voters %}
                            <tr class="hover-shadow-sm transition-all border-bottom border-warning border-opacity-10" style="background: rgba(255, 193, 7, 0.02);">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-3 bg-warning-subtle text-warning fw-bold rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; font-size: 10px;">
                                            {{ voter.first_name|slice(0, 1) }}{{ voter.last_name|slice(0, 1) }}
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-0">{{ voter.first_name }} {{ voter.last_name }}</div>
                                            <div class="text-muted extra-small">{{ voter.email }}</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-primary border fw-mono px-2">{{ voter.voter_id }}</span>
                                </td>
                                <td>
                                    <span class="extra-small fw-bold text-muted">{{ voter.title }}</span>
                                </td>
                                <td class="pe-4 text-end">
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="{{ PROOT }}admin/voters/edit/{{ voter.uuid }}" class="btn btn-sm btn-white border rounded-3 shadow-sm px-2">
                                            <span class="material-symbols-outlined fs-6 pt-1">edit</span>
                                        </a>
                                        <a href="{{ PROOT }}admin/voters/delete/{{ voter.uuid }}" class="btn btn-sm btn-white border border-danger-subtle text-danger rounded-3 shadow-sm px-2" onclick="return confirm('Permanently delete this duplicate?')">
                                            <span class="material-symbols-outlined fs-6 pt-1">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center py-5">
                                        <div class="mb-3">
                                            <span class="material-symbols-outlined fs-1 text-success opacity-25">check_circle</span>
                                        </div>
                                        <h5 class="fw-bold text-dark">Registry is Clean</h5>
                                        <p class="text-muted small mb-0">No duplicated email addresses found in the current selection.</p>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm bg-warning-subtle rounded-4 border-start border-warning border-4">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-warning mb-3 d-flex align-items-center">
                        <span class="material-symbols-outlined me-2 fs-5">report_problem</span>
                        Audit Information
                    </h6>
                    <p class="extra-small text-dark opacity-75 mb-4">The system identifies duplicates by scanning the email address field. Voters listed here share an identical email, which may lead to authentication issues or multiple votes.</p>
                    
                    <div class="bg-white bg-opacity-50 rounded-4 p-3 mb-3 border border-warning border-opacity-10">
                        <h6 class="extra-small fw-bold text-uppercase mb-1">Total Duplicates</h6>
                        <h3 class="fw-bold text-dark mb-0">{{ voters|length }}</h3>
                    </div>

                    <p class="extra-small text-muted mb-0 italic">"Integrity is the bedrock of electoral trust."</p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.7rem; }
    .fw-mono { font-family: 'JetBrains Mono', monospace; }
    .transition-all { transition: all 0.2s ease; }
    .italic { font-style: italic; }
</style>
{% endblock %}
