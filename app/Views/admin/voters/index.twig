{% extends "admin/layout.twig" %}

{% set active_page = 'voters' %}

{% block title %}Voters Registrar • Kokuromotie{% endblock %}

{% block content %}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5">
        <div>
            <h1 class="h3 fw-bold mb-1">Voters Registrar</h1>
            <p class="text-muted small mb-0">Maintain the identity database for electoral eligibility.</p>
        </div>
        <div class="d-flex gap-2 mt-3 mt-md-0">
            <div class="dropdown">
                <button class="btn btn-light dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                    <span class="material-symbols-outlined me-1 fs-6">construction</span> Registry Tools
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 py-2">
                    <li><a class="dropdown-item py-2 d-flex align-items-center" href="#" data-bs-toggle="modal" data-bs-target="#duplicateAuditModal"><span class="material-symbols-outlined me-2 text-muted fs-6">layers</span> Identify Duplicates</a></li>
                    <li><a class="dropdown-item py-2 d-flex align-items-center" href="{{ PROOT }}admin/voters/import"><span class="material-symbols-outlined me-2 text-muted fs-6">upload_file</span> Import Identities (CSV)</a></li>
                    <li><hr class="dropdown-divider mx-3"></li>
                    <li><a class="dropdown-item py-2 text-danger d-flex align-items-center" href="#" data-bs-toggle="modal" data-bs-target="#wipeRegistryModal"><span class="material-symbols-outlined me-2 fs-6">warning</span> Wipe Registry</a></li>
                </ul>
            </div>
            <a href="{{ PROOT }}admin/voters/add" class="btn btn-indigo shadow-sm d-flex align-items-center">
                <span class="material-symbols-outlined me-1 fs-6">person_add</span> Register Voter
            </a>
        </div>
    </div>

    <!-- Voters Registry -->
    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white border-bottom pt-4 px-4 pb-3">
            <div class="row align-items-center g-3">
                <div class="col-md-auto">
                    <h5 class="fw-bold mb-0">Identity Registry</h5>
                </div>
                <div class="col-md-4 ms-md-auto">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-0"><span class="material-symbols-outlined fs-6 text-muted">search</span></span>
                        <input type="text" id="voterSearch" class="form-control bg-light border-0" placeholder="Search names, IDs, emails...">
                    </div>
                </div>
            </div>
        </div>
        
        <form action="{{ PROOT }}admin/voters/bulk-delete" method="POST" id="bulkDeleteForm">
            {{ csrf_field()|raw }}
            <div class="table-responsive">
                <table class="table align-middle" id="votersTable">
                    <thead>
                        <tr>
                            <th style="width: 50px;" class="ps-4">
                                <input type="checkbox" class="form-check-input" id="selectAll">
                            </th>
                            <th>Identity & Contact</th>
                            <th>Registry ID</th>
                            <th>Target Election</th>
                            <th class="text-end pe-4">Management</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for voter in voters %}
                            <tr>
                                <td class="ps-4">
                                    <input type="checkbox" name="voter_ids[]" value="{{ voter.uuid }}" class="form-check-input voter-checkbox">
                                </td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="avatar avatar-sm me-3 d-flex align-items-center justify-content-center text-indigo fw-bold bg-indigo-subtle rounded-circle" style="width: 38px; height: 38px;">
                                            {{ voter.first_name|slice(0, 1) }}{{ voter.last_name|slice(0, 1) }}
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">{{ voter.first_name }} {{ voter.last_name }}</div>
                                            <div class="d-flex align-items-center flex-wrap">
                                                {% if voter.email %}
                                                    <div class="text-muted extra-small me-2 d-flex align-items-center">
                                                        <span class="material-symbols-outlined fs-6 me-1">alternate_email</span> {{ voter.email }}
                                                    </div>
                                                {% endif %}
                                                {% if voter.phone %}
                                                    <div class="text-muted extra-small me-2 d-flex align-items-center">
                                                        <span class="material-symbols-outlined fs-6 me-1">phone</span> {{ voter.phone }}
                                                    </div>
                                                {% endif %}
                                                <span class="badge {{ voter.gender == 'male' ? 'bg-primary-subtle text-primary' : 'bg-danger-subtle text-danger' }} extra-small px-2 py-0">
                                                    <span class="material-symbols-outlined" style="font-size: 10px;">{{ voter.gender }}</span>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-primary fw-mono border">{{ voter.voter_id }}</span>
                                </td>
                                <td class="text-muted small">
                                    <span class="material-symbols-outlined me-1 fs-6 align-middle">inventory_2</span> {{ voter.title }}
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        {% if voter.election_status == 0 %}
                                            {% if voter.allow_direct_link %}
                                                <button type="button" class="btn btn-sm btn-white border text-indigo rounded-3 shadow-sm d-flex align-items-center btn-copy-link" data-token="{{ voter.voting_token }}" title="Copy Direct Voting Link">
                                                    <span class="material-symbols-outlined fs-6">link</span>
                                                </button>
                                            {% endif %}
                                            <a href="{{ PROOT }}admin/voters/edit/{{ voter.uuid }}" class="btn btn-sm btn-white border rounded-3 shadow-sm d-flex align-items-center">
                                                <span class="material-symbols-outlined fs-6">edit</span>
                                            </a>
                                            <a href="{{ PROOT }}admin/voters/delete/{{ voter.uuid }}" class="btn btn-sm btn-white border text-danger rounded-3 shadow-sm d-flex align-items-center" onclick="return confirm('Delete this voter?')">
                                                <span class="material-symbols-outlined fs-6">delete</span>
                                            </a>
                                        {% else %}
                                            <span class="badge bg-light text-muted border px-3 rounded-pill">Session Locked</span>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <div class="mb-2"><span class="material-symbols-outlined fs-1 opacity-25">group</span></div>
                                    No identities found in the registrar.
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <!-- Bulk Actions Footer -->
            <div class="card-footer bg-light bg-opacity-50 border-top-0 py-3 px-4" id="bulkActions" style="display: none;">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <span class="badge bg-indigo rounded-pill me-2" id="selectedCount">0</span>
                        <span class="small text-muted fw-medium">Identities selected for action</span>
                    </div>
                    <button type="submit" class="btn btn-sm btn-danger px-4 fw-bold shadow-sm d-flex align-items-center" onclick="return confirm('Delete selected identities from the registry?')">
                        Delete Selected <span class="material-symbols-outlined ms-1 fs-6">delete</span>
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Duplicate Audit Modal -->
    <div class="modal fade" id="duplicateAuditModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0">Identify Duplicates</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <p class="text-muted small">Select the scope of the duplication audit.</p>
                    <form action="{{ PROOT }}admin/voters/duplicates" method="GET">
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase">Target Election</label>
                            <select class="form-select bg-light border-0 shadow-none" name="election_uuid">
                                <option value="">Audit All Elections</option>
                                {% for election in elections %}
                                    <option value="{{ election.uuid }}">{{ election.title }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn btn-dark w-100 fw-bold py-2 shadow-sm">Start Audit</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Wipe Registry Modal -->
    <div class="modal fade" id="wipeRegistryModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pt-4 px-4">
                    <h5 class="fw-bold mb-0 text-danger">Wipe Registry</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="alert alert-danger border-0 rounded-4 mb-4">
                        <div class="d-flex">
                            <span class="material-symbols-outlined me-2">report</span>
                            <div class="small fw-bold">This action is irreversible. All selected voter records and their login credentials will be permanently erased.</div>
                        </div>
                    </div>

                    <form action="{{ PROOT }}admin/voters/truncate" method="POST">
                        {{ csrf_field()|raw }}
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-uppercase">Wipe Scope</label>
                            <div class="d-flex flex-column gap-2">
                                <div class="form-check p-3 bg-light rounded-3 border-0">
                                    <input class="form-check-input ms-0 me-3" type="radio" name="wipe_scope" id="wipeElection" value="election" checked onchange="toggleWipeElection(true)">
                                    <label class="form-check-label fw-bold small text-dark" for="wipeElection">Specific Election</label>
                                </div>
                                <div class="form-check p-3 bg-light rounded-3 border-0">
                                    <input class="form-check-input ms-0 me-3" type="radio" name="wipe_scope" id="wipeAll" value="all" onchange="toggleWipeElection(false)">
                                    <label class="form-check-label fw-bold small text-danger" for="wipeAll">Entire Registry (Global Wipe)</label>
                                </div>
                            </div>
                        </div>

                        <div id="wipeElectionSelect" class="mb-4">
                            <label class="form-label small fw-bold text-uppercase">Select Election</label>
                            <select class="form-select bg-light border-0 shadow-none" name="election_uuid">
                                <option value="">Select Election...</option>
                                {% for election in elections %}
                                    <option value="{{ election.uuid }}">{{ election.title }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-danger w-100 fw-bold py-2 shadow-sm" onclick="return confirm('FINAL WARNING: Proceed with wiping data?')">
                                Confirm Wipe
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
<style>
    .extra-small { font-size: 0.75rem; }
    .fw-mono { font-family: 'JetBrains Mono', 'Fira Code', monospace; }
    .btn-white { background: #fff; }
    .btn-white:hover { background: #f8fafc; color: var(--admin-primary); }
</style>
{% endblock %}

{% block scripts %}
<script>
    function toggleWipeElection(show) {
        const select = document.getElementById('wipeElectionSelect');
        if (select) select.style.display = show ? 'block' : 'none';
    }

    $(document).ready(function() {
        // Search Functionality
        $("#voterSearch").on("keyup", function() {
            var value = $(this).val().toLowerCase();
            $("#votersTable tbody tr").filter(function() {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

        // Bulk Selection
        $('#selectAll').on('change', function() {
            $('.voter-checkbox').prop('checked', $(this).prop('checked'));
            updateBulkStatus();
        });

        $(document).on('change', '.voter-checkbox', function() {
            updateBulkStatus();
        });

        function updateBulkStatus() {
            var count = $('.voter-checkbox:checked').length;
            $('#selectedCount').text(count);
            if (count > 0) {
                $('#bulkActions').slideDown(200);
            } else {
                $('#bulkActions').slideUp(200);
            }
        }

        // Copy Link Functionality
        $('.btn-copy-link').on('click', function() {
            const token = $(this).data('token');
            const url = window.location.origin + '{{ PROOT }}v/' + token;
            
            const tempInput = document.createElement('input');
            tempInput.value = url;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand('copy');
            document.body.removeChild(tempInput);
            
            const btn = $(this);
            const originalIcon = btn.find('.material-symbols-outlined').text();
            btn.find('.material-symbols-outlined').text('check');
            btn.addClass('text-success').removeClass('text-indigo');
            
            setTimeout(() => {
                btn.find('.material-symbols-outlined').text(originalIcon);
                btn.removeClass('text-success').addClass('text-indigo');
            }, 2000);
        });
    });
</script>
{% endblock %}

