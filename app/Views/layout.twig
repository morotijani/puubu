<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="shortcut icon" href="{{ PROOT }}media/favicon.ico" type="image/x-icon" />
    
    <!-- Primary Meta Tags -->
    <meta name="title" content="Kokuromotie - Professional Digital Electoral System" />
    <meta name="description" content="Kokuromotie is a state-of-the-art digital voting platform designed for transparency, security, and ease of use in modern elections." />
    <meta name="keywords" content="e-voting, digital election, secure voting, electoral system, kokuromotie, online ballot" />
    <meta name="author" content="Kokuromotie Team" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://kokuromotie.com/" />
    <meta property="og:title" content="Kokuromotie - Professional Digital Electoral System" />
    <meta property="og:description" content="Secure, transparent, and user-friendly digital voting for modern democratic processes." />
    <meta property="og:image" content="{{ PROOT }}media/logo.svg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content="Kokuromotie - Professional Digital Electoral System" />
    <meta property="twitter:description" content="Secure, transparent, and user-friendly digital voting for modern democratic processes." />
    <meta property="twitter:image" content="{{ PROOT }}media/logo.svg" />
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- CSS Libs -->
    <link rel="stylesheet" href="{{ PROOT }}dist/css/libs.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/index.bundle.css" />
    <link rel="stylesheet" href="{{ PROOT }}dist/css/Kokuromotie.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <title>{% block title %}Kokuromotie{% endblock %}</title>
    {% block styles %}{% endblock %}
</head>
<body>
    {% block content %}{% endblock %}

    <!-- javascript -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script type="text/javascript" src="{{ PROOT }}dist/js/vendor.bundle.js"></script>
    <script type="text/javascript" src="{{ PROOT }}dist/js/index.bundle.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>

