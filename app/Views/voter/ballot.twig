{% extends "layout.twig" %}

{% block title %}{{ voter.first_name }} {{ voter.last_name }}, Start Vote • Kokuromotie{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-accent: #dcf3b0;
        --dark-accent: #1d3d37;
        --light-bg: #fdfcf5;
        --card-bg: #ffffff;
        --border-color: rgba(29, 61, 55, 0.08);
        --success-color: #22c55e;
        --danger-color: #ef4444;
    }

    body {
        background: var(--light-bg);
        color: var(--dark-accent);
        font-family: 'Outfit', sans-serif;
        overflow-x: hidden;
    }

    /* Stepper Header */
    .ballot-header {
        background: rgba(253, 252, 245, 0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-color);
        padding: 20px 0;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .progress-wrapper {
        max-width: 800px;
        margin: 0 auto;
    }

    .progress-container {
        height: 6px;
        background: rgba(29, 61, 55, 0.05);
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 15px;
    }

    .progress-bar {
        height: 100%;
        background: var(--dark-accent);
        width: 0%;
        transition: width 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .step-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #718783;
    }

    /* Ballot Content */
    .ballot-wizard {
        padding: 60px 0 120px;
        min-height: 70vh;
    }

    .vote-step {
        display: none;
        animation: slideUp 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .vote-step.active {
        display: block;
    }

    @keyframes slideUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .position-title {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        font-weight: 800;
        letter-spacing: -1px;
        margin-bottom: 8px;
        text-align: center;
    }

    .position-desc {
        text-align: center;
        color: #718783;
        margin-bottom: 48px;
        font-size: 1.1rem;
    }

    /* Candidate Cards */
    .candidate-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
    }

    .candidate-card {
        background: var(--card-bg);
        border: 2px solid var(--border-color);
        border-radius: 32px;
        padding: 40px;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .candidate-card:hover {
        transform: translateY(-8px);
        border-color: #cbd5e1;
        box-shadow: 0 20px 40px -10px rgba(29, 61, 55, 0.1);
    }

    .candidate-card.selected {
        background: #f0fdf4;
        border-color: var(--success-color);
        box-shadow: 0 25px 50px -12px rgba(34, 197, 94, 0.15);
    }

    .candidate-card.selected::after {
        content: '\e876';
        font-family: 'Material Symbols Outlined';
        position: absolute;
        top: 20px;
        right: 20px;
        width: 32px;
        height: 32px;
        background: var(--success-color);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    @keyframes popIn {
        0% { transform: scale(0); }
        100% { transform: scale(1); }
    }

    .candidate-avatar {
        width: 140px;
        height: 140px;
        border-radius: 40px;
        margin-bottom: 24px;
        overflow: hidden;
        background: #f1f5f9;
        border: 4px solid white;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .candidate-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .candidate-initials {
        font-size: 2.5rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
    }

    .candidate-name {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: 4px;
        color: var(--dark-accent);
    }

    .candidate-tag {
        font-size: 0.85rem;
        font-weight: 700;
        color: #94a3b8;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    /* Unopposed Styles */
    .unopposed-container {
        max-width: 600px;
        margin: 0 auto;
        background: white;
        padding: 40px;
        border-radius: 40px;
        border: 1px solid var(--border-color);
        text-align: center;
    }

    .unopposed-options {
        display: flex;
        gap: 20px;
        margin-top: 32px;
    }

    .unopposed-btn {
        flex: 1;
        padding: 24px;
        border-radius: 24px;
        border: 2px solid #f1f5f9;
        background: #f8fafc;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .unopposed-btn .icon { font-size: 2rem; }
    .unopposed-btn.yes:hover, .unopposed-btn.yes.active { background: #f0fdf4; border-color: var(--success-color); color: var(--success-color); }
    .unopposed-btn.no:hover, .unopposed-btn.no.active { background: #fef2f2; border-color: var(--danger-color); color: var(--danger-color); }

    /* Controls Bar */
    .ballot-controls {
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        background: rgba(253, 252, 245, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-top: 1px solid var(--border-color);
        padding: 24px 0;
        z-index: 1000;
    }

    .controls-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
    }

    .btn-nav {
        padding: 16px 32px;
        border-radius: 100px;
        font-weight: 800;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: all 0.3s ease;
        border: none;
    }

    .btn-prev { background: #f1f5f9; color: #475569; }
    .btn-prev:hover { background: #e2e8f0; }

    .btn-next { background: var(--dark-accent); color: white; }
    .btn-next:hover { background: #132e29; transform: translateX(4px); }
    .btn-next:disabled { opacity: 0.3; cursor: not-allowed; transform: none; }

    .btn-submit { background: var(--success-color); color: white; padding: 16px 48px; position: relative; overflow: hidden; }
    .btn-submit:hover { background: #16a34a; box-shadow: 0 10px 20px rgba(34, 197, 94, 0.3); }
    .btn-submit:disabled { opacity: 0.7; cursor: wait; }

    .btn-submit .spinner-border {
        width: 1.2rem;
        height: 1.2rem;
        display: none;
        border: 2px solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spinner-rotate .75s linear infinite;
    }
    @keyframes spinner-rotate {
        to { transform: rotate(360deg); }
    }
    .btn-submit.loading .spinner-border { display: inline-block; }
    .btn-submit.loading .material-symbols-outlined { display: none; }
    .btn-submit.loading .btn-text { display: none; }
    .btn-submit.loading .loading-text { display: inline-block; }
    .btn-submit .loading-text { display: none; }

    /* Review Step */
    .review-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    .review-item {
        background: white;
        padding: 20px;
        border-radius: 24px;
        border: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .review-avatar { width: 50px; height: 50px; border-radius: 12px; object-fit: cover; }
</style>
{% endblock %}

{% block content %}
    <header class="ballot-header">
        <div class="container">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center">
                    <span class="material-symbols-outlined text-dark me-2">how_to_vote</span>
                    <span class="fw-bold h5 mb-0">Cast Ballot</span>
                </div>
                <div class="countdown-timer text-danger fw-bold small d-flex align-items-center" id="countDT">
                    <span class="material-symbols-outlined fs-6 me-1">schedule</span> Initializing...
                </div>
            </div>
            
            <div class="progress-wrapper">
                <div class="progress-container">
                    <div class="progress-bar" id="ballotProgress"></div>
                </div>
                <div class="step-labels">
                    <span id="currentStepLabel">Selection</span>
                    <span id="stepCounter">1 / {{ ballot|length + 1 }}</span>
                </div>
            </div>
        </div>
    </header>

    <main class="ballot-wizard">
        <div class="container">
            <form action="{{ PROOT }}submitvote" method="POST" id="voteForm">
                {{ csrf_field()|raw }}
                <input type="hidden" name="number-of-positions" value="{{ ballot|length }}">
                <input type="hidden" name="name-of-election" value="{{ electionUuid }}">

                {% for item in ballot %}
                    <div class="vote-step" id="step-{{ loop.index0 }}" data-position="{{ item.position.position_name }}">
                        <input type="hidden" name="name-of-positions{{ loop.index0 }}" value="{{ item.position.position_id }}">
                        
                        <h2 class="position-title">{{ item.position.position_name }}</h2>
                        <p class="position-desc">Select your preferred candidate for this office.</p>

                        {% if item.count < 1 %}
                            <div class="text-center py-5">
                                <span class="material-symbols-outlined display-1 opacity-10">person_off</span>
                                <p class="mt-3 fw-bold text-muted">No contestants registered.</p>
                            </div>
                            <input type="hidden" name="contestant{{ loop.index0 }}" value="">
                            <input type="hidden" name="onecont{{ loop.index0 }}" value="">
                        {% else %}
                            {% if item.count > 1 %}
                                <div class="candidate-grid">
                                    {% for contestant in item.contestants %}
                                        <div class="candidate-card" onclick="selectCandidate({{ loop.parent.loop.index0 }}, '{{ contestant.uuid }}', '{{ contestant.first_name }} {{ contestant.last_name }}', '{{ contestant.profile_image }}')">
                                            <input type="radio" name="contestant{{ loop.parent.loop.index0 }}" value="{{ contestant.uuid }}" class="visually-hidden">
                                            <div class="candidate-avatar">
                                                {% if contestant.profile_image %}
                                                    <img src="{{ PROOT }}media/uploadedprofile/{{ contestant.profile_image }}" alt="Profile">
                                                {% else %}
                                                    <span class="candidate-initials">{{ contestant.first_name|first }}{{ contestant.last_name|first }}</span>
                                                {% endif %}
                                            </div>
                                            <div class="candidate-name">{{ contestant.first_name }} {{ contestant.last_name }}</div>
                                            <div class="candidate-tag">Ballot #{{ contestant.contestant_ballot_number }}</div>
                                        </div>
                                    {% endfor %}
                                    
                                    <!-- Skip Option -->
                                    <div class="candidate-card skip-card" onclick="selectCandidate({{ loop.index0 }}, 'skip', 'Skipped', '')">
                                        <input type="radio" name="contestant{{ loop.index0 }}" value="" class="visually-hidden">
                                        <div class="candidate-avatar d-flex align-items-center justify-content-center bg-light">
                                            <span class="material-symbols-outlined fs-1 text-muted">block</span>
                                        </div>
                                        <div class="candidate-name">Abstain</div>
                                        <div class="candidate-tag">Skip this position</div>
                                    </div>
                                </div>
                            {% else %}
                                <!-- Unopposed -->
                                {% set contestant = item.contestants|first %}
                                <div class="unopposed-container">
                                    <div class="candidate-avatar mx-auto" style="width: 180px; height: 180px;">
                                        {% if contestant.profile_image %}
                                            <img src="{{ PROOT }}media/uploadedprofile/{{ contestant.profile_image }}" alt="Profile">
                                        {% else %}
                                            <span class="candidate-initials" style="font-size: 3.5rem;">{{ contestant.first_name|first }}{{ contestant.last_name|first }}</span>
                                        {% endif %}
                                    </div>
                                    <h3 class="candidate-name mt-3">{{ contestant.first_name }} {{ contestant.last_name }}</h3>
                                    <p class="text-muted">Do you approve this candidate for the office of <br><strong>{{ item.position.position_name }}</strong>?</p>
                                    
                                    <div class="unopposed-options">
                                        <div class="unopposed-btn yes" onclick="selectUnopposed({{ loop.index0 }}, 'yes', '{{ contestant.uuid }}', '{{ contestant.first_name }} {{ contestant.last_name }}', '{{ contestant.profile_image }}')">
                                            <span class="material-symbols-outlined icon">thumb_up</span>
                                            <span class="fw-bold">Yes, I Approve</span>
                                        </div>
                                        <div class="unopposed-btn no" onclick="selectUnopposed({{ loop.index0 }}, 'no', '{{ contestant.uuid }}', '{{ contestant.first_name }} {{ contestant.last_name }}', '{{ contestant.profile_image }}')">
                                            <span class="material-symbols-outlined icon">thumb_down</span>
                                            <span class="fw-bold">No, I Reject</span>
                                        </div>
                                        <input type="radio" name="onecont{{ loop.index0 }}" id="onecont_yes_{{ loop.index0 }}" value="yes,{{ contestant.uuid }}" class="visually-hidden">
                                        <input type="radio" name="onecont{{ loop.index0 }}" id="onecont_no_{{ loop.index0 }}" value="no,{{ contestant.uuid }}" class="visually-hidden">
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endfor %}

                <!-- Summary Step -->
                <div class="vote-step" id="step-summary">
                    <h2 class="position-title">Review Your Ballot</h2>
                    <p class="position-desc">Please verify your selections before final submission.</p>
                    
                    <div class="review-grid" id="reviewContainer">
                        <!-- Populated by JS -->
                    </div>

                    <div class="text-center mt-5 p-4 bg-white rounded-4 border border-warning border-opacity-25">
                        <div class="d-flex align-items-center justify-content-center text-warning mb-2">
                            <span class="material-symbols-outlined me-2">lock</span>
                            <span class="fw-bold small text-uppercase">Final Confirmation</span>
                        </div>
                        <p class="small text-muted mb-0">By clicking "Confirm & Cast Vote", your choices will be permanently recorded and encrypted.</p>
                    </div>
                </div>
            </form>
        </div>
    </main>

    <footer class="ballot-controls">
        <div class="controls-container">
            <button type="button" class="btn-nav btn-prev" id="prevBtn" onclick="moveStep(-1)">
                <span class="material-symbols-outlined">arrow_back</span> Back
            </button>
            
            <div class="d-flex gap-3">
                <button type="button" class="btn-nav btn-next" id="nextBtn" onclick="moveStep(1)">
                    Continue <span class="material-symbols-outlined">arrow_forward</span>
                </button>
                <button type="submit" form="voteForm" name="submitVotes" class="btn-nav btn-submit d-none" id="submitBtn">
                    <span class="btn-text">Confirm & Cast Vote</span>
                    <span class="loading-text">Encrypting & Casting...</span>
                    <div class="spinner-border spinner-border-sm ms-2" role="status" aria-hidden="true"></div>
                    <span class="material-symbols-outlined">how_to_vote</span>
                </button>
            </div>
        </div>
    </footer>
{% endblock %}

{% block scripts %}
<script>
    let currentStep = 0;
    const totalPositions = {{ ballot|length }};
    const selections = {};

    function moveStep(n) {
        const steps = document.querySelectorAll('.vote-step');
        
        // Hide current
        steps[currentStep].classList.remove('active');
        
        currentStep += n;
        
        if (currentStep >= steps.length) {
            // Should not happen as submit button handles final
            return false;
        }

        // Show next
        steps[currentStep].classList.add('active');
        
        updateUI();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function updateUI() {
        // Progress bar
        const progress = (currentStep / totalPositions) * 100;
        document.getElementById('ballotProgress').style.width = progress + '%';
        
        // Labels
        const steps = document.querySelectorAll('.vote-step');
        const currentLabel = steps[currentStep].dataset.position || 'Final Review';
        document.getElementById('currentStepLabel').innerText = currentLabel;
        document.getElementById('stepCounter').innerText = (currentStep + 1) + ' / ' + steps.length;

        // Buttons
        document.getElementById('prevBtn').classList.toggle('d-none', currentStep === 0);
        
        if (currentStep === totalPositions) {
            document.getElementById('nextBtn').classList.add('d-none');
            document.getElementById('submitBtn').classList.remove('d-none');
            renderSummary();
        } else {
            document.getElementById('nextBtn').classList.remove('d-none');
            document.getElementById('submitBtn').classList.add('d-none');
            
            // Disable next if no selection made (optional: depending on business logic)
            // checkSelection();
        }
    }

    function selectCandidate(stepIdx, contId, name, photo) {
        const step = document.getElementById('step-' + stepIdx);
        const radios = step.querySelectorAll('input[type="radio"]');
        const cards = step.querySelectorAll('.candidate-card');
        
        cards.forEach(c => c.classList.remove('selected'));
        
        radios.forEach(r => {
            if (r.value === contId || (contId === 'skip' && r.value === '')) {
                r.checked = true;
                const card = r.closest('.candidate-card');
                if (card) card.classList.add('selected');
            }
        });

        selections[stepIdx] = { name, photo, position: step.dataset.position };
        
        // Auto-advance after delay?
        // setTimeout(() => moveStep(1), 500);
    }

    function selectUnopposed(stepIdx, choice, contId, name, photo) {
        const step = document.getElementById('step-' + stepIdx);
        const btns = step.querySelectorAll('.unopposed-btn');
        const radioYes = document.getElementById('onecont_yes_' + stepIdx);
        const radioNo = document.getElementById('onecont_no_' + stepIdx);

        btns.forEach(b => b.classList.remove('active'));
        
        if (choice === 'yes') {
            radioYes.checked = true;
            step.querySelector('.unopposed-btn.yes').classList.add('active');
            selections[stepIdx] = { name: name + ' (Approved)', photo, position: step.dataset.position };
        } else {
            radioNo.checked = true;
            step.querySelector('.unopposed-btn.no').classList.add('active');
            selections[stepIdx] = { name: name + ' (Rejected)', photo, position: step.dataset.position };
        }
    }

    function renderSummary() {
        const container = document.getElementById('reviewContainer');
        container.innerHTML = '';
        
        for (let i = 0; i < totalPositions; i++) {
            const sel = selections[i] || { name: 'Skipped', photo: '', position: document.getElementById('step-' + i).dataset.position };
            const imgHtml = sel.photo 
                ? `<img src="{{ PROOT }}media/uploadedprofile/${sel.photo}" class="review-avatar">`
                : `<div class="review-avatar bg-light d-flex align-items-center justify-content-center"><span class="material-symbols-outlined text-muted">person</span></div>`;

            container.innerHTML += `
                <div class="review-item" onclick="goToStep(${i})" style="cursor: pointer;">
                    ${imgHtml}
                    <div>
                        <div class="small text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">${sel.position}</div>
                        <div class="fw-bold text-dark">${sel.name}</div>
                    </div>
                    <span class="material-symbols-outlined ms-auto text-muted fs-6">edit</span>
                </div>
            `;
        }
    }

    function goToStep(idx) {
        document.querySelectorAll('.vote-step').forEach(s => s.classList.remove('active'));
        currentStep = idx;
        document.getElementById('step-' + idx).classList.add('active');
        updateUI();
    }

    $(document).ready(function() {
        // Form submission handling
        $('#voteForm').on('submit', function() {
            const $btn = $('#submitBtn');
            $btn.addClass('loading');
            $btn.prop('disabled', true);
            
            // Also disable the back button to prevent navigation during submission
            $('#prevBtn').prop('disabled', true);
            
            return true; // Continue with form submission
        });

        // Init first step
        document.getElementById('step-0').classList.add('active');
        updateUI();

        // Countdown Timer
        {% if started_election > 0 %}
            var countDownDate = {{ voter.ends_at|date('U') }} * 1000;
            var x = setInterval(function() {
                var now = Date.now();
                var distance = countDownDate - now;
                var days = Math.floor(distance / (1000 * 60 * 60 * 24));
                var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById('countDT').innerHTML = 
                    '<span class="material-symbols-outlined fs-6 me-1">schedule</span> ' + 
                    (days > 0 ? days + "d " : "") + hours + "h " + minutes + "m " + seconds + "s";

                if (distance < 0) {
                    clearInterval(x);
                    window.location = '{{ PROOT }}votingon';
                }
            }, 1000);
        {% endif %}
    });
</script>
{% endblock %}


