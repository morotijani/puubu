{% extends "layout.twig" %}

{% block title %}{{ voter.std_fname }} {{ voter.std_lname }}, Start Vote • Puubu{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-accent: #dcf3b0;
        --dark-accent: #1d3d37;
        --light-bg: #fdfcf5;
        --card-bg: #ffffff;
        --border-color: rgba(29, 61, 55, 0.08);
    }

    body {
        background: var(--light-bg);
        color: var(--dark-accent);
        font-family: 'Outfit', sans-serif;
    }

    .ballot-nav {
        background: var(--light-bg) !important;
        border-bottom: 1px solid var(--border-color);
        padding: 1rem 0;
    }

    .ballot-hero {
        background-color: var(--light-bg);
        padding: 60px 0;
        position: relative;
        border-bottom: 1px solid var(--border-color);
    }

    .ballot-hero::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background-image: radial-gradient(circle at 80% 20%, rgba(220, 243, 176, 0.2), transparent 40%),
                          radial-gradient(circle at 20% 80%, rgba(29, 61, 55, 0.02), transparent 40%);
        z-index: 0;
    }

    .hero-content {
        position: relative;
        z-index: 10;
    }

    .voter-badge {
        background: var(--primary-accent);
        color: var(--dark-accent);
        padding: 6px 16px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        box-shadow: 0 4px 12px rgba(220, 243, 176, 0.3);
    }

    .election-title {
        font-weight: 800;
        color: var(--dark-accent);
        letter-spacing: -1.5px;
        margin-bottom: 12px;
    }

    .countdown-timer {
        font-weight: 700;
        color: #ef4444;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-size: 1.25rem;
    }

    .ballot-container {
        padding: 60px 0;
    }

    .accordion-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px !important;
        margin-bottom: 24px;
        overflow: hidden;
        box-shadow: 0 10px 30px -10px rgba(29, 61, 55, 0.05);
    }

    .accordion-button {
        background: var(--card-bg) !important;
        color: var(--dark-accent) !important;
        padding: 24px 32px;
        font-weight: 700;
        font-size: 1.1rem;
        box-shadow: none !important;
    }

    .accordion-button:not(.collapsed) {
        border-bottom: 1px solid var(--border-color);
    }

    .accordion-button::after {
        filter: grayscale(1) invert(0);
    }

    .candidate-card {
        background: var(--card-bg);
        border: 2px solid var(--border-color);
        border-radius: 24px;
        padding: 24px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
    }

    .candidate-card:hover {
        transform: translateY(-4px);
        border-color: #d1d5db;
        box-shadow: 0 15px 30px -10px rgba(29, 61, 55, 0.1);
    }

    .candidate-card.selected {
        background: #f0fdf4;
        border-color: #22c55e;
        box-shadow: 0 15px 30px -10px rgba(34, 197, 94, 0.2);
    }

    .candidate-card.selected .check-badge {
        opacity: 1;
        transform: scale(1);
    }

    .check-badge {
        position: absolute;
        top: -12px;
        right: -12px;
        width: 32px;
        height: 32px;
        background: #22c55e;
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 10;
        box-shadow: 0 4px 12px rgba(34, 197, 94, 0.4);
    }

    .candidate-avatar {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
        overflow: hidden;
        border: 4px solid white;
        box-shadow: 0 8px 16px rgba(0,0,0,0.05);
    }

    .candidate-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .candidate-initials {
        font-size: 1.75rem;
        font-weight: 800;
        color: #94a3b8;
        text-transform: uppercase;
    }

    .candidate-name {
        font-weight: 700;
        color: var(--dark-accent);
        margin-bottom: 4px;
        font-size: 1.05rem;
    }

    .candidate-info {
        font-size: 0.8rem;
        color: #718783;
        font-weight: 600;
        background: #f1f5f9;
        padding: 4px 12px;
        border-radius: 100px;
        margin-bottom: 16px;
    }

    .btn-vote {
        border-radius: 100px;
        padding: 8px 24px;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .submit-ballot-bar {
        position: sticky;
        bottom: 30px;
        z-index: 100;
        display: flex;
        justify-content: center;
        margin-top: 40px;
    }

    .btn-submit-ballot {
        background: var(--dark-accent);
        color: white;
        border: none;
        padding: 20px 60px;
        border-radius: 100px;
        font-weight: 800;
        font-size: 1.25rem;
        box-shadow: 0 20px 40px -10px rgba(29, 61, 55, 0.4);
        display: flex;
        align-items: center;
        gap: 16px;
        transition: all 0.3s ease;
    }

    .btn-submit-ballot:hover {
        background: #132e29;
        transform: translateY(-4px) scale(1.02);
        box-shadow: 0 30px 60px -10px rgba(29, 61, 55, 0.5);
        color: white;
    }
</style>
{% endblock %}

{% block content %}
    <nav class="navbar navbar-expand-lg ballot-nav fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" href="{{ PROOT }}votingon">
                <span class="material-symbols-outlined text-dark me-2 fs-3">inventory_2</span>
                <span class="h4 mb-0 brand-text fw-bold">Puu<span style="color: #4ade80 !important;">Bu</span></span>
            </a>
            <div class="ms-auto">
                <a href="{{ PROOT }}auth/logout" class="btn btn-outline-danger border-opacity-25 rounded-pill px-4 fw-bold small text-decoration-none">
                    Save & Exit
                </a>
            </div>
        </div>
    </nav>

    <section class="ballot-hero mt-5">
        <div class="container hero-content text-center pt-5">
            <div class="voter-badge">
                <span class="material-symbols-outlined fs-6">person</span>
                {{ voter.std_fname }} {{ voter.std_lname }}
            </div>
            <h1 class="election-title display-5">{{ voter.title }}</h1>
            <p class="text-muted fw-500 mb-4">Election organized by <span class="text-dark fw-700">{{ voter.organized_by }}</span></p>
            
            <div id="countDT" class="countdown-timer">
                <span class="material-symbols-outlined">schedule</span>
                Initializing...
            </div>
        </div>
    </section>

    <div class="ballot-container">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <form action="{{ PROOT }}submitvote" method="POST" id="voteForm">
                        {{ csrf_field() }}
                        <input type="hidden" name="number-of-positions" value="{{ ballot|length }}">
                        <input type="hidden" name="name-of-election" value="{{ electionUuid }}">

                        <div class="accordion" id="ballotAccordion">
                            {% for item in ballot %}
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading-{{ item.position.position_id }}">
                                        <button class="accordion-button {% if not loop.first %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{ item.position.position_id }}">
                                            <div class="d-flex align-items-center w-100">
                                                <span class="me-3 opacity-25 fw-900">{{ "%02d"|format(loop.index) }}</span>
                                                <span class="text-uppercase">{{ item.position.position_name }}</span>
                                            </div>
                                        </button>
                                    </h2>
                                    <div id="collapse-{{ item.position.position_id }}" class="accordion-collapse collapse {% if loop.first %}show{% endif %}" data-bs-parent="#ballotAccordion">
                                        <div class="accordion-body p-4 p-md-5">
                                            <input type="hidden" name="name-of-positions{{ loop.index0 }}" value="{{ item.position.position_id }}">
                                            
                                            {% if item.count < 1 %}
                                                <div class="text-center py-5 opacity-50">
                                                    <span class="material-symbols-outlined fs-1 mb-3">person_off</span>
                                                    <p class="mb-0 fw-600">No contestants found for this position.</p>
                                                </div>
                                                <input type="hidden" name="contestant{{ loop.index0 }}" value="">
                                                <input type="hidden" name="onecont{{ loop.index0 }}" value="">
                                            {% else %}
                                                <div class="row g-4 justify-content-center">
                                                    {% for contestant in item.contestants %}
                                                        <div class="col-sm-6 col-md-4 col-xl-3">
                                                            <div class="candidate-card" onclick="selectCandidate(this, 'cont_{{ contestant.contestant_id }}')">
                                                                <div class="check-badge">
                                                                    <span class="material-symbols-outlined fs-6">check</span>
                                                                </div>
                                                                
                                                                <div class="candidate-avatar">
                                                                    {% if contestant.cont_profile %}
                                                                        <img src="{{ PROOT }}media/uploadedprofile/{{ contestant.cont_profile }}" alt="Profile">
                                                                    {% else %}
                                                                        <span class="candidate-initials">
                                                                            {{ contestant.cont_fname|first }}{{ contestant.cont_lname|first }}
                                                                        </span>
                                                                    {% endif %}
                                                                </div>
                                                                
                                                                <div class="candidate-name">{{ contestant.cont_fname }} {{ contestant.cont_lname }}</div>
                                                                <div class="candidate-info">Ballot #{{ contestant.contestant_ballot_number }}</div>
                                                                
                                                                <div class="mt-auto w-100">
                                                                    {% if item.count > 1 %}
                                                                        <input type="radio" id="cont_{{ contestant.contestant_id }}" name="contestant{{ loop.parent.loop.index0 }}" value="{{ contestant.contestant_id }}" class="visually-hidden candidate-radio">
                                                                        <div class="btn btn-outline-dark btn-vote w-100">Select</div>
                                                                    {% else %}
                                                                        <div class="d-flex gap-2">
                                                                            <input type="radio" name="onecont{{ loop.parent.loop.index0 }}" id="cont_{{ contestant.contestant_id }}_yes" value="yes,{{ contestant.contestant_id }}" class="visually-hidden candidate-radio">
                                                                            <label for="cont_{{ contestant.contestant_id }}_yes" class="btn btn-outline-success btn-vote flex-grow-1">Yes</label>
                                                                            
                                                                            <input type="radio" name="onecont{{ loop.parent.loop.index0 }}" id="cont_{{ contestant.contestant_id }}_no" value="no,{{ contestant.contestant_id }}" class="visually-hidden candidate-radio">
                                                                            <label for="cont_{{ contestant.contestant_id }}_no" class="btn btn-outline-danger btn-vote flex-grow-1">No</label>
                                                                        </div>
                                                                    {% endif %}
                                                                </div>
                                                            </div>
                                                        </div>
                                                    {% endfor %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="submit-ballot-bar">
                            <button type="submit" name="submitVotes" id="submitBtn" class="btn-submit-ballot">
                                <span>Cast Your Ballot</span>
                                <span class="material-symbols-outlined fs-3">how_to_vote</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <footer class="pt-5 pb-0 position-relative overflow-hidden mt-5" style="background: #f8f9f5; border-top: 1px solid var(--border-color);">
        <div class="container position-relative" style="z-index: 10;">
            <div class="row py-4 small fw-600" style="color: #718783;">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    &copy; {{ "now"|date("Y") }} All rights reserved
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <a href="mailto:info@puubu.com" class="text-decoration-none" style="color: inherit;">info@puubu.com</a>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <a href="#" class="text-decoration-none" style="color: inherit;">Privacy Policy</a>
                </div>
            </div>
        </div>
        
        <div class="footer-giant-text select-none">
            PUUBU
        </div>

        <style>
            .footer-giant-text {
                font-size: clamp(10rem, 25vw, 30rem);
                font-weight: 900;
                color: rgba(29, 61, 55, 0.03);
                line-height: 0.8;
                margin-top: -2rem;
                margin-bottom: -5rem;
                text-align: center;
                letter-spacing: -0.05em;
                pointer-events: none;
                text-transform: uppercase;
                width: 100%;
            }
            .select-none {
                user-select: none;
                -webkit-user-select: none;
            }
        </style>
    </footer>
{% endblock %}

{% block scripts %}
<script>
    function selectCandidate(card, radioId) {
        const radio = document.getElementById(radioId);
        if (radio) {
            radio.checked = true;
            // Trigger change event manually
            $(radio).trigger('change');
        }
    }

    $(document).ready(function() {
        {% if started_election > 0 %}
            var countDownDate = {{ voter.ends_at|date('U') }} * 1000;
            var x = setInterval(function() {
                var now = Date.now();
                var distance = countDownDate - now;
                var days = Math.floor(distance / (1000 * 60 * 60 * 24));
                var hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                var seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById('countDT').innerHTML = 
                    '<span class="material-symbols-outlined">schedule</span> ' + 
                    (days > 0 ? days + "d " : "") + hours + "h " + minutes + "m " + seconds + "s remaining";

                if (distance < 0) {
                    clearInterval(x);
                    document.getElementById('countDT').innerHTML = "ELECTION ENDED";
                    document.getElementById('countDT').style.color = "#94a3b8";
                    window.location = '{{ PROOT }}votingon';
                }
            }, 1000);
        {% endif %}

        $('.candidate-radio').on('change', function() {
            const nameGroup = $(this).attr('name');
            // Remove selected class from all cards in the same group
            $(`input[name="${nameGroup}"]`).closest('.candidate-card').removeClass('selected');
            
            // Add selected class to the checked one
            if($(this).is(':checked')) {
                $(this).closest('.candidate-card').addClass('selected');
            }
        });
    });
</script>
{% endblock %}
