{% extends "layout.twig" %}

{% block title %}Voter Dashboard • Kokuromotie{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-accent: #dcf3b0;
        --dark-accent: #1d3d37;
        --light-bg: #fdfcf5;
        --card-bg: #ffffff;
        --border-color: rgba(29, 61, 55, 0.08);
    }

    body {
        background: var(--light-bg);
        color: var(--dark-accent);
        font-family: 'Outfit', sans-serif;
    }

    .dashboard-nav {
        background: rgba(253, 252, 245, 0.8) !important;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid var(--border-color);
        padding: 0.75rem 0;
        z-index: 1000;
    }

    .brand-icon {
        width: 42px;
        height: 42px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .brand-logo-img {
        width: 100%;
        height: 100%;
        object-fit: contain;
    }

    .nav-user-pill {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 6px 6px 6px 16px;
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 100px;
        transition: all 0.3s ease;
    }

    .nav-user-pill:hover {
        border-color: rgba(29, 61, 55, 0.2);
        box-shadow: 0 4px 12px rgba(29, 61, 55, 0.05);
    }

    .nav-avatar {
        width: 32px;
        height: 32px;
        background: var(--primary-accent);
        color: var(--dark-accent);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 0.75rem;
    }

    .nav-signout {
        color: #ef4444;
        background: #fef2f2;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        text-decoration: none;
    }

    .nav-signout:hover {
        background: #ef4444;
        color: white;
    }

    .brand-text {
        letter-spacing: -1px;
        color: var(--dark-accent);
        font-size: 1.5rem;
    }

    .brand-text .bu-part {
        background: linear-gradient(135deg, #4ade80, #10b981);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
    }

    .dashboard-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        padding: 100px 0 60px;
        position: relative;
        overflow: hidden;
    }

    .dashboard-section::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background-image: radial-gradient(circle at 80% 20%, rgba(220, 243, 176, 0.25), transparent 40%),
                          radial-gradient(circle at 20% 80%, rgba(29, 61, 55, 0.03), transparent 40%);
        z-index: 0;
    }

    .welcome-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 40px;
        padding: 60px;
        position: relative;
        z-index: 10;
        box-shadow: 0 40px 80px -20px rgba(29, 61, 55, 0.08);
        text-align: center;
    }

    .user-avatar-initials {
        width: 80px;
        height: 80px;
        background: var(--primary-accent);
        color: var(--dark-accent);
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 800;
        margin: 0 auto 32px;
        box-shadow: 0 10px 20px rgba(220, 243, 176, 0.4);
    }

    .welcome-badge {
        background: rgba(29, 61, 55, 0.05);
        color: #718783;
        padding: 6px 16px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 20px;
        display: inline-block;
    }

    .voter-name {
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 800;
        color: var(--dark-accent);
        letter-spacing: -1.5px;
        margin-bottom: 16px;
    }

    .election-info {
        font-size: 1.15rem;
        color: #718783;
        max-width: 500px;
        margin: 0 auto 40px;
        line-height: 1.6;
    }

    .timer-box {
        background: #f8f9f5;
        border: 2px solid var(--border-color);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 48px;
        display: inline-block;
        min-width: 300px;
    }

    .timer-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 8px;
    }

    #countDT {
        font-family: 'Outfit', sans-serif;
        transition: all 0.3s ease;
    }
    .timer-box #countDT {
        font-size: 2.5rem;
        font-weight: 900;
        color: #ef4444;
        letter-spacing: -1px;
    }

    .btn-start {
        background: var(--dark-accent);
        color: white !important;
        border: none;
        padding: 20px 50px;
        border-radius: 18px;
        font-weight: 700;
        font-size: 1.2rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        box-shadow: 0 20px 40px -10px rgba(29, 61, 55, 0.3);
    }

    .btn-start:hover {
        background: #132e29;
        transform: translateY(-4px);
        box-shadow: 0 25px 50px -10px rgba(29, 61, 55, 0.4);
    }

    .btn-signout {
        color: #718783 !important;
        font-weight: 600;
        padding: 20px 40px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-signout:hover {
        color: #ef4444 !important;
    }

    /* Premium Security & Sync UI */
    .premium-security-notice {
        background: #fef2f2;
        border: 1px solid rgba(239, 68, 68, 0.1);
        border-radius: 20px;
        padding: 20px;
        text-align: left;
    }
    .notice-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .notice-label {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }
    .badge-intelligence {
        background: var(--dark-accent);
        color: var(--primary-accent);
        padding: 6px 16px;
        border-radius: 100px;
        font-size: 0.7rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        display: inline-block;
    }
    .matrix-timer {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 32px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(29, 61, 55, 0.04);
        position: relative;
        overflow: hidden;
    }
    .matrix-timer #countDT {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--dark-accent);
        letter-spacing: -2px;
        line-height: 1;
    }
    .matrix-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #718783;
        margin-bottom: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .matrix-timer {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--dark-accent);
        letter-spacing: -2px;
        line-height: 1;
    }
    .matrix-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 6px;
        background: #f1f5f9;
    }
    .progress-bar-loading {
        height: 100%;
        width: 40%;
        background: var(--primary-accent);
        border-radius: 0 100px 100px 0;
        animation: loading-shimmer 2s infinite ease-in-out;
    }
    @keyframes loading-shimmer {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(250%); }
    }
    .synchronization-card {
        background: #f8fafc;
        border-radius: 24px;
        padding: 24px;
        border: 1px solid rgba(29, 61, 55, 0.05);
    }
    .card-icon {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .fw-900 { font-weight: 900; }
    .animate-pulse {
        animation: pulse-sync 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    @keyframes pulse-sync {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: .7; transform: scale(0.98); }
    }
</style>
{% endblock %}

{% block content %}
    <nav class="navbar navbar-expand-lg dashboard-nav fixed-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" href="{{ PROOT }}votingon">
                <div class="brand-icon me-2">
                    <img src="{{ PROOT }}media/logo.svg" alt="Kokuromotie Logo" class="brand-logo-img">
                </div>
                <span class="h4 mb-0 brand-text fw-bold text-uppercase" style="letter-spacing: -1px;">KOKURO<span style="color: #a3e635 !important;">MOTIE</span></span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <div class="nav-user-pill d-none d-md-flex">
                    <span class="small fw-bold text-muted">{{ voter.first_name }} {{ voter.last_name }}</span>
                    <div class="nav-avatar">
                        {{ voter.first_name|first }}{{ voter.last_name|first }}
                    </div>
                    <a href="{{ PROOT }}auth/logout" class="nav-signout" title="Sign Out">
                        <span class="material-symbols-outlined fs-6">logout</span>
                    </a>
                </div>
                <a href="{{ PROOT }}auth/logout" class="nav-signout d-md-none">
                    <span class="material-symbols-outlined fs-6">logout</span>
                </a>
            </div>
        </div>
    </nav>

    <section class="dashboard-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8 col-xl-7">
                    <div class="welcome-card">
                        <div class="user-avatar-initials">
                            {{ voter.first_name|first }}{{ voter.last_name|first }}
                        </div>
                        
                        <span class="welcome-badge">Authentication Verified</span>
                        <h1 class="voter-name">Welcome, {{ voter.first_name }}</h1>
                        <p class="election-info">
                            You are authorized to vote in the <span class="text-dark fw-700">{{ voter.election_title }}</span>. Your vote is strictly private and encrypted.
                        </p>

                        <div id="activeActions">
                            {% if session.flash_error %}
                                <div class="premium-security-notice mb-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="notice-icon bg-danger text-white">
                                            <span class="material-symbols-outlined">gpp_maybe</span>
                                        </div>
                                        <div class="text-start">
                                            <div class="notice-label text-danger">Protocol Restriction</div>
                                            <div class="notice-text fw-bold text-dark">{{ session.flash_error|raw }}</div>
                                        </div>
                                    </div>
                                </div>
                            {% endif %}

                            {% if has_voted %}
                                <div class="voted-notice-wrapper mb-5">
                                    <div class="icon-circle mb-4 bg-success-subtle text-success">
                                        <span class="material-symbols-outlined fs-1">verified</span>
                                    </div>
                                    <h2 class="fw-800 mb-3" style="letter-spacing: -1px;">Ballot Cast Successfully</h2>
                                    <p class="text-secondary lead-sm mb-4">Your vote has been securely recorded and encrypted. Multiple voting is strictly prohibited to maintain electoral integrity.</p>
                                    
                                    <div class="d-flex justify-content-center">
                                        <a href="{{ PROOT }}auth/logout" class="btn-start bg-secondary">
                                            Logout Securely
                                            <span class="material-symbols-outlined">logout</span>
                                        </a>
                                    </div>
                                </div>
                            {% elseif not_started_yet %}
                                <div class="temporal-sync-container mb-5">
                                    <div class="sync-header mb-4">
                                        <span class="badge-intelligence animate-pulse">Pending Activation</span>
                                        <h2 class="fw-900 mt-2 mb-0">Temporal Synchronization</h2>
                                    </div>

                                    <div class="matrix-timer mb-5">
                                        <div class="matrix-label">Electoral Cluster Deployment In</div>
                                        <div id="countDT" class="matrix-timer">Initializing...</div>
                                        <div class="matrix-progress">
                                            <div class="progress-bar-loading"></div>
                                        </div>
                                    </div>

                                    <div class="synchronization-card text-start">
                                        <div class="d-flex gap-3 align-items-start">
                                            <div class="card-icon bg-primary-accent text-dark">
                                                <span class="material-symbols-outlined">schedule</span>
                                            </div>
                                            <div>
                                                <h6 class="fw-bold mb-1">Session Parameters</h6>
                                                <p class="small text-muted mb-0">The cluster is scheduled to activate on <strong>{{ voter.starts_at|date("M j, Y, g:i a") }}</strong>. Your biometric token will be validated automatically at that time.</p>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-5 d-flex flex-column align-items-center">
                                        <a href="{{ PROOT }}auth/logout" class="btn-signout fw-bold">
                                            <span class="material-symbols-outlined fs-6 align-middle">logout</span> Abort Session Wait
                                        </a>
                                    </div>
                                </div>
                            {% else %}
                                <div class="timer-box mb-5">
                                    <div class="timer-label">Session Termination In</div>
                                    <div id="countDT">Initializing...</div>
                                </div>

                                <div class="d-flex flex-column flex-md-row align-items-center justify-content-center gap-3">
                                    <a href="{{ PROOT }}startvote" class="btn-start">
                                        Start Voting
                                        <span class="material-symbols-outlined">how_to_vote</span>
                                    </a>
                                    <a href="{{ PROOT }}auth/logout" class="btn-signout">
                                        Sign Out
                                    </a>
                                </div>
                            {% endif %}
                        </div>

                        <div id="endedActions" style="display: none;">
                            <div class="ended-notice-wrapper mb-5">
                                <div class="icon-circle mb-4">
                                    <span class="material-symbols-outlined fs-1">verified</span>
                                </div>
                                <h2 class="fw-800 mb-3" style="letter-spacing: -1px;">Election has Concluded</h2>
                                <p class="text-secondary lead-sm mb-0">The voting session is officially closed. Thank you for making your voice heard.</p>
                            </div>
                            
                            <div class="d-grid">
                                <a href="{{ PROOT }}auth/logout" class="btn-start justify-content-center py-4">
                                    Logout to Secure Session
                                    <span class="material-symbols-outlined">logout</span>
                                </a>
                            </div>
                        </div>

                        <style>
                            .ended-notice-wrapper {
                                padding: 20px 0;
                            }
                            .icon-circle {
                                width: 80px;
                                height: 80px;
                                background: #f8f9f5;
                                color: var(--dark-accent);
                                border-radius: 50%;
                                display: flex;
                                align-items: center;
                                justify-content: center;
                                margin: 0 auto;
                                border: 1px solid var(--border-color);
                            }
                            .lead-sm {
                                font-size: 1.1rem;
                                line-height: 1.6;
                            }
                        </style>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="pt-5 pb-0 position-relative overflow-hidden" style="background: #f8f9f5; border-top: 1px solid var(--border-color);">
        <div class="container position-relative" style="z-index: 10;">
            <div class="row py-4 small fw-600" style="color: #718783;">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    &copy; {{ "now"|date("Y") }} All rights reserved
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <a href="mailto:info@Kokuromotie.com" class="text-decoration-none" style="color: inherit;">info@Kokuromotie.com</a>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <a href="#" class="text-decoration-none" style="color: inherit;">Privacy Policy</a>
                </div>
            </div>
        </div>
        
        <div class="footer-giant-text select-none">
            Kokuromotie
        </div>

        <style>
            .footer-giant-text {
                font-size: clamp(10rem, 25vw, 30rem);
                font-weight: 900;
                color: rgba(29, 61, 55, 0.03);
                line-height: 0.8;
                margin-top: -2rem;
                margin-bottom: -5rem;
                text-align: center;
                letter-spacing: -0.05em;
                pointer-events: none;
                text-transform: uppercase;
                width: 100%;
            }
            .select-none {
                user-select: none;
                -webkit-user-select: none;
            }
        </style>
    </footer>
{% endblock %}

{% block scripts %}
<script type="text/javascript">
    $(document).ready(function() {
        {% if remaining_seconds > 0 %}
            var distance = {{ remaining_seconds }};
            
            // Check initial state
            {% if has_ended %}
                document.getElementById('activeActions').style.display = 'none';
                document.getElementById('endedActions').style.display = 'block';
            {% endif %}

            var x = setInterval(function() {
                distance--;
                
                var days = Math.floor(distance / (60 * 60 * 24));
                var hours = Math.floor((distance % (60 * 60 * 24)) / (60 * 60));
                var minutes = Math.floor((distance % (60 * 60)) / 60);
                var seconds = Math.floor(distance % 60);

                if (document.getElementById('countDT')) {
                    document.getElementById('countDT').innerHTML = (days > 0 ? days + "d " : "") + hours + "h " + minutes + "m " + seconds + "s";
                }

                if (distance < 0) {
                    clearInterval(x);
                    if (document.getElementById('countDT')) {
                        document.getElementById('countDT').innerHTML = "{% if not_started_yet %}SESSION STARTING...{% else %}ELECTION ENDED{% endif %}";
                    }
                    
                    // Reload to refresh UI (e.g. show "Start Voting" button when countdown to start hits zero)
                    setTimeout(function() {
                        window.location.reload();
                    }, 2000);
                }
            }, 1000);
        {% endif %}
    });
</script>
{% endblock %}

