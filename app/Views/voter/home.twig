{% extends "layout.twig" %}

{% block title %}Puubu • Secure Digital Voting Platform{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    .hero-section {
        min-height: 100vh;
        background: radial-gradient(circle at top right, rgba(79, 70, 229, 0.15), transparent),
                    radial-gradient(circle at bottom left, rgba(124, 58, 237, 0.1), transparent),
                    #0f172a;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding-top: 120px;
        padding-bottom: 80px;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        width: 200%;
        height: 200%;
        top: -50%;
        left: -50%;
        background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        animation: rotate-bg 240s linear infinite;
        z-index: 1;
    }

    .hero-section > .container {
        position: relative;
        z-index: 10;
    }

    @keyframes rotate-bg {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .glass-nav {
        background: rgba(15, 23, 42, 0.9) !important;
        backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid var(--glass-border);
        transition: all 0.3s ease;
        padding: 1.5rem 0;
    }

    .brand-text {
        font-family: 'Outfit', sans-serif;
        letter-spacing: -1px;
    }

    .hero-badge {
        background: rgba(79, 70, 229, 0.1);
        border: 1px solid rgba(79, 70, 229, 0.2);
        padding: 10px 24px;
        border-radius: 100px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: #818cf8;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 40px;
        backdrop-filter: blur(4px);
    }

    .hero-title {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        line-height: 1.05;
        font-weight: 800;
        color: white;
        margin-bottom: 30px;
        letter-spacing: -2px;
    }

    .btn-premium {
        background: var(--primary-gradient);
        color: white !important;
        border: none;
        padding: 20px 40px;
        border-radius: 18px;
        font-weight: 700;
        font-size: 1.15rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 14px;
        box-shadow: 0 20px 40px -12px rgba(79, 70, 229, 0.4);
        text-decoration: none;
        position: relative;
        z-index: 20;
        pointer-events: auto;
    }

    .btn-premium:hover {
        transform: translateY(-5px) scale(1.02);
        box-shadow: 0 30px 60px -12px rgba(79, 70, 229, 0.5);
    }

    .floating-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(24px);
        border-radius: 40px;
        padding: 48px;
        animation: float-anim 6s ease-in-out infinite;
        position: relative;
        z-index: 1;
        box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.5);
    }

    @keyframes float-anim {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(1deg); }
    }

    .feature-item {
        display: flex;
        gap: 24px;
        margin-bottom: 32px;
    }

    .feature-icon {
        width: 56px;
        height: 56px;
        background: linear-gradient(135deg, rgba(79, 70, 229, 0.2) 0%, rgba(124, 58, 237, 0.2) 100%);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #818cf8;
        flex-shrink: 0;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
</style>
{% endblock %}

{% block content %}
    <nav class="navbar navbar-expand-lg glass-nav fixed-top py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" href="{{ PROOT }}">
                <span class="material-symbols-outlined text-primary me-2 fs-3">inventory_2</span>
                <span class="h4 mb-0 text-white brand-text fw-bold">Puu<span class="text-primary">Bu</span></span>
            </a>
            <div class="ms-auto">
                <a href="{{ PROOT }}admin/signin?token={{ ADMIN_TOKEN }}" class="btn btn-outline-primary border-primary border-opacity-25 rounded-pill px-4 fw-bold small text-white text-decoration-none transition-all">
                    Admin Portal
                </a>
            </div>
        </div>
    </nav>

    <section class="hero-section min-vh-100">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-7">
                    <div class="hero-badge">
                        <span class="material-symbols-outlined fs-6 text-primary">verified</span>
                        Voter Identity Management & Secured Ballot System
                    </div>
                    <h1 class="hero-title">The Future of <br>Digital Democracy.</h1>
                    <p class="lead text-muted mb-5 fs-5 pe-lg-5">
                        Experience a new standard in transparent, secure, and accessible elections. Puubu provides end-to-end encryption and real-time auditing for the modern electorate.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="{{ PROOT }}signin" class="btn btn-premium">
                            Access Voter Portal
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                        <div class="d-flex align-items-center ms-md-4 mt-3 mt-md-0">
                            <div class="avatar-group d-flex me-3">
                                <div class="avatar avatar-xs rounded-circle bg-primary text-white d-flex align-items-center justify-content-center border border-dark" style="width: 32px; height: 32px; font-size: 10px;">JD</div>
                                <div class="avatar avatar-xs rounded-circle bg-success text-white d-flex align-items-center justify-content-center border border-dark ms-n2" style="width: 32px; height: 32px; font-size: 10px;">AS</div>
                                <div class="avatar avatar-xs rounded-circle bg-warning text-white d-flex align-items-center justify-content-center border border-dark ms-n2" style="width: 32px; height: 32px; font-size: 10px;">+</div>
                            </div>
                            <div class="small text-muted">
                                <span class="text-white fw-bold">12.5k+</span> Voters trust Puubu
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="floating-card">
                        <div class="feature-item">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">lock</span>
                            </div>
                            <div>
                                <h6 class="text-white fw-bold mb-1">Encrypted Ballots</h6>
                                <p class="small text-muted mb-0">Your vote is protected by military-grade AES-256 encryption.</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">analytics</span>
                            </div>
                            <div>
                                <h6 class="text-white fw-bold mb-1">Real-time Auditing</h6>
                                <p class="small text-muted mb-0">Transparent result tracking as votes are cast across the platform.</p>
                            </div>
                        </div>
                        <div class="feature-item mb-0">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">fingerprint</span>
                            </div>
                            <div>
                                <h6 class="text-white fw-bold mb-1">Identity Verification</h6>
                                <p class="small text-muted mb-0">Strict multi-factor authentication to ensure "One Person, One Vote".</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="py-4 border-top border-white border-opacity-10 bg-darker">
        <div class="container text-center">
            <p class="text-muted small mb-0">&copy; {{ "now"|date("Y") }} Puubu Voting Systems. All rights reserved.</p>
        </div>
    </footer>
{% endblock %}
