{% extends "layout.twig" %}

{% block title %}Kokuromotie • Secure Digital Voting Platform{% endblock %}

{% block styles %}
<style>
    :root {
        --primary-accent: #dcf3b0;
        --dark-accent: #1d3d37;
        --light-bg: #fdfcf5;
        --card-bg: #ffffff;
        --border-color: rgba(29, 61, 55, 0.08);
    }

    .hero-section {
        min-height: 100vh;
        background-color: var(--light-bg);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        padding-top: 100px;
        padding-bottom: 80px;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background-image: radial-gradient(circle at 80% 20%, rgba(220, 243, 176, 0.3), transparent 40%),
                          radial-gradient(circle at 20% 80%, rgba(29, 61, 55, 0.03), transparent 40%);
        z-index: 1;
    }

    .hero-section > .container {
        position: relative;
        z-index: 10;
    }

    .glass-nav {
        background: rgba(253, 252, 245, 0.8) !important;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border-color);
        transition: all 0.3s ease;
        padding: 1rem 0;
    }

    .brand-icon-wrapper {
        width: 42px;
        height: 42px;
        background: var(--dark-accent);
        color: var(--primary-accent);
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(29, 61, 55, 0.15);
    }

    .brand-text {
        font-family: 'Outfit', sans-serif;
        letter-spacing: -0.5px;
        color: var(--dark-accent) !important;
    }

    .hero-badge {
        background: var(--primary-accent);
        border: 1px solid rgba(29, 61, 55, 0.05);
        padding: 8px 24px;
        border-radius: 100px;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        color: var(--dark-accent);
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 32px;
        box-shadow: 0 4px 12px rgba(220, 243, 176, 0.3);
    }

    .hero-title {
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        line-height: 1.05;
        font-weight: 800;
        color: var(--dark-accent);
        margin-bottom: 24px;
        letter-spacing: -2px;
    }

    .btn-premium {
        background: var(--dark-accent);
        color: white !important;
        border: none;
        padding: 20px 40px;
        border-radius: 18px;
        font-weight: 700;
        font-size: 1.15rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        display: inline-flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        position: relative;
        z-index: 20;
    }

    .btn-premium:hover {
        background: #132e29;
        transform: translateY(-3px);
        box-shadow: 0 15px 30px -5px rgba(29, 61, 55, 0.2);
    }

    .floating-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 40px;
        padding: 48px;
        position: relative;
        z-index: 1;
        box-shadow: 0 40px 80px -20px rgba(29, 61, 55, 0.08);
    }

    .feature-item {
        display: flex;
        gap: 24px;
        margin-bottom: 32px;
    }

    .feature-icon {
        width: 56px;
        height: 56px;
        background: var(--primary-accent);
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--dark-accent);
        flex-shrink: 0;
        border: 1px solid rgba(0, 0, 0, 0.03);
    }
</style>
{% endblock %}

{% block content %}
    <nav class="navbar navbar-expand-lg glass-nav fixed-top py-3">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-decoration-none" href="{{ PROOT }}">
                <div class="brand-icon-wrapper me-2 d-flex align-items-center justify-content-center">
                    <span class="material-symbols-outlined fs-3">shield_lock</span>
                </div>
                <span class="h4 mb-0 brand-text fw-bold text-uppercase" style="letter-spacing: -1px;">KOKURO<span style="color: #a3e635 !important;">MOTIE</span></span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-4">
                <a href="#features" class="nav-link fw-bold text-dark d-none d-md-block small text-uppercase tracking-wider opacity-75">Intelligence</a>
                <a href="{{ PROOT }}admin/signin?token={{ ADMIN_TOKEN }}" class="btn btn-dark rounded-pill px-4 py-2 fw-bold small shadow-sm d-flex align-items-center gap-2">
                    <span class="material-symbols-outlined fs-6">security</span>
                    Intelligence Portal
                </a>
            </div>
        </div>
    </nav>

    <section class="hero-section min-vh-100">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-7">
                    <div class="hero-badge">
                        <span class="material-symbols-outlined fs-6 text-primary">verified</span>
                        Voter Identity Management & Secured Ballot System
                    </div>
                    <h1 class="hero-title">The Future of <br>Digital Democracy.</h1>
                    <p class="lead text-muted mb-5 fs-5 pe-lg-5">
                        Experience a new standard in transparent, secure, and accessible elections. Kokuromotie provides end-to-end encryption and real-time auditing for the modern electorate.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a href="{{ PROOT }}signin" class="btn btn-premium">
                            Access Voter Portal
                            <span class="material-symbols-outlined">arrow_forward</span>
                        </a>
                        <div class="d-flex align-items-center ms-md-4 mt-3 mt-md-0">
                            <div class="avatar-group d-flex me-3">
                                <div class="avatar avatar-xs rounded-circle bg-primary text-white d-flex align-items-center justify-content-center border border-dark" style="width: 32px; height: 32px; font-size: 10px;">JD</div>
                                <div class="avatar avatar-xs rounded-circle bg-success text-white d-flex align-items-center justify-content-center border border-dark ms-n2" style="width: 32px; height: 32px; font-size: 10px;">AS</div>
                                <div class="avatar avatar-xs rounded-circle bg-warning text-white d-flex align-items-center justify-content-center border border-dark ms-n2" style="width: 32px; height: 32px; font-size: 10px;">+</div>
                            </div>
                            <div class="small text-muted">
                                <span class="fw-bold" style="color: var(--dark-accent);">12.5k+</span> Voters trust Kokuromotie
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-5 d-none d-lg-block">
                    <div class="floating-card">
                        <div class="feature-item">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">lock</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color: var(--dark-accent);">Encrypted Ballots</h6>
                                <p class="small text-muted mb-0">Your vote is protected by military-grade AES-256 encryption.</p>
                            </div>
                        </div>
                        <div class="feature-item">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">analytics</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color: var(--dark-accent);">Real-time Auditing</h6>
                                <p class="small text-muted mb-0">Transparent result tracking as votes are cast across the platform.</p>
                            </div>
                        </div>
                        <div class="feature-item mb-0">
                            <div class="feature-icon">
                                <span class="material-symbols-outlined">fingerprint</span>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1" style="color: var(--dark-accent);">Identity Verification</h6>
                                <p class="small text-muted mb-0">Strict multi-factor authentication to ensure "One Person, One Vote".</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="pt-5 pb-0 position-relative overflow-hidden" style="background: #f8f9f5; border-top: 1px solid var(--border-color);">
        <div class="container position-relative" style="z-index: 10;">
            <div class="row py-4 small fw-600" style="color: #718783;">
                <div class="col-md-4 text-center text-md-start mb-3 mb-md-0">
                    &copy; {{ "now"|date("Y") }} All rights reserved
                </div>
                <div class="col-md-4 text-center mb-3 mb-md-0">
                    <a href="mailto:info@Kokuromotie.com" class="text-decoration-none" style="color: inherit;">info@Kokuromotie.com</a>
                </div>
                <div class="col-md-4 text-center text-md-end">
                    <a href="#" class="text-decoration-none" style="color: inherit;">Privacy Policy</a>
                </div>
            </div>
        </div>
        
        <div class="footer-giant-text select-none">
            Kokuromotie
        </div>

        <style>
            .footer-giant-text {
                font-size: clamp(10rem, 25vw, 30rem);
                font-weight: 900;
                color: rgba(29, 61, 55, 0.03);
                line-height: 0.8;
                margin-top: -2rem;
                margin-bottom: -5rem;
                text-align: center;
                letter-spacing: -0.05em;
                pointer-events: none;
                text-transform: uppercase;
                width: 100%;
            }
            .select-none {
                user-select: none;
                -webkit-user-select: none;
            }
        </style>
    </footer>
{% endblock %}

